# ─── Text (required) ──────────────────────────────────────────────
# The Anthropic key is what writes the stories.
ANTHROPIC_API_KEY=
# Model used to write the stories (fine as-is).
STORY_MODEL=claude-opus-4-8

# ─── Database — Turso cloud (required) ────────────────────────────
# The app uses ONLY a remote Turso database (no local mode).
# Network required. See the README to create the db and get these values.
DATABASE_URL=libsql://<your-db>.turso.io
TURSO_AUTH_TOKEN=

# ─── Images (optional) — disabled by default ──────────────────────
# Set IMAGE_ENABLED=true and fill GEMINI_API_KEY for illustrations.
IMAGE_ENABLED=false
GEMINI_API_KEY=
IMAGE_MODEL=gemini-2.5-flash-image

# ─── Voice (optional) — disabled by default ───────────────────────
# Set TTS_ENABLED=true for the "Listen" button.
# TTS_PROVIDER=edge (free, French voices) or elevenlabs (premium).
TTS_ENABLED=false
TTS_PROVIDER=edge
ELEVENLABS_API_KEY=

# ─── Branding (optional) ──────────────────────────────────────────
# Personalize without touching the code (defaults in src/config/app.ts).
# VITE_CHILD_NAME=Léa derives everything: app name "L'atelier de Léa"
# (browser tab + home header) and booklet footer "Une histoire de Léa"
# ("de" elides to "d'" before a vowel: Arsène → "d'Arsène").
VITE_CHILD_NAME=
# Full-string overrides, when the derived phrasing doesn't fit:
VITE_APP_NAME=
VITE_APP_DESCRIPTION=
VITE_STORY_LABEL=

# ─── Misc ─────────────────────────────────────────────────────────
DEFAULT_LANG=fr
# Disk folder for generated images/audio (the db stays on Turso; in Docker
# this is the app-data volume). On an ephemeral filesystem (no volume), set
# BLOB_READ_WRITE_TOKEN instead (Vercel Blob).
DATA_DIR=./data
# Extra hostnames the Vite DEV server accepts (Vite blocks unknown Host
# headers). Only needed when reaching `bun run dev` through a reverse proxy
# or tunnel; comma-separated. Keep real domains in the gitignored .env.
DEV_ALLOWED_HOSTS=
