{"type":"item.completed","item":{"id":"item_24","type":"command_execution","command":"/usr/bin/zsh -lc \"git show main:src/server/providers/image/nanobanana.ts | nl -ba | sed -n '1,180p'; nl -ba src/server/providers/image/nanobanana.ts | sed -n '1,180p'; rg -n \\\"z\\\\.object\\\\(|z\\\\.enum\\\\(|schema:\\\" <(git diff main...HEAD -- '*.ts' '*.tsx') 2>/dev/null || true\"","aggregated_output":"     1\timport { createGoogleGenerativeAI } from \"@ai-sdk/google\";\n     2\timport { generateText } from \"ai\";\n     3\timport { serverEnv } from \"~/env\";\n     4\timport { generateId } from \"~/lib/id-generator\";\n     5\timport { saveMedia } from \"~/server/providers/media-store\";\n     6\timport type { ImageProvider } from \"~/server/providers/types\";\n     7\t\n     8\t// Gemini image models bill per OUTPUT token at $30 / 1M tokens; a standard\n     9\t// (<=1024px) image is ~1290 output tokens ≈ $0.039/image. We estimate cost from\n    10\t// the usage tokens the SDK returns, falling back to a flat per-image price.\n    11\t// Source: https://ai.google.dev/gemini-api/docs/pricing (2026-06).\n    12\tconst IMAGE_USD_PER_OUTPUT_TOKEN = 30 / 1_000_000;\n    13\tconst IMAGE_USD_PER_IMAGE = 0.039;\n    14\t\n    15\t/**\n    16\t * Nano Banana = Google's gemini image family, accessed through the Gemini API\n    17\t * via the Vercel AI SDK's Google provider. The model returns image files\n    18\t * inline; we persist the first one under DATA_DIR and return its web path. The\n    19\t * `model` arg (already allowlist-resolved by the caller) overrides the env\n    20\t * default per request so a parent can compare models; all offered models share\n    21\t * this exact call shape, so only the model-id arg changes.\n    22\t *\n    23\t * Behind IMAGE_ENABLED — the caller decides whether to invoke this at all.\n    24\t *\n    25\t * COST: Gemini image models bill per OUTPUT token and are resolution-tiered, so\n    26\t * we pin a LOW output resolution via `providerOptions.google.imageConfig`\n    27\t * (`imageSize` from `IMAGE_RESOLUTION`, default \"1K\") + `aspectRatio: \"4:3\"` to\n    28\t * match the modest 4/3 display container (no wasted pixels, no crop). These are\n    29\t * the @ai-sdk/google `imageConfig` schema fields. A model that doesn't support\n    30\t * imageConfig (e.g. gemini-2.5-flash-image) just ignores it — no crash.\n    31\t *\n    32\t * CONSISTENCY: `referenceImage` (a prior illustration of the SAME story — blob\n    33\t * URL or local bytes) is sent as an IMAGE INPUT alongside the text prompt, the\n    34\t * standard Gemini-image technique for keeping characters/style stable across\n    35\t * independently-generated scenes. Without it every beat reinvented the\n    36\t * characters (hair color, clothes, age drifted page to page). Input images\n    37\t * bill as INPUT tokens (cheap) — the expensive part stays the output image.\n    38\t */\n    39\texport const nanoBananaImageProvider: ImageProvider = {\n    40\t  async generateImage(\n    41\t    prompt: string,\n    42\t    model?: string,\n    43\t    referenceImage?: Uint8Array | URL\n    44\t  ): Promise<string> {\n    45\t    if (!serverEnv.geminiApiKey) {\n    46\t      throw new Error(\"GEMINI_API_KEY manquante.\");\n    47\t    }\n    48\t\n    49\t    const google = createGoogleGenerativeAI({ apiKey: serverEnv.geminiApiKey });\n    50\t\n    51\t    const providerOptions = {\n    52\t      google: {\n    53\t        // Pin a low, display-matched output to cut cost (see header).\n    54\t        imageConfig: {\n    55\t          aspectRatio: \"4:3\",\n    56\t          imageSize: serverEnv.imageResolution,\n    57\t        },\n    58\t        responseModalities: [\"IMAGE\"],\n    59\t      },\n    60\t    };\n    61\t\n    62\t    const result = await generateText({\n    63\t      // A stalled Gemini call must fail (→ calm \"no drawing\" state) rather\n    64\t      // than hold the request open past any client reveal timeout.\n    65\t      abortSignal: AbortSignal.timeout(90_000),\n    66\t      model: google(model ?? serverEnv.imageModel),\n    67\t      ...(referenceImage\n    68\t        ? {\n    69\t            messages: [\n    70\t              {\n    71\t                content: [\n    72\t                  { image: referenceImage, type: \"image\" as const },\n    73\t                  { text: prompt, type: \"text\" as const },\n    74\t                ],\n    75\t                role: \"user\" as const,\n    76\t              },\n    77\t            ],\n    78\t          }\n    79\t        : { prompt }),\n    80\t      providerOptions,\n    81\t    });\n    82\t\n    83\t    const imageFile = result.files.find((f) =>\n    84\t      f.mediaType?.startsWith(\"image/\")\n    85\t    );\n    86\t    if (!imageFile) {\n    87\t      throw new Error(\"Aucune image renvoyée par le générateur d'image.\");\n    88\t    }\n    89\t\n    90\t    const usedModel = model ?? serverEnv.imageModel;\n    91\t    console.log(\n    92\t      `[image-gen] model=${usedModel} ref=${referenceImage ? \"yes\" : \"no\"} prompt=${prompt}`\n    93\t    );\n    94\t    try {\n    95\t      const outTokens = result.usage?.outputTokens;\n    96\t      const cost =\n    97\t        outTokens === undefined\n    98\t          ? IMAGE_USD_PER_IMAGE\n    99\t          : outTokens * IMAGE_USD_PER_OUTPUT_TOKEN;\n   100\t      const basis =\n   101\t        outTokens === undefined\n   102\t          ? \"flat per-image estimate\"\n   103\t          : `${outTokens} output tokens @ $30/1M`;\n   104\t      console.log(`[image-gen] cost≈$${cost.toFixed(4)} (${basis})`);\n   105\t    } catch {\n   106\t      // Never let cost logging break image generation.\n   107\t    }\n   108\t\n   109\t    const ext = imageFile.mediaType === \"image/jpeg\" ? \"jpg\" : \"png\";\n   110\t    const filename = `${generateId(\"img\")}.${ext}`;\n   111\t    return saveMedia(filename, imageFile.uint8Array);\n   112\t  },\n   113\t};\n     1\timport { createGoogleGenerativeAI } from \"@ai-sdk/google\";\n     2\timport { generateText } from \"ai\";\n     3\timport { serverEnv } from \"~/env\";\n     4\timport { generateId } from \"~/lib/id-generator\";\n     5\timport { saveMedia } from \"~/server/providers/media-store\";\n     6\t\n     7\t// Gemini image models bill per OUTPUT token at $30 / 1M tokens; a standard\n     8\t// (<=1024px) image is ~1290 output tokens ≈ $0.039/image. We estimate cost from\n     9\t// the usage tokens the SDK returns, falling back to a flat per-image price.\n    10\t// Source: https://ai.google.dev/gemini-api/docs/pricing (2026-06).\n    11\tconst IMAGE_USD_PER_OUTPUT_TOKEN = 30 / 1_000_000;\n    12\tconst IMAGE_USD_PER_IMAGE = 0.039;\n    13\t\n    14\t/**\n    15\t * Nano Banana = Google's gemini image family, accessed through the Gemini API\n    16\t * via the Vercel AI SDK's Google provider. The model returns image files\n    17\t * inline; we persist the first one under DATA_DIR and return its web path. The\n    18\t * `model` arg (already allowlist-resolved by the caller) overrides the env\n    19\t * default per request so a parent can compare models; all offered models share\n    20\t * this exact call shape, so only the model-id arg changes.\n    21\t *\n    22\t * Behind IMAGE_ENABLED — the caller decides whether to invoke this at all.\n    23\t *\n    24\t * COST: Gemini image models bill per OUTPUT token and are resolution-tiered, so\n    25\t * we pin a LOW output resolution via `providerOptions.google.imageConfig`\n    26\t * (`imageSize` from `IMAGE_RESOLUTION`, default \"1K\") + `aspectRatio: \"4:3\"` to\n    27\t * match the modest 4/3 display container (no wasted pixels, no crop). These are\n    28\t * the @ai-sdk/google `imageConfig` schema fields. A model that doesn't support\n    29\t * imageConfig (e.g. gemini-2.5-flash-image) just ignores it — no crash.\n    30\t *\n    31\t * CONSISTENCY: `referenceImage` (a prior illustration of the SAME story — blob\n    32\t * URL or local bytes) is sent as an IMAGE INPUT alongside the text prompt, the\n    33\t * standard Gemini-image technique for keeping characters/style stable across\n    34\t * independently-generated scenes. Without it every beat reinvented the\n    35\t * characters (hair color, clothes, age drifted page to page). Input images\n    36\t * bill as INPUT tokens (cheap) — the expensive part stays the output image.\n    37\t *\n    38\t * This is the app's SOLE image generation entry point (a plain module\n    39\t * function, imported by concrete name; there is deliberately no provider\n    40\t * interface — see the adapter-census note in `types.ts`). `model` overrides\n    41\t * the env default for THIS request (parent-pickable model; already\n    42\t * allowlist-resolved by the caller). `referenceImage` (URL for blob-hosted,\n    43\t * bytes for local-disk media) is a prior illustration of the SAME story, sent\n    44\t * alongside the prompt so the model keeps the characters/style consistent\n    45\t * across beats. Omitted → pure text-to-image (opening beat, or no prior image\n    46\t * available).\n    47\t */\n    48\texport async function generateImage(\n    49\t  prompt: string,\n    50\t  model?: string,\n    51\t  referenceImage?: Uint8Array | URL\n    52\t): Promise<string> {\n    53\t  if (!serverEnv.geminiApiKey) {\n    54\t    throw new Error(\"GEMINI_API_KEY manquante.\");\n    55\t  }\n    56\t\n    57\t  const google = createGoogleGenerativeAI({ apiKey: serverEnv.geminiApiKey });\n    58\t\n    59\t  const providerOptions = {\n    60\t    google: {\n    61\t      // Pin a low, display-matched output to cut cost (see header).\n    62\t      imageConfig: {\n    63\t        aspectRatio: \"4:3\",\n    64\t        imageSize: serverEnv.imageResolution,\n    65\t      },\n    66\t      responseModalities: [\"IMAGE\"],\n    67\t    },\n    68\t  };\n    69\t\n    70\t  const result = await generateText({\n    71\t    // A stalled Gemini call must fail (→ calm \"no drawing\" state) rather\n    72\t    // than hold the request open past any client reveal timeout.\n    73\t    abortSignal: AbortSignal.timeout(90_000),\n    74\t    model: google(model ?? serverEnv.imageModel),\n    75\t    ...(referenceImage\n    76\t      ? {\n    77\t          messages: [\n    78\t            {\n    79\t              content: [\n    80\t                { image: referenceImage, type: \"image\" as const },\n    81\t                { text: prompt, type: \"text\" as const },\n    82\t              ],\n    83\t              role: \"user\" as const,\n    84\t            },\n    85\t          ],\n    86\t        }\n    87\t      : { prompt }),\n    88\t    providerOptions,\n    89\t  });\n    90\t\n    91\t  const imageFile = result.files.find((f) => f.mediaType?.startsWith(\"image/\"));\n    92\t  if (!imageFile) {\n    93\t    throw new Error(\"Aucune image renvoyée par le générateur d'image.\");\n    94\t  }\n    95\t\n    96\t  const usedModel = model ?? serverEnv.imageModel;\n    97\t  console.log(\n    98\t    `[image-gen] model=${usedModel} ref=${referenceImage ? \"yes\" : \"no\"} prompt=${prompt}`\n    99\t  );\n   100\t  try {\n   101\t    const outTokens = result.usage?.outputTokens;\n   102\t    const cost =\n   103\t      outTokens === undefined\n   104\t        ? IMAGE_USD_PER_IMAGE\n   105\t        : outTokens * IMAGE_USD_PER_OUTPUT_TOKEN;\n   106\t    const basis =\n   107\t      outTokens === undefined\n   108\t        ? \"flat per-image estimate\"\n   109\t        : `${outTokens} output tokens @ $30/1M`;\n   110\t    console.log(`[image-gen] cost≈$${cost.toFixed(4)} (${basis})`);\n   111\t  } catch {\n   112\t    // Never let cost logging break image generation.\n   113\t  }\n   114\t\n   115\t  const ext = imageFile.mediaType === \"image/jpeg\" ? \"jpg\" : \"png\";\n   116\t  const filename = `${generateId(\"img\")}.${ext}`;\n   117\t  return saveMedia(filename, imageFile.uint8Array);\n   118\t}\n","exit_code":0,"status":"completed"}}
