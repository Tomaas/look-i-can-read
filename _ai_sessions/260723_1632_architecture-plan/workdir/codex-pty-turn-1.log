{"type":"item.completed","item":{"id":"item_22","type":"command_execution","command":"/usr/bin/zsh -lc \"git diff --unified=100 main...HEAD -- src/components/bureau/fenetre.tsx src/lib/bureau/clamp.ts src/lib/bureau/__tests__/bureau.golden.ts src/lib/bureau/__tests__/routes.golden.ts; nl -ba src/components/bureau/fenetre.tsx | sed -n '1,300p'; nl -ba src/lib/bureau/clamp.ts | sed -n '1,220p'; nl -ba src/lib/bureau/__tests__/routes.golden.ts | sed -n '1,260p'\"","aggregated_output":"diff --git a/src/components/bureau/fenetre.tsx b/src/components/bureau/fenetre.tsx\nindex 7f94430..180ad42 100644\n--- a/src/components/bureau/fenetre.tsx\n+++ b/src/components/bureau/fenetre.tsx\n@@ -1,285 +1,277 @@\n /**\n  * La fenêtre du bureau — le CADRE, pas le contenu (prémisse 6).\n  *\n  * Une vraie grammaire de fenêtre à taille d'enfant : barre de titre (seule\n  * zone de drag), grande croix douce ≥ 48 px toujours visible (jamais rouge —\n  * la croix a la sémantique de navigation EXISTANTE : un Link vers `/`), ni\n  * resize, ni minimize, ni maximize, ni z-order — une seule fenêtre à la fois.\n  *\n  * Géométrie (eng-review D23-A) : ~85 % du viewport — à ~92 % la course de\n  * drag n'était que quelques dizaines de pixels, un « déplacer la fenêtre »\n  * symbolique mé-enseigne. À chaque ouverture la fenêtre repart CENTRÉE\n  * (ceo-review D9-A) : le matériel revient toujours à sa place — aucune\n  * position persistée, la récupération d'une fenêtre « perdue » est la\n  * réouverture. Le centrage par défaut est 100 % CSS (inset 7.5vw/7.5vh) :\n  * aucune lecture de `window` pendant le rendu, SSR-safe (contrat D17-A).\n  *\n  * La position committée n'est JAMAIS un transform CSS (eng-review D24-A) :\n  * transform pendant le drag seulement, commit en `left/top` — un transform\n  * persistant ferait du cadre le containing block des descendants\n  * `position: fixed`, et le DragOverlay du pavé de /calcul rendrait décalé\n  * d'exactement la translation de la fenêtre. Même raison : pas de\n  * `will-change`/`filter` sur le cadre.\n  *\n  * Sous le point de rupture lg, la fenêtre rend PLEIN ÉCRAN sans drag, croix\n  * conservée (ceo-review D14-A) : les mini-apps ne sont jamais comprimées, la\n  * grammaire OS s'efface quand la place manque.\n  *\n  * Les capteurs du DndContext sont activés par la SEULE zone de titre (T5) :\n  * il ne peut jamais interférer avec le DndContext du pavé de /calcul qui vit\n  * à l'intérieur. À l'impression, le positionnement est neutralisé\n  * (`.bureau-fenetre` dans globals.css) : le contenu s'imprime comme avant.\n  */\n \n import {\n   DndContext,\n   type DragEndEvent,\n   PointerSensor,\n   useDraggable,\n   useSensor,\n   useSensors,\n } from \"@dnd-kit/core\";\n import { Link } from \"@tanstack/react-router\";\n import { X } from \"lucide-react\";\n import {\n   type ReactNode,\n   useEffect,\n   useRef,\n   useState,\n   useSyncExternalStore,\n } from \"react\";\n import { Button } from \"~/components/ui/button\";\n-import { clampFenetrePosition, type Position } from \"~/lib/bureau/clamp\";\n+import {\n+  clampFenetrePosition,\n+  type Position,\n+  reclampCommitted,\n+  type Taille,\n+} from \"~/lib/bureau/clamp\";\n import { cn } from \"~/lib/cn\";\n \n /** Hauteur de la barre de titre — appariée à la classe h-14 (56px) du cadre. */\n export const FENETRE_TITLE_BAR_HEIGHT = 56;\n \n // 4px of travel before a drag starts: a plain click on the title bar stays a\n // click. Hoisted for a stable useSensor options identity (same idiom as\n // /calcul's numpad sensor).\n const POINTER_ACTIVATION = { activationConstraint: { distance: 4 } };\n \n /** Le drag n'existe qu'au-dessus du breakpoint lg (D14-A). */\n const DESKTOP_QUERY = \"(min-width: 1024px)\";\n \n+/** Le viewport au moment du commit — lu au même instant que le rect. */\n+function viewportActuel(): Taille {\n+  return { height: window.innerHeight, width: window.innerWidth };\n+}\n+\n function subscribeDesktop(onChange: () => void) {\n   const media = window.matchMedia(DESKTOP_QUERY);\n   media.addEventListener(\"change\", onChange);\n   return () => media.removeEventListener(\"change\", onChange);\n }\n \n function useEstDesktop(): boolean {\n   return useSyncExternalStore(\n     subscribeDesktop,\n     () => window.matchMedia(DESKTOP_QUERY).matches,\n     // SSR: pas de lecture de window pendant le rendu (D17-A) — le faux\n     // n'active aucun style inline, la géométrie du premier paint est en CSS.\n     () => false\n   );\n }\n \n export interface FenetreProps {\n   children: ReactNode;\n   /** Le pictogramme de l'icône du bureau, repris dans la barre de titre. */\n   icone: ReactNode;\n   /** Le titre de la fenêtre = le libellé de l'icône (« Histoires »…). */\n   titre: string;\n }\n \n export function Fenetre({ children, icone, titre }: FenetreProps) {\n   const estDesktop = useEstDesktop();\n   // null = centrée par le CSS (l'état de CHAQUE ouverture) ; un point après\n   // le premier drag, committé en left/top.\n   const [position, setPosition] = useState<Position | null>(null);\n   const cadreRef = useRef<HTMLDivElement | null>(null);\n   const origineDragRef = useRef<Position | null>(null);\n   const sensors = useSensors(useSensor(PointerSensor, POINTER_ACTIVATION));\n \n   // L'invariant « barre entièrement visible » tient aussi au REDIMENSIONNEMENT\n   // du viewport (D11-A) : le même modifier pur re-borne la position committée.\n   const aUnePosition = position !== null;\n   useEffect(() => {\n     if (!(aUnePosition && estDesktop)) {\n       return;\n     }\n     function reclamp() {\n       if (origineDragRef.current) {\n         // Drag en vol : re-positionner sous le transform ferait sursauter la\n         // fenêtre — dragEnd re-borne de toute façon.\n         return;\n       }\n       const rect = cadreRef.current?.getBoundingClientRect();\n       if (!rect) {\n         return;\n       }\n-      setPosition((prev) => {\n-        if (!prev) {\n-          return prev;\n-        }\n-        const bornee = clampFenetrePosition(\n-          prev,\n-          { height: rect.height, width: rect.width },\n-          { height: window.innerHeight, width: window.innerWidth },\n-          FENETRE_TITLE_BAR_HEIGHT\n-        );\n-        // No-op → même référence : pas de re-rendu à chaque event resize\n-        // quand la fenêtre est loin des bords.\n-        return bornee.x === prev.x && bornee.y === prev.y ? prev : bornee;\n-      });\n+      // null-passthrough + no-op même référence : dans le helper pur —\n+      // pas de re-rendu à chaque event resize loin des bords.\n+      setPosition((prev) =>\n+        reclampCommitted(prev, rect, viewportActuel(), FENETRE_TITLE_BAR_HEIGHT)\n+      );\n     }\n     // Re-borne aussi à l'ATTACHE : le viewport a pu changer pendant\n     // l'interlude <lg (rotation, restore) où l'écouteur était détaché.\n     reclamp();\n     window.addEventListener(\"resize\", reclamp);\n     return () => window.removeEventListener(\"resize\", reclamp);\n   }, [aUnePosition, estDesktop]);\n \n   function handleDragStart() {\n     // Au départ du drag le transform est nul (jamais persisté) : le rect EST\n     // la position réelle, qu'elle vienne du CSS centré ou d'un left/top.\n     const rect = cadreRef.current?.getBoundingClientRect();\n     origineDragRef.current = rect ? { x: rect.left, y: rect.top } : null;\n   }\n \n   function handleDragEnd(event: DragEndEvent) {\n     const origine = origineDragRef.current;\n     origineDragRef.current = null;\n     const rect = cadreRef.current?.getBoundingClientRect();\n     if (!(origine && rect)) {\n       return;\n     }\n     setPosition(\n       clampFenetrePosition(\n         { x: origine.x + event.delta.x, y: origine.y + event.delta.y },\n-        { height: rect.height, width: rect.width },\n-        { height: window.innerHeight, width: window.innerWidth },\n+        rect,\n+        viewportActuel(),\n         FENETRE_TITLE_BAR_HEIGHT\n       )\n     );\n   }\n \n   function handleDragCancel() {\n     // dnd-kit ANNULE (jamais dragEnd) sur resize, Escape, pointercancel et\n     // changement d'onglet : sans ce nettoyage, le garde « drag en vol » de\n     // reclamp resterait armé pour toujours et l'invariant D23-A mourrait en\n     // silence (relevé par les 3 passes adversariales, cross-model).\n     origineDragRef.current = null;\n     // Le resize qui vient d'annuler le drag doit re-borner tout de suite —\n     // l'écouteur a vu le garde encore armé.\n     const rect = cadreRef.current?.getBoundingClientRect();\n     if (!rect) {\n       return;\n     }\n-    setPosition((prev) => {\n-      if (!prev) {\n-        return prev;\n-      }\n-      const bornee = clampFenetrePosition(\n-        prev,\n-        { height: rect.height, width: rect.width },\n-        { height: window.innerHeight, width: window.innerWidth },\n-        FENETRE_TITLE_BAR_HEIGHT\n-      );\n-      return bornee.x === prev.x && bornee.y === prev.y ? prev : bornee;\n-    });\n+    setPosition((prev) =>\n+      reclampCommitted(prev, rect, viewportActuel(), FENETRE_TITLE_BAR_HEIGHT)\n+    );\n   }\n \n   return (\n     <>\n       {/* Le bureau respire derrière la fenêtre — même lavis que l'accueil. */}\n       <div aria-hidden=\"true\" className=\"bureau-fond no-print fixed inset-0\" />\n       {/* id STABLE obligatoire : ce DndContext rend au SSR (contrat D17-A) et\n           l'id auto-généré de dnd-kit (compteur de module) diverge entre le\n           serveur et le client → mismatch d'hydratation sur aria-describedby. */}\n       <DndContext\n         id=\"bureau-fenetre-dnd\"\n         onDragCancel={handleDragCancel}\n         onDragEnd={handleDragEnd}\n         onDragStart={handleDragStart}\n         sensors={sensors}\n       >\n         <CadreFenetre\n           cadreRef={cadreRef}\n           dragActif={estDesktop}\n           icone={icone}\n           position={estDesktop ? position : null}\n           titre={titre}\n         >\n           {children}\n         </CadreFenetre>\n       </DndContext>\n     </>\n   );\n }\n \n function CadreFenetre({\n   cadreRef,\n   children,\n   dragActif,\n   icone,\n   position,\n   titre,\n }: {\n   cadreRef: React.RefObject<HTMLDivElement | null>;\n   children: ReactNode;\n   dragActif: boolean;\n   icone: ReactNode;\n   position: Position | null;\n   titre: string;\n }) {\n   // `attributes` de useDraggable est volontairement NON étalé sur la zone de\n   // drag : il injecte role=\"button\" + tabIndex=0 — un contrôle tabbable\n   // invisible qui ne fait rien au clavier (le clavier est hors périmètre,\n   // D24-A ; pas de KeyboardSensor). Les listeners pointeur suffisent.\n   const { listeners, setNodeRef, transform } = useDraggable({\n     disabled: !dragActif,\n     id: \"bureau-fenetre\",\n   });\n \n   return (\n     <div\n       className={cn(\n         // <lg : plein écran, la grammaire OS s'efface (D14-A). ≥lg : ~85 % du\n         // viewport, centrage par défaut 100 % CSS — SSR-safe, et chaque\n         // ouverture repart centrée (D9-A).\n         \"bureau-fenetre fixed inset-0 z-10 flex flex-col overflow-hidden bg-background\",\n         \"lg:inset-auto lg:top-[7.5vh] lg:left-[7.5vw] lg:h-[85vh] lg:w-[85vw]\",\n         \"lg:rounded-2xl lg:border lg:border-border lg:shadow-2xl\"\n       )}\n       ref={cadreRef}\n       style={{\n         // Commit en left/top, jamais de transform persistant (D24-A). Le\n         // transform n'existe que PENDANT le drag.\n         ...(position ? { left: position.x, top: position.y } : {}),\n         ...(transform\n           ? { transform: `translate3d(${transform.x}px, ${transform.y}px, 0)` }\n           : {}),\n       }}\n     >\n       {/* Barre de titre à la grammaire des vrais OS : pictogramme à gauche,\n           titre CENTRÉ sur toute la largeur de la barre, contrôle de fenêtre\n           rond à droite (ocre doux, jamais rouge). La zone de drag couvre\n           toute la barre SAUF la croix (posée au-dessus, z-10) : un doigt qui\n           glisse sur la croix ne déplace rien. */}\n       <div className=\"no-print relative flex h-14 shrink-0 items-center border-border border-b bg-card pr-2\">\n         <div\n           className={cn(\n             \"absolute inset-0 flex touch-none select-none items-center pl-5\",\n             dragActif && \"cursor-grab active:cursor-grabbing\"\n           )}\n           ref={setNodeRef}\n           {...listeners}\n         >\n           <span aria-hidden=\"true\" className=\"text-muted-foreground\">\n             {icone}\n           </span>\n         </div>\n         <span className=\"pointer-events-none absolute inset-x-16 truncate text-center font-semibold text-muted-foreground text-xl\">\n           {titre}\n         </span>\n         <Button\n           aria-label=\"Fermer la fenêtre\"\n           className=\"relative z-10 ml-auto size-12 shrink-0 rounded-full bg-primary/10 text-primary hover:bg-primary/20\"\n           nativeButton={false}\n           render={<Link aria-label=\"Fermer la fenêtre\" to=\"/\" />}\ndiff --git a/src/lib/bureau/__tests__/bureau.golden.ts b/src/lib/bureau/__tests__/bureau.golden.ts\nindex 3851e3e..4ebd3ed 100644\n--- a/src/lib/bureau/__tests__/bureau.golden.ts\n+++ b/src/lib/bureau/__tests__/bureau.golden.ts\n@@ -1,222 +1,271 @@\n /**\n  * BUREAU assertion script — la couche OS calme (ceo-review D12-A).\n  *\n  * Pins the pure desktop-layer modules. Same standalone-runnable pattern as\n  * operations.golden.ts (no test runner in this app):\n  *   bun run src/lib/bureau/__tests__/bureau.golden.ts\n  * (wired as `bun run test:bureau`). Exits non-zero on any failure.\n  * Pure modules (no env import) — no SKIP_ENV_VALIDATION needed.\n  *\n  * Ce que ces assertions verrouillent :\n  *  - le modifier de bornage (D23-A strict) : la barre de titre reste\n  *    ENTIÈREMENT visible — bords, coins, viewport plus petit que la fenêtre,\n  *    et le RE-bornage sur redimensionnement (D11-A) ;\n  *  - la garde de forme de session : n'importe quel contenu de\n  *    `bureau:session` → un booléen, jamais d'exception ;\n  *  - le rituel de session complet (lire/ouvrir/ranger) sur un localStorage\n  *    factice : clé stable, aller-retour, et le SILENCE en cas de panne de\n  *    stockage — l'enfant ne voit jamais d'erreur ;\n  *  - la machine à états de sélection de l'icône (D19-A, sans horloge —\n  *    remplace la « fonction de seuil », supprimée par T5 : dblclick natif) :\n  *    la sélection ne se perd JAMAIS sur un second clic, `ouverte` absorbe ;\n  *  - l'identité du bureau (T4-A) : correspondance childName ↔ héros\n  *    insensible à la casse et à l'élision.\n  */\n \n-import { clampFenetrePosition } from \"~/lib/bureau/clamp\";\n+import { clampFenetrePosition, reclampCommitted } from \"~/lib/bureau/clamp\";\n import {\n   type EtatIcone,\n   type EvenementIcone,\n   transitionIcone,\n } from \"~/lib/bureau/icone\";\n import { matchesChildName } from \"~/lib/bureau/identite\";\n import {\n   estSessionOuverte,\n   lireSessionOuverte,\n   ouvrirSession,\n   rangerBureau,\n   SESSION_STORAGE_KEY,\n } from \"~/lib/bureau/session\";\n \n let failures = 0;\n function check(name: string, ok: boolean, detail?: string) {\n   if (ok) {\n     console.log(`✓ ${name}`);\n   } else {\n     failures += 1;\n     console.error(`✗ ${name}${detail ? `\\n  ${detail}` : \"\"}`);\n   }\n }\n \n /* ------------------------- Bornage de la fenêtre ------------------------- */\n \n // Géométrie de référence : fenêtre 85 % d'un viewport 1600×1000, barre 56px.\n const FENETRE = { height: 850, width: 1360 };\n const VIEWPORT = { height: 1000, width: 1600 };\n const BARRE = 56;\n \n function clampe(x: number, y: number) {\n   return clampFenetrePosition({ x, y }, FENETRE, VIEWPORT, BARRE);\n }\n \n const interieur = clampe(120, 75);\n check(\n   \"clamp: une position intérieure est inchangée\",\n   interieur.x === 120 && interieur.y === 75\n );\n const gaucheHaut = clampe(-500, -500);\n check(\n   \"clamp: coin haut-gauche — jamais de x/y négatif\",\n   gaucheHaut.x === 0 && gaucheHaut.y === 0\n );\n const droite = clampe(9999, 75);\n check(\n   \"clamp: bord droit — la barre entière reste dans l'écran en largeur\",\n   droite.x === VIEWPORT.width - FENETRE.width,\n   `x=${droite.x}`\n );\n const bas = clampe(120, 9999);\n check(\n   \"clamp: bord bas — il reste toujours au moins la barre visible\",\n   bas.y === VIEWPORT.height - BARRE,\n   `y=${bas.y}`\n );\n const coin = clampe(9999, 9999);\n check(\n   \"clamp: coin bas-droit — les deux axes bornés ensemble\",\n   coin.x === 240 && coin.y === 944\n );\n const etroit = clampFenetrePosition(\n   { x: 300, y: 40 },\n   FENETRE,\n   { height: 700, width: 900 },\n   BARRE\n );\n check(\n   \"clamp: viewport plus étroit que la fenêtre → x=0 (alignée à gauche), jamais NaN\",\n   etroit.x === 0 && etroit.y === 40\n );\n // Re-bornage sur resize (D11-A) : une position valide AVANT le\n // rétrécissement est re-bornée par le MÊME modifier pur.\n const avant = clampe(240, 900);\n const apres = clampFenetrePosition(\n   avant,\n   FENETRE,\n   { height: 600, width: 1400 },\n   BARRE\n );\n check(\n   \"clamp: re-bornage après rétrécissement du viewport (D11-A)\",\n   apres.x === 40 && apres.y === 600 - BARRE,\n   `x=${apres.x} y=${apres.y}`\n );\n check(\n   \"clamp: viewport plus bas que la barre → y=0 (cas dégradé théorique)\",\n   clampFenetrePosition(\n     { x: 0, y: 30 },\n     FENETRE,\n     { height: 40, width: 1600 },\n     BARRE\n   ).y === 0\n );\n \n+/* ------------------- Re-bornage d'une position committée ------------------ */\n+\n+// reclampCommitted = la discipline de commit du composant, écrite une fois :\n+// null-passthrough (fenêtre centrée par le CSS), no-op → MÊME référence\n+// (setPosition(prev => prev) ne re-rend pas), sinon le clamp D23-A.\n+check(\n+  \"reclamp: position committée nulle (centrée CSS) → null, rien à re-borner\",\n+  reclampCommitted(null, FENETRE, VIEWPORT, BARRE) === null\n+);\n+const committeeLoinDesBords = { x: 120, y: 75 };\n+check(\n+  \"reclamp: no-op loin des bords → la MÊME référence (aucun re-rendu resize)\",\n+  reclampCommitted(committeeLoinDesBords, FENETRE, VIEWPORT, BARRE) ===\n+    committeeLoinDesBords\n+);\n+const committeeAuBordExact = { x: 240, y: 944 };\n+check(\n+  \"reclamp: déjà exactement sur la borne → toujours la même référence\",\n+  reclampCommitted(committeeAuBordExact, FENETRE, VIEWPORT, BARRE) ===\n+    committeeAuBordExact\n+);\n+const committeeHorsBornes = { x: 9999, y: 9999 };\n+const rebornee = reclampCommitted(\n+  committeeHorsBornes,\n+  FENETRE,\n+  VIEWPORT,\n+  BARRE\n+);\n+check(\n+  \"reclamp: hors bornes → NOUVELLE référence, bornée comme clampFenetrePosition\",\n+  rebornee !== committeeHorsBornes &&\n+    rebornee?.x === 240 &&\n+    rebornee?.y === 944,\n+  `x=${rebornee?.x} y=${rebornee?.y}`\n+);\n+// Rétrécissement du viewport (D11-A) : le re-bornage committé suit le même\n+// modifier pur que le drag.\n+const retrecie = reclampCommitted(\n+  { x: 240, y: 900 },\n+  FENETRE,\n+  { height: 600, width: 1400 },\n+  BARRE\n+);\n+check(\n+  \"reclamp: re-bornage après rétrécissement du viewport (D11-A)\",\n+  retrecie?.x === 40 && retrecie?.y === 600 - BARRE,\n+  `x=${retrecie?.x} y=${retrecie?.y}`\n+);\n+\n /* ------------------------ Garde de forme de session ---------------------- */\n \n check(\"session: absente (null) → fermée\", estSessionOuverte(null) === false);\n check(\"session: undefined → fermée\", estSessionOuverte(undefined) === false);\n check(\n   \"session: contenu corrompu (string) → fermée, sans exception\",\n   estSessionOuverte(\"n'importe quoi\") === false\n );\n check(\"session: mauvais type (42) → fermée\", estSessionOuverte(42) === false);\n check(\"session: objet vide → fermée\", estSessionOuverte({}) === false);\n check(\n   \"session: ouverte:true littéral → ouverte\",\n   estSessionOuverte({ ouverte: true, v: 1 }) === true\n );\n check(\n   \"session: ouverte truthy mais non-true ('oui') → fermée\",\n   estSessionOuverte({ ouverte: \"oui\", v: 1 }) === false\n );\n check(\n   \"session: version FUTURE qui garde ouverte:true → toujours lisible\",\n   estSessionOuverte({ extra: { x: 1 }, ouverte: true, v: 99 }) === true\n );\n check(\"session: tableau → fermée\", estSessionOuverte([true]) === false);\n \n /* --------------- Rituel de session sur un localStorage factice ------------ */\n \n // Le script bun n'a pas de DOM : un window factice suffit — les helpers ne\n // touchent QUE window.localStorage, et c'est exactement ce qu'on épingle.\n const memoire = new Map<string, string>();\n const windowFactice = {\n   localStorage: {\n     getItem: (k: string) => memoire.get(k) ?? null,\n     removeItem: (k: string) => {\n       memoire.delete(k);\n     },\n     setItem: (k: string, v: string) => {\n       memoire.set(k, v);\n     },\n   },\n };\n (globalThis as { window?: unknown }).window = windowFactice;\n \n check(\n   \"session: clé de stockage stable (bureau:session)\",\n   SESSION_STORAGE_KEY === \"bureau:session\"\n );\n check(\n   \"session: stockage vide → fermée par défaut\",\n   lireSessionOuverte() === false\n );\n ouvrirSession();\n check(\n   \"session: ouvrirSession → lue ouverte, sous la clé stable\",\n   lireSessionOuverte() === true && memoire.has(SESSION_STORAGE_KEY)\n );\n rangerBureau();\n check(\n   \"session: rangerBureau → clé retirée, lue fermée\",\n   lireSessionOuverte() === false && !memoire.has(SESSION_STORAGE_KEY)\n );\n memoire.set(SESSION_STORAGE_KEY, \"{pas du json\");\n check(\n   \"session: JSON corrompu dans le stockage → fermée, sans exception\",\n   lireSessionOuverte() === false\n );\n \n // Panne de stockage (quota, mode privé, désactivé) : SILENCE — aucun des\n // trois helpers ne jette, et la session vit en MÉMOIRE le temps de l'onglet\n // (repli du module ; sans lui la gate re-présenterait le portrait à chaque\n // ouverture d'app — le rituel deviendrait une barrière répétée).\n (globalThis as { window?: unknown }).window = {\n   localStorage: {\n     getItem: () => {\n       throw new Error(\"panne\");\n     },\n     removeItem: () => {\n       throw new Error(\"panne\");\n     },\n     setItem: () => {\n       throw new Error(\"panne\");\n     },\n   },\n };\n let panneSilencieuse = true;\n let ouverteEnMemoire = false;\n let rangeeEnMemoire = false;\n try {\n   ouvrirSession();\n   ouverteEnMemoire = lireSessionOuverte();\n   rangerBureau();\n   rangeeEnMemoire = !lireSessionOuverte();\n } catch {\n   panneSilencieuse = false;\n }\n check(\n   \"session: stockage en panne → silence total, la session vit en mémoire\",\n   panneSilencieuse && ouverteEnMemoire && rangeeEnMemoire\n );\n \n // Le stub en panne est RESTAURÉ : les assertions ajoutées après cette\ndiff --git a/src/lib/bureau/__tests__/routes.golden.ts b/src/lib/bureau/__tests__/routes.golden.ts\nindex d00e050..8ce2cfb 100644\n--- a/src/lib/bureau/__tests__/routes.golden.ts\n+++ b/src/lib/bureau/__tests__/routes.golden.ts\n@@ -19,107 +19,150 @@ function check(name: string, ok: boolean, detail?: string) {\n     console.log(`✓ ${name}`);\n   } else {\n     failures += 1;\n     console.error(`✗ ${name}${detail ? `\\n  ${detail}` : \"\"}`);\n   }\n }\n \n const routeTree = readFileSync(\"src/routeTree.gen.ts\", \"utf8\");\n \n /* --------------------- Les URLs publiques, inchangées --------------------- */\n \n // Chaque chemin doit exister comme fullPath dans l'arbre généré — la ligne\n // `fullPath: '/aventure/'` est l'empreinte de l'URL réellement servie.\n const URLS_PUBLIQUES = [\n   \"/\",\n   \"/aventure/\",\n   \"/aventure/$id\",\n   \"/calcul/\",\n   \"/bibliotheque\",\n   \"/parents/\",\n   \"/parents/calcul\",\n   \"/data/$\",\n ];\n for (const url of URLS_PUBLIQUES) {\n   check(\n     `URL publique inchangée: ${url}`,\n     routeTree.includes(`fullPath: '${url}'`)\n   );\n }\n \n // La layout est bien pathless : `/_bureau` existe comme id mais n'introduit\n // AUCUN segment d'URL (aucun fullPath ne commence par /_bureau).\n check(\"la layout _bureau existe (id) …\", routeTree.includes(\"id: '/_bureau'\"));\n check(\n   \"… et n'apparaît dans aucune URL (pathless)\",\n   !routeTree.includes(\"fullPath: '/_bureau\")\n );\n \n /* ------------------- Aucun id d'ancienne route résiduel ------------------- */\n \n // Les ids des routes déménagées ont été RÉÉCRITS (D24-A) : plus aucun\n // createFileRoute avec un ancien id, nulle part sous src/app.\n const ANCIENS_IDS = [\n   'createFileRoute(\"/aventure/\")',\n   'createFileRoute(\"/aventure/$id\")',\n   'createFileRoute(\"/calcul/\")',\n   'createFileRoute(\"/bibliotheque\")',\n ];\n const NOUVEAUX_IDS = [\n   'createFileRoute(\"/_bureau/aventure/\")',\n   'createFileRoute(\"/_bureau/aventure/$id\")',\n   'createFileRoute(\"/_bureau/calcul/\")',\n   'createFileRoute(\"/_bureau/bibliotheque\")',\n ];\n \n function listeFichiers(dir: string): string[] {\n   return readdirSync(dir).flatMap((name) => {\n     const path = join(dir, name);\n     return statSync(path).isDirectory() ? listeFichiers(path) : [path];\n   });\n }\n \n const sources = listeFichiers(\"src/app\")\n   .filter((p) => p.endsWith(\".tsx\") || p.endsWith(\".ts\"))\n   .map((p) => ({ contenu: readFileSync(p, \"utf8\"), path: p }));\n \n for (const ancien of ANCIENS_IDS) {\n   const restes = sources.filter((s) => s.contenu.includes(ancien));\n   check(\n     `aucun id d'ancienne route résiduel: ${ancien}`,\n     restes.length === 0,\n     restes.map((r) => r.path).join(\", \")\n   );\n }\n for (const nouveau of NOUVEAUX_IDS) {\n   check(\n     `id réécrit présent: ${nouveau}`,\n     sources.some((s) => s.contenu.includes(nouveau))\n   );\n }\n \n // Les anciens emplacements de fichiers n'existent plus (le déménagement est\n // complet, pas une copie).\n for (const ancien of [\n   \"src/app/aventure\",\n   \"src/app/calcul\",\n   \"src/app/bibliotheque.tsx\",\n ]) {\n   check(`ancien emplacement disparu: ${ancien}`, !existsSync(ancien));\n }\n \n // /parents reste HORS de l'OS : aucune route parents sous _bureau.\n check(\n   \"/parents hors de l'OS (jamais sous _bureau)\",\n   !(\n     existsSync(\"src/app/_bureau/parents\") ||\n     routeTree.includes(\"'/_bureau/parents\")\n   )\n );\n \n+/* --------------- Contrats prose → épinglés (D17-A + T2-A) ----------------- */\n+\n+// (D17-A) Selective SSR : AUCUNE option `ssr:` sous src/app/_bureau/** — la\n+// config SSR de TanStack est héritée vers le bas et ne peut que se\n+// restreindre ; un `ssr: false` posé sur la layout (ou n'importe quelle\n+// route enfant) rendrait silencieusement les mini-apps client-only. Le scan\n+// retire d'abord les commentaires : le contrat vit AUSSI en prose dans\n+// route.tsx, qui cite « ssr: false » précisément pour l'interdire.\n+const BLOCS_COMMENTAIRES = /\\/\\*[\\s\\S]*?\\*\\//g;\n+const LIGNES_COMMENTAIRES = /\\/\\/[^\\n]*/g;\n+const OPTION_SSR = /\\bssr\\s*:/;\n+function sansCommentaires(code: string): string {\n+  return code.replace(BLOCS_COMMENTAIRES, \"\").replace(LIGNES_COMMENTAIRES, \"\");\n+}\n+const sousBureau = sources.filter((s) => s.path.startsWith(\"src/app/_bureau/\"));\n+const avecOptionSsr = sousBureau.filter((s) =>\n+  OPTION_SSR.test(sansCommentaires(s.contenu))\n+);\n+check(\n+  \"contrat D17-A: aucune option `ssr:` sous src/app/_bureau/** (héritage Selective SSR)\",\n+  sousBureau.length > 0 && avecOptionSsr.length === 0,\n+  avecOptionSsr.map((s) => s.path).join(\", \") ||\n+    \"aucun fichier scanné sous src/app/_bureau/\"\n+);\n+\n+// (T2-A) La gate session-fermée vit à exactement DEUX endroits : `/` et la\n+// layout _bureau — jamais __root, sinon /parents et /data/$ seraient gatés.\n+// L'empreinte textuelle est l'appel à `lireSessionOuverte` (session.ts).\n+const GATE_TOKEN = \"lireSessionOuverte\";\n+const EMPLACEMENTS_GATE = [\"src/app/_bureau/route.tsx\", \"src/app/index.tsx\"];\n+const fichiersGate = sources\n+  .filter((s) => s.contenu.includes(GATE_TOKEN))\n+  .map((s) => s.path)\n+  // Tri par code units (pas localeCompare) : l'ordre attendu est celui des\n+  // littéraux d'EMPLACEMENTS_GATE, indépendant de la locale de la machine.\n+  .sort((a, b) => (a < b ? -1 : 1));\n+check(\n+  \"contrat T2-A: la gate (lireSessionOuverte) vit à exactement DEUX endroits — / et la layout _bureau, jamais __root\",\n+  fichiersGate.length === EMPLACEMENTS_GATE.length &&\n+    EMPLACEMENTS_GATE.every((p, i) => fichiersGate[i] === p),\n+  `trouvée dans: ${fichiersGate.join(\", \") || \"(nulle part)\"}`\n+);\n+\n /* -------------------------------- Verdict -------------------------------- */\n \n if (failures > 0) {\n   console.error(`\\n${failures} assertion(s) routes en échec.`);\n   process.exit(1);\n }\n console.log(\"\\nToutes les assertions routes passent.\");\ndiff --git a/src/lib/bureau/clamp.ts b/src/lib/bureau/clamp.ts\nindex 218fb85..1b92f4b 100644\n--- a/src/lib/bureau/clamp.ts\n+++ b/src/lib/bureau/clamp.ts\n@@ -1,43 +1,70 @@\n /**\n  * Bornage de la fenêtre du bureau — module PUR, golden-testé (test:bureau).\n  *\n  * Lecture STRICTE du clamp (eng-review D23-A) : la barre de titre reste\n  * ENTIÈREMENT visible en toute circonstance — jamais d'état « fenêtre\n  * perdue » pour un enfant de 5 ans. Le corps de la fenêtre peut déborder du\n  * bas de l'écran, la poignée qui la ramène, jamais. Le MÊME modifier re-borne\n  * au redimensionnement du viewport (ceo-review D11-A) : l'invariant tient au\n  * drag ET au resize.\n  */\n \n export interface Position {\n   x: number;\n   y: number;\n }\n \n export interface Taille {\n   height: number;\n   width: number;\n }\n \n /**\n  * (position, taille fenêtre, viewport, hauteur de barre) → position bornée.\n  *\n  * - x ∈ [0, viewport.width − fenêtre.width] : la barre entière reste dans\n  *   l'écran en largeur. Viewport plus étroit que la fenêtre (cas dégradé) →\n  *   x = 0, alignée à gauche — le maximum visible possible.\n  * - y ∈ [0, viewport.height − barre] : le haut ne sort jamais, et il reste\n  *   toujours au moins la barre complète visible en bas.\n  */\n export function clampFenetrePosition(\n   position: Position,\n   fenetre: Taille,\n   viewport: Taille,\n   titleBarHeight: number\n ): Position {\n   const maxX = Math.max(0, viewport.width - fenetre.width);\n   const maxY = Math.max(0, viewport.height - titleBarHeight);\n   return {\n     x: Math.min(Math.max(position.x, 0), maxX),\n     y: Math.min(Math.max(position.y, 0), maxY),\n   };\n }\n+\n+/**\n+ * Re-bornage d'une position COMMITTÉE (resize du viewport, drag annulé) —\n+ * la règle répétée côté composant, écrite UNE fois :\n+ *\n+ * - `prev` null (fenêtre centrée par le CSS de chaque ouverture) → null,\n+ *   rien à re-borner ;\n+ * - no-op → MÊME référence : `setPosition(prev => prev)` ne re-rend pas —\n+ *   aucun re-rendu à chaque event resize quand la fenêtre est loin des\n+ *   bords.\n+ *\n+ * L'invariant « barre entièrement visible » reste celui de\n+ * `clampFenetrePosition` (D23-A) : ce helper n'ajoute que la discipline de\n+ * commit (null-passthrough + identité de référence).\n+ */\n+export function reclampCommitted(\n+  prev: Position | null,\n+  fenetre: Taille,\n+  viewport: Taille,\n+  titleBarHeight: number\n+): Position | null {\n+  if (!prev) {\n+    return prev;\n+  }\n+  const bornee = clampFenetrePosition(prev, fenetre, viewport, titleBarHeight);\n+  return bornee.x === prev.x && bornee.y === prev.y ? prev : bornee;\n+}\n     1\t/**\n     2\t * La fenêtre du bureau — le CADRE, pas le contenu (prémisse 6).\n     3\t *\n     4\t * Une vraie grammaire de fenêtre à taille d'enfant : barre de titre (seule\n     5\t * zone de drag), grande croix douce ≥ 48 px toujours visible (jamais rouge —\n     6\t * la croix a la sémantique de navigation EXISTANTE : un Link vers `/`), ni\n     7\t * resize, ni minimize, ni maximize, ni z-order — une seule fenêtre à la fois.\n     8\t *\n     9\t * Géométrie (eng-review D23-A) : ~85 % du viewport — à ~92 % la course de\n    10\t * drag n'était que quelques dizaines de pixels, un « déplacer la fenêtre »\n    11\t * symbolique mé-enseigne. À chaque ouverture la fenêtre repart CENTRÉE\n    12\t * (ceo-review D9-A) : le matériel revient toujours à sa place — aucune\n    13\t * position persistée, la récupération d'une fenêtre « perdue » est la\n    14\t * réouverture. Le centrage par défaut est 100 % CSS (inset 7.5vw/7.5vh) :\n    15\t * aucune lecture de `window` pendant le rendu, SSR-safe (contrat D17-A).\n    16\t *\n    17\t * La position committée n'est JAMAIS un transform CSS (eng-review D24-A) :\n    18\t * transform pendant le drag seulement, commit en `left/top` — un transform\n    19\t * persistant ferait du cadre le containing block des descendants\n    20\t * `position: fixed`, et le DragOverlay du pavé de /calcul rendrait décalé\n    21\t * d'exactement la translation de la fenêtre. Même raison : pas de\n    22\t * `will-change`/`filter` sur le cadre.\n    23\t *\n    24\t * Sous le point de rupture lg, la fenêtre rend PLEIN ÉCRAN sans drag, croix\n    25\t * conservée (ceo-review D14-A) : les mini-apps ne sont jamais comprimées, la\n    26\t * grammaire OS s'efface quand la place manque.\n    27\t *\n    28\t * Les capteurs du DndContext sont activés par la SEULE zone de titre (T5) :\n    29\t * il ne peut jamais interférer avec le DndContext du pavé de /calcul qui vit\n    30\t * à l'intérieur. À l'impression, le positionnement est neutralisé\n    31\t * (`.bureau-fenetre` dans globals.css) : le contenu s'imprime comme avant.\n    32\t */\n    33\t\n    34\timport {\n    35\t  DndContext,\n    36\t  type DragEndEvent,\n    37\t  PointerSensor,\n    38\t  useDraggable,\n    39\t  useSensor,\n    40\t  useSensors,\n    41\t} from \"@dnd-kit/core\";\n    42\timport { Link } from \"@tanstack/react-router\";\n    43\timport { X } from \"lucide-react\";\n    44\timport {\n    45\t  type ReactNode,\n    46\t  useEffect,\n    47\t  useRef,\n    48\t  useState,\n    49\t  useSyncExternalStore,\n    50\t} from \"react\";\n    51\timport { Button } from \"~/components/ui/button\";\n    52\timport {\n    53\t  clampFenetrePosition,\n    54\t  type Position,\n    55\t  reclampCommitted,\n    56\t  type Taille,\n    57\t} from \"~/lib/bureau/clamp\";\n    58\timport { cn } from \"~/lib/cn\";\n    59\t\n    60\t/** Hauteur de la barre de titre — appariée à la classe h-14 (56px) du cadre. */\n    61\texport const FENETRE_TITLE_BAR_HEIGHT = 56;\n    62\t\n    63\t// 4px of travel before a drag starts: a plain click on the title bar stays a\n    64\t// click. Hoisted for a stable useSensor options identity (same idiom as\n    65\t// /calcul's numpad sensor).\n    66\tconst POINTER_ACTIVATION = { activationConstraint: { distance: 4 } };\n    67\t\n    68\t/** Le drag n'existe qu'au-dessus du breakpoint lg (D14-A). */\n    69\tconst DESKTOP_QUERY = \"(min-width: 1024px)\";\n    70\t\n    71\t/** Le viewport au moment du commit — lu au même instant que le rect. */\n    72\tfunction viewportActuel(): Taille {\n    73\t  return { height: window.innerHeight, width: window.innerWidth };\n    74\t}\n    75\t\n    76\tfunction subscribeDesktop(onChange: () => void) {\n    77\t  const media = window.matchMedia(DESKTOP_QUERY);\n    78\t  media.addEventListener(\"change\", onChange);\n    79\t  return () => media.removeEventListener(\"change\", onChange);\n    80\t}\n    81\t\n    82\tfunction useEstDesktop(): boolean {\n    83\t  return useSyncExternalStore(\n    84\t    subscribeDesktop,\n    85\t    () => window.matchMedia(DESKTOP_QUERY).matches,\n    86\t    // SSR: pas de lecture de window pendant le rendu (D17-A) — le faux\n    87\t    // n'active aucun style inline, la géométrie du premier paint est en CSS.\n    88\t    () => false\n    89\t  );\n    90\t}\n    91\t\n    92\texport interface FenetreProps {\n    93\t  children: ReactNode;\n    94\t  /** Le pictogramme de l'icône du bureau, repris dans la barre de titre. */\n    95\t  icone: ReactNode;\n    96\t  /** Le titre de la fenêtre = le libellé de l'icône (« Histoires »…). */\n    97\t  titre: string;\n    98\t}\n    99\t\n   100\texport function Fenetre({ children, icone, titre }: FenetreProps) {\n   101\t  const estDesktop = useEstDesktop();\n   102\t  // null = centrée par le CSS (l'état de CHAQUE ouverture) ; un point après\n   103\t  // le premier drag, committé en left/top.\n   104\t  const [position, setPosition] = useState<Position | null>(null);\n   105\t  const cadreRef = useRef<HTMLDivElement | null>(null);\n   106\t  const origineDragRef = useRef<Position | null>(null);\n   107\t  const sensors = useSensors(useSensor(PointerSensor, POINTER_ACTIVATION));\n   108\t\n   109\t  // L'invariant « barre entièrement visible » tient aussi au REDIMENSIONNEMENT\n   110\t  // du viewport (D11-A) : le même modifier pur re-borne la position committée.\n   111\t  const aUnePosition = position !== null;\n   112\t  useEffect(() => {\n   113\t    if (!(aUnePosition && estDesktop)) {\n   114\t      return;\n   115\t    }\n   116\t    function reclamp() {\n   117\t      if (origineDragRef.current) {\n   118\t        // Drag en vol : re-positionner sous le transform ferait sursauter la\n   119\t        // fenêtre — dragEnd re-borne de toute façon.\n   120\t        return;\n   121\t      }\n   122\t      const rect = cadreRef.current?.getBoundingClientRect();\n   123\t      if (!rect) {\n   124\t        return;\n   125\t      }\n   126\t      // null-passthrough + no-op même référence : dans le helper pur —\n   127\t      // pas de re-rendu à chaque event resize loin des bords.\n   128\t      setPosition((prev) =>\n   129\t        reclampCommitted(prev, rect, viewportActuel(), FENETRE_TITLE_BAR_HEIGHT)\n   130\t      );\n   131\t    }\n   132\t    // Re-borne aussi à l'ATTACHE : le viewport a pu changer pendant\n   133\t    // l'interlude <lg (rotation, restore) où l'écouteur était détaché.\n   134\t    reclamp();\n   135\t    window.addEventListener(\"resize\", reclamp);\n   136\t    return () => window.removeEventListener(\"resize\", reclamp);\n   137\t  }, [aUnePosition, estDesktop]);\n   138\t\n   139\t  function handleDragStart() {\n   140\t    // Au départ du drag le transform est nul (jamais persisté) : le rect EST\n   141\t    // la position réelle, qu'elle vienne du CSS centré ou d'un left/top.\n   142\t    const rect = cadreRef.current?.getBoundingClientRect();\n   143\t    origineDragRef.current = rect ? { x: rect.left, y: rect.top } : null;\n   144\t  }\n   145\t\n   146\t  function handleDragEnd(event: DragEndEvent) {\n   147\t    const origine = origineDragRef.current;\n   148\t    origineDragRef.current = null;\n   149\t    const rect = cadreRef.current?.getBoundingClientRect();\n   150\t    if (!(origine && rect)) {\n   151\t      return;\n   152\t    }\n   153\t    setPosition(\n   154\t      clampFenetrePosition(\n   155\t        { x: origine.x + event.delta.x, y: origine.y + event.delta.y },\n   156\t        rect,\n   157\t        viewportActuel(),\n   158\t        FENETRE_TITLE_BAR_HEIGHT\n   159\t      )\n   160\t    );\n   161\t  }\n   162\t\n   163\t  function handleDragCancel() {\n   164\t    // dnd-kit ANNULE (jamais dragEnd) sur resize, Escape, pointercancel et\n   165\t    // changement d'onglet : sans ce nettoyage, le garde « drag en vol » de\n   166\t    // reclamp resterait armé pour toujours et l'invariant D23-A mourrait en\n   167\t    // silence (relevé par les 3 passes adversariales, cross-model).\n   168\t    origineDragRef.current = null;\n   169\t    // Le resize qui vient d'annuler le drag doit re-borner tout de suite —\n   170\t    // l'écouteur a vu le garde encore armé.\n   171\t    const rect = cadreRef.current?.getBoundingClientRect();\n   172\t    if (!rect) {\n   173\t      return;\n   174\t    }\n   175\t    setPosition((prev) =>\n   176\t      reclampCommitted(prev, rect, viewportActuel(), FENETRE_TITLE_BAR_HEIGHT)\n   177\t    );\n   178\t  }\n   179\t\n   180\t  return (\n   181\t    <>\n   182\t      {/* Le bureau respire derrière la fenêtre — même lavis que l'accueil. */}\n   183\t      <div aria-hidden=\"true\" className=\"bureau-fond no-print fixed inset-0\" />\n   184\t      {/* id STABLE obligatoire : ce DndContext rend au SSR (contrat D17-A) et\n   185\t          l'id auto-généré de dnd-kit (compteur de module) diverge entre le\n   186\t          serveur et le client → mismatch d'hydratation sur aria-describedby. */}\n   187\t      <DndContext\n   188\t        id=\"bureau-fenetre-dnd\"\n   189\t        onDragCancel={handleDragCancel}\n   190\t        onDragEnd={handleDragEnd}\n   191\t        onDragStart={handleDragStart}\n   192\t        sensors={sensors}\n   193\t      >\n   194\t        <CadreFenetre\n   195\t          cadreRef={cadreRef}\n   196\t          dragActif={estDesktop}\n   197\t          icone={icone}\n   198\t          position={estDesktop ? position : null}\n   199\t          titre={titre}\n   200\t        >\n   201\t          {children}\n   202\t        </CadreFenetre>\n   203\t      </DndContext>\n   204\t    </>\n   205\t  );\n   206\t}\n   207\t\n   208\tfunction CadreFenetre({\n   209\t  cadreRef,\n   210\t  children,\n   211\t  dragActif,\n   212\t  icone,\n   213\t  position,\n   214\t  titre,\n   215\t}: {\n   216\t  cadreRef: React.RefObject<HTMLDivElement | null>;\n   217\t  children: ReactNode;\n   218\t  dragActif: boolean;\n   219\t  icone: ReactNode;\n   220\t  position: Position | null;\n   221\t  titre: string;\n   222\t}) {\n   223\t  // `attributes` de useDraggable est volontairement NON étalé sur la zone de\n   224\t  // drag : il injecte role=\"button\" + tabIndex=0 — un contrôle tabbable\n   225\t  // invisible qui ne fait rien au clavier (le clavier est hors périmètre,\n   226\t  // D24-A ; pas de KeyboardSensor). Les listeners pointeur suffisent.\n   227\t  const { listeners, setNodeRef, transform } = useDraggable({\n   228\t    disabled: !dragActif,\n   229\t    id: \"bureau-fenetre\",\n   230\t  });\n   231\t\n   232\t  return (\n   233\t    <div\n   234\t      className={cn(\n   235\t        // <lg : plein écran, la grammaire OS s'efface (D14-A). ≥lg : ~85 % du\n   236\t        // viewport, centrage par défaut 100 % CSS — SSR-safe, et chaque\n   237\t        // ouverture repart centrée (D9-A).\n   238\t        \"bureau-fenetre fixed inset-0 z-10 flex flex-col overflow-hidden bg-background\",\n   239\t        \"lg:inset-auto lg:top-[7.5vh] lg:left-[7.5vw] lg:h-[85vh] lg:w-[85vw]\",\n   240\t        \"lg:rounded-2xl lg:border lg:border-border lg:shadow-2xl\"\n   241\t      )}\n   242\t      ref={cadreRef}\n   243\t      style={{\n   244\t        // Commit en left/top, jamais de transform persistant (D24-A). Le\n   245\t        // transform n'existe que PENDANT le drag.\n   246\t        ...(position ? { left: position.x, top: position.y } : {}),\n   247\t        ...(transform\n   248\t          ? { transform: `translate3d(${transform.x}px, ${transform.y}px, 0)` }\n   249\t          : {}),\n   250\t      }}\n   251\t    >\n   252\t      {/* Barre de titre à la grammaire des vrais OS : pictogramme à gauche,\n   253\t          titre CENTRÉ sur toute la largeur de la barre, contrôle de fenêtre\n   254\t          rond à droite (ocre doux, jamais rouge). La zone de drag couvre\n   255\t          toute la barre SAUF la croix (posée au-dessus, z-10) : un doigt qui\n   256\t          glisse sur la croix ne déplace rien. */}\n   257\t      <div className=\"no-print relative flex h-14 shrink-0 items-center border-border border-b bg-card pr-2\">\n   258\t        <div\n   259\t          className={cn(\n   260\t            \"absolute inset-0 flex touch-none select-none items-center pl-5\",\n   261\t            dragActif && \"cursor-grab active:cursor-grabbing\"\n   262\t          )}\n   263\t          ref={setNodeRef}\n   264\t          {...listeners}\n   265\t        >\n   266\t          <span aria-hidden=\"true\" className=\"text-muted-foreground\">\n   267\t            {icone}\n   268\t          </span>\n   269\t        </div>\n   270\t        <span className=\"pointer-events-none absolute inset-x-16 truncate text-center font-semibold text-muted-foreground text-xl\">\n   271\t          {titre}\n   272\t        </span>\n   273\t        <Button\n   274\t          aria-label=\"Fermer la fenêtre\"\n   275\t          className=\"relative z-10 ml-auto size-12 shrink-0 rounded-full bg-primary/10 text-primary hover:bg-primary/20\"\n   276\t          nativeButton={false}\n   277\t          render={<Link aria-label=\"Fermer la fenêtre\" to=\"/\" />}\n   278\t          variant=\"ghost\"\n   279\t        >\n   280\t          <X className=\"size-6\" />\n   281\t        </Button>\n   282\t      </div>\n   283\t      <div className=\"bureau-fenetre-contenu min-h-0 flex-1 overflow-y-auto\">\n   284\t        {/* Le conteneur que __root offrait avant le plein-bleed : les\n   285\t            mini-apps gardent leur largeur et leurs marges d'origine. */}\n   286\t        <div className=\"mx-auto w-full max-w-5xl px-6 py-10\">{children}</div>\n   287\t      </div>\n   288\t    </div>\n   289\t  );\n   290\t}\n     1\t/**\n     2\t * Bornage de la fenêtre du bureau — module PUR, golden-testé (test:bureau).\n     3\t *\n     4\t * Lecture STRICTE du clamp (eng-review D23-A) : la barre de titre reste\n     5\t * ENTIÈREMENT visible en toute circonstance — jamais d'état « fenêtre\n     6\t * perdue » pour un enfant de 5 ans. Le corps de la fenêtre peut déborder du\n     7\t * bas de l'écran, la poignée qui la ramène, jamais. Le MÊME modifier re-borne\n     8\t * au redimensionnement du viewport (ceo-review D11-A) : l'invariant tient au\n     9\t * drag ET au resize.\n    10\t */\n    11\t\n    12\texport interface Position {\n    13\t  x: number;\n    14\t  y: number;\n    15\t}\n    16\t\n    17\texport interface Taille {\n    18\t  height: number;\n    19\t  width: number;\n    20\t}\n    21\t\n    22\t/**\n    23\t * (position, taille fenêtre, viewport, hauteur de barre) → position bornée.\n    24\t *\n    25\t * - x ∈ [0, viewport.width − fenêtre.width] : la barre entière reste dans\n    26\t *   l'écran en largeur. Viewport plus étroit que la fenêtre (cas dégradé) →\n    27\t *   x = 0, alignée à gauche — le maximum visible possible.\n    28\t * - y ∈ [0, viewport.height − barre] : le haut ne sort jamais, et il reste\n    29\t *   toujours au moins la barre complète visible en bas.\n    30\t */\n    31\texport function clampFenetrePosition(\n    32\t  position: Position,\n    33\t  fenetre: Taille,\n    34\t  viewport: Taille,\n    35\t  titleBarHeight: number\n    36\t): Position {\n    37\t  const maxX = Math.max(0, viewport.width - fenetre.width);\n    38\t  const maxY = Math.max(0, viewport.height - titleBarHeight);\n    39\t  return {\n    40\t    x: Math.min(Math.max(position.x, 0), maxX),\n    41\t    y: Math.min(Math.max(position.y, 0), maxY),\n    42\t  };\n    43\t}\n    44\t\n    45\t/**\n    46\t * Re-bornage d'une position COMMITTÉE (resize du viewport, drag annulé) —\n    47\t * la règle répétée côté composant, écrite UNE fois :\n    48\t *\n    49\t * - `prev` null (fenêtre centrée par le CSS de chaque ouverture) → null,\n    50\t *   rien à re-borner ;\n    51\t * - no-op → MÊME référence : `setPosition(prev => prev)` ne re-rend pas —\n    52\t *   aucun re-rendu à chaque event resize quand la fenêtre est loin des\n    53\t *   bords.\n    54\t *\n    55\t * L'invariant « barre entièrement visible » reste celui de\n    56\t * `clampFenetrePosition` (D23-A) : ce helper n'ajoute que la discipline de\n    57\t * commit (null-passthrough + identité de référence).\n    58\t */\n    59\texport function reclampCommitted(\n    60\t  prev: Position | null,\n    61\t  fenetre: Taille,\n    62\t  viewport: Taille,\n    63\t  titleBarHeight: number\n    64\t): Position | null {\n    65\t  if (!prev) {\n    66\t    return prev;\n    67\t  }\n    68\t  const bornee = clampFenetrePosition(prev, fenetre, viewport, titleBarHeight);\n    69\t  return bornee.x === prev.x && bornee.y === prev.y ? prev : bornee;\n    70\t}\n     1\t/**\n     2\t * ROUTES assertion script — intégrité des URLs publiques (eng-review D24-A).\n     3\t *\n     4\t * La relocalisation des mini-apps sous `src/app/_bureau/` (préfixe `_` =\n     5\t * layout sans segment d'URL) ne doit changer AUCUNE URL publique, et aucun\n     6\t * id d'ancienne route ne doit subsister. Vérification TEXTUELLE sur\n     7\t * routeTree.gen.ts + les fichiers de src/app : importer le vrai routeTree\n     8\t * tirerait l'env serveur et le CSS — hors de portée d'un script bun pur.\n     9\t *   bun run src/lib/bureau/__tests__/routes.golden.ts\n    10\t * (wired as `bun run test:routes`). Exits non-zero on any failure.\n    11\t */\n    12\t\n    13\timport { existsSync, readdirSync, readFileSync, statSync } from \"node:fs\";\n    14\timport { join } from \"node:path\";\n    15\t\n    16\tlet failures = 0;\n    17\tfunction check(name: string, ok: boolean, detail?: string) {\n    18\t  if (ok) {\n    19\t    console.log(`✓ ${name}`);\n    20\t  } else {\n    21\t    failures += 1;\n    22\t    console.error(`✗ ${name}${detail ? `\\n  ${detail}` : \"\"}`);\n    23\t  }\n    24\t}\n    25\t\n    26\tconst routeTree = readFileSync(\"src/routeTree.gen.ts\", \"utf8\");\n    27\t\n    28\t/* --------------------- Les URLs publiques, inchangées --------------------- */\n    29\t\n    30\t// Chaque chemin doit exister comme fullPath dans l'arbre généré — la ligne\n    31\t// `fullPath: '/aventure/'` est l'empreinte de l'URL réellement servie.\n    32\tconst URLS_PUBLIQUES = [\n    33\t  \"/\",\n    34\t  \"/aventure/\",\n    35\t  \"/aventure/$id\",\n    36\t  \"/calcul/\",\n    37\t  \"/bibliotheque\",\n    38\t  \"/parents/\",\n    39\t  \"/parents/calcul\",\n    40\t  \"/data/$\",\n    41\t];\n    42\tfor (const url of URLS_PUBLIQUES) {\n    43\t  check(\n    44\t    `URL publique inchangée: ${url}`,\n    45\t    routeTree.includes(`fullPath: '${url}'`)\n    46\t  );\n    47\t}\n    48\t\n    49\t// La layout est bien pathless : `/_bureau` existe comme id mais n'introduit\n    50\t// AUCUN segment d'URL (aucun fullPath ne commence par /_bureau).\n    51\tcheck(\"la layout _bureau existe (id) …\", routeTree.includes(\"id: '/_bureau'\"));\n    52\tcheck(\n    53\t  \"… et n'apparaît dans aucune URL (pathless)\",\n    54\t  !routeTree.includes(\"fullPath: '/_bureau\")\n    55\t);\n    56\t\n    57\t/* ------------------- Aucun id d'ancienne route résiduel ------------------- */\n    58\t\n    59\t// Les ids des routes déménagées ont été RÉÉCRITS (D24-A) : plus aucun\n    60\t// createFileRoute avec un ancien id, nulle part sous src/app.\n    61\tconst ANCIENS_IDS = [\n    62\t  'createFileRoute(\"/aventure/\")',\n    63\t  'createFileRoute(\"/aventure/$id\")',\n    64\t  'createFileRoute(\"/calcul/\")',\n    65\t  'createFileRoute(\"/bibliotheque\")',\n    66\t];\n    67\tconst NOUVEAUX_IDS = [\n    68\t  'createFileRoute(\"/_bureau/aventure/\")',\n    69\t  'createFileRoute(\"/_bureau/aventure/$id\")',\n    70\t  'createFileRoute(\"/_bureau/calcul/\")',\n    71\t  'createFileRoute(\"/_bureau/bibliotheque\")',\n    72\t];\n    73\t\n    74\tfunction listeFichiers(dir: string): string[] {\n    75\t  return readdirSync(dir).flatMap((name) => {\n    76\t    const path = join(dir, name);\n    77\t    return statSync(path).isDirectory() ? listeFichiers(path) : [path];\n    78\t  });\n    79\t}\n    80\t\n    81\tconst sources = listeFichiers(\"src/app\")\n    82\t  .filter((p) => p.endsWith(\".tsx\") || p.endsWith(\".ts\"))\n    83\t  .map((p) => ({ contenu: readFileSync(p, \"utf8\"), path: p }));\n    84\t\n    85\tfor (const ancien of ANCIENS_IDS) {\n    86\t  const restes = sources.filter((s) => s.contenu.includes(ancien));\n    87\t  check(\n    88\t    `aucun id d'ancienne route résiduel: ${ancien}`,\n    89\t    restes.length === 0,\n    90\t    restes.map((r) => r.path).join(\", \")\n    91\t  );\n    92\t}\n    93\tfor (const nouveau of NOUVEAUX_IDS) {\n    94\t  check(\n    95\t    `id réécrit présent: ${nouveau}`,\n    96\t    sources.some((s) => s.contenu.includes(nouveau))\n    97\t  );\n    98\t}\n    99\t\n   100\t// Les anciens emplacements de fichiers n'existent plus (le déménagement est\n   101\t// complet, pas une copie).\n   102\tfor (const ancien of [\n   103\t  \"src/app/aventure\",\n   104\t  \"src/app/calcul\",\n   105\t  \"src/app/bibliotheque.tsx\",\n   106\t]) {\n   107\t  check(`ancien emplacement disparu: ${ancien}`, !existsSync(ancien));\n   108\t}\n   109\t\n   110\t// /parents reste HORS de l'OS : aucune route parents sous _bureau.\n   111\tcheck(\n   112\t  \"/parents hors de l'OS (jamais sous _bureau)\",\n   113\t  !(\n   114\t    existsSync(\"src/app/_bureau/parents\") ||\n   115\t    routeTree.includes(\"'/_bureau/parents\")\n   116\t  )\n   117\t);\n   118\t\n   119\t/* --------------- Contrats prose → épinglés (D17-A + T2-A) ----------------- */\n   120\t\n   121\t// (D17-A) Selective SSR : AUCUNE option `ssr:` sous src/app/_bureau/** — la\n   122\t// config SSR de TanStack est héritée vers le bas et ne peut que se\n   123\t// restreindre ; un `ssr: false` posé sur la layout (ou n'importe quelle\n   124\t// route enfant) rendrait silencieusement les mini-apps client-only. Le scan\n   125\t// retire d'abord les commentaires : le contrat vit AUSSI en prose dans\n   126\t// route.tsx, qui cite « ssr: false » précisément pour l'interdire.\n   127\tconst BLOCS_COMMENTAIRES = /\\/\\*[\\s\\S]*?\\*\\//g;\n   128\tconst LIGNES_COMMENTAIRES = /\\/\\/[^\\n]*/g;\n   129\tconst OPTION_SSR = /\\bssr\\s*:/;\n   130\tfunction sansCommentaires(code: string): string {\n   131\t  return code.replace(BLOCS_COMMENTAIRES, \"\").replace(LIGNES_COMMENTAIRES, \"\");\n   132\t}\n   133\tconst sousBureau = sources.filter((s) => s.path.startsWith(\"src/app/_bureau/\"));\n   134\tconst avecOptionSsr = sousBureau.filter((s) =>\n   135\t  OPTION_SSR.test(sansCommentaires(s.contenu))\n   136\t);\n   137\tcheck(\n   138\t  \"contrat D17-A: aucune option `ssr:` sous src/app/_bureau/** (héritage Selective SSR)\",\n   139\t  sousBureau.length > 0 && avecOptionSsr.length === 0,\n   140\t  avecOptionSsr.map((s) => s.path).join(\", \") ||\n   141\t    \"aucun fichier scanné sous src/app/_bureau/\"\n   142\t);\n   143\t\n   144\t// (T2-A) La gate session-fermée vit à exactement DEUX endroits : `/` et la\n   145\t// layout _bureau — jamais __root, sinon /parents et /data/$ seraient gatés.\n   146\t// L'empreinte textuelle est l'appel à `lireSessionOuverte` (session.ts).\n   147\tconst GATE_TOKEN = \"lireSessionOuverte\";\n   148\tconst EMPLACEMENTS_GATE = [\"src/app/_bureau/route.tsx\", \"src/app/index.tsx\"];\n   149\tconst fichiersGate = sources\n   150\t  .filter((s) => s.contenu.includes(GATE_TOKEN))\n   151\t  .map((s) => s.path)\n   152\t  // Tri par code units (pas localeCompare) : l'ordre attendu est celui des\n   153\t  // littéraux d'EMPLACEMENTS_GATE, indépendant de la locale de la machine.\n   154\t  .sort((a, b) => (a < b ? -1 : 1));\n   155\tcheck(\n   156\t  \"contrat T2-A: la gate (lireSessionOuverte) vit à exactement DEUX endroits — / et la layout _bureau, jamais __root\",\n   157\t  fichiersGate.length === EMPLACEMENTS_GATE.length &&\n   158\t    EMPLACEMENTS_GATE.every((p, i) => fichiersGate[i] === p),\n   159\t  `trouvée dans: ${fichiersGate.join(\", \") || \"(nulle part)\"}`\n   160\t);\n   161\t\n   162\t/* -------------------------------- Verdict -------------------------------- */\n   163\t\n   164\tif (failures > 0) {\n   165\t  console.error(`\\n${failures} assertion(s) routes en échec.`);\n   166\t  process.exit(1);\n   167\t}\n   168\tconsole.log(\"\\nToutes les assertions routes passent.\");\n","exit_code":0,"status":"completed"}}
