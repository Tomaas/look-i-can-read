{"type":"item.completed","item":{"id":"item_25","type":"command_execution","command":"/usr/bin/zsh -lc \"git show main:src/app/_bureau/calcul/index.tsx | nl -ba | sed -n '70,430p'; nl -ba src/app/_bureau/calcul/index.tsx | sed -n '70,380p'; nl -ba src/lib/operations/serie-session.ts | sed -n '1,390p'\"","aggregated_output":"    70\t      withTimeout(getMathSettingsFn(), null),\n    71\t      withTimeout(listHeroesFn(), []),\n    72\t      withTimeout(listDoudousFn(), []),\n    73\t    ]);\n    74\t    return {\n    75\t      doudouName: doudous[0]?.label ?? null,\n    76\t      heroName: heroes[0]?.label ?? null,\n    77\t      settings,\n    78\t    };\n    79\t  },\n    80\t});\n    81\t\n    82\tconst SETTINGS_CACHE_KEY = \"calcul:settings\";\n    83\t// La série en cours vit sous UNE clé PAR FAMILLE (serieStorageKeyOf, décision\n    84\t// 2A révisée : chaque plateau se souvient d'où il en était — rien n'est\n    85\t// jamais rangé dans le dos de l'enfant). L'ancienne clé unique\n    86\t// LEGACY_SERIE_STATE_KEY est migrée une fois par le pont (bridgeLegacySerie).\n    87\t\n    88\t// Durée du moment « rangé » (D-2A) : 🌿 respire, puis fondu vers l'étagère —\n    89\t// appariée au fondu de 300 ms de FadeIn, jamais un écran-destination.\n    90\tconst TIDIED_MOMENT_MS = 1600;\n    91\t\n    92\t// 8px of travel before a drag starts: a plain tap stays a click. Hoisted so\n    93\t// dnd-kit's useSensor memo keeps a stable options identity across renders.\n    94\tconst POINTER_ACTIVATION = { activationConstraint: { distance: 8 } };\n    95\t\n    96\t/**\n    97\t * Forgiving drop detection for small fingers: precise when the fingertip is\n    98\t * inside a cell (pointerWithin), else the cell the tile overlaps most counts\n    99\t * (rectIntersection) — a near-miss inks the obvious cell instead of nothing.\n   100\t */\n   101\tconst forgivingCollision: CollisionDetection = (args) => {\n   102\t  const within = pointerWithin(args);\n   103\t  return within.length > 0 ? within : rectIntersection(args);\n   104\t};\n   105\t\n   106\t/** The droppable payload crosses dnd-kit untyped — validate, never cast. */\n   107\tfunction isCellRef(value: unknown): value is CellRef {\n   108\t  const cell = value as CellRef | null;\n   109\t  return (\n   110\t    typeof cell === \"object\" &&\n   111\t    cell !== null &&\n   112\t    (cell.row === \"result\" || cell.row === \"carry\") &&\n   113\t    typeof cell.col === \"number\"\n   114\t  );\n   115\t}\n   116\t\n   117\t/**\n   118\t * Pencil flow, shared by tap and drag: after a result digit, the pencil steps\n   119\t * to the next column leftwards; col 0 and carry cells keep the pencil put.\n   120\t */\n   121\tfunction pencilAdvance(cell: CellRef): CellRef {\n   122\t  return cell.row === \"result\" && cell.col > 0\n   123\t    ? { col: cell.col - 1, row: \"result\" }\n   124\t    : cell;\n   125\t}\n   126\t\n   127\t/**\n   128\t * L'état de série vit dans le module pur (SerieStateLike, golden-testé) —\n   129\t * GridEntries (UI) et SerieEntriesLike (lib) sont structurellement identiques.\n   130\t */\n   131\ttype SerieState = SerieStateLike;\n   132\t\n   133\tfunction readJson<T>(key: string): T | null {\n   134\t  try {\n   135\t    const raw = window.localStorage.getItem(key);\n   136\t    return raw ? (JSON.parse(raw) as T) : null;\n   137\t  } catch {\n   138\t    return null;\n   139\t  }\n   140\t}\n   141\t\n   142\tfunction writeJson(key: string, value: unknown) {\n   143\t  try {\n   144\t    window.localStorage.setItem(key, JSON.stringify(value));\n   145\t  } catch {\n   146\t    // Storage unavailable (private mode…) — the session simply won't resume.\n   147\t  }\n   148\t}\n   149\t\n   150\t/**\n   151\t * L'état « sorti » d'un plateau + reprise : lit la clé de la famille, valide\n   152\t * avec le prédicat complet (isResumableSerie, pur et golden-testé), PURGE\n   153\t * silencieusement une clé non reprenable (palier changé par le parent, cache\n   154\t * d'un autre format — l'éducatrice a réorganisé l'étagère, exception assumée\n   155\t * de la prémisse 4).\n   156\t */\n   157\tfunction readResumableSerie(\n   158\t  famille: Operation,\n   159\t  palierId: string,\n   160\t  serieSize: number\n   161\t): SerieState | null {\n   162\t  const key = serieStorageKeyOf(famille);\n   163\t  const saved = readJson<SerieState>(key);\n   164\t  if (saved === null) {\n   165\t    return null;\n   166\t  }\n   167\t  if (isResumableSerie(saved, famille, palierId, serieSize)) {\n   168\t    return saved;\n   169\t  }\n   170\t  try {\n   171\t    window.localStorage.removeItem(key);\n   172\t  } catch {\n   173\t    // Storage unavailable — reading already failed softly anyway.\n   174\t  }\n   175\t  return null;\n   176\t}\n   177\t\n   178\t/**\n   179\t * Les trois temps de l'atelier : l'étagère (le choix), la série (le travail),\n   180\t * le moment « rangé » (la transition de fin, D-2A — jamais une destination).\n   181\t * Phase en état local, pas de route : le back matériel sort de l'atelier\n   182\t * (écart assumé D-8B), la flèche in-app fait le trajet fin.\n   183\t */\n   184\ttype Phase =\n   185\t  | { kind: \"shelf\" }\n   186\t  | { kind: \"serie\"; famille: Operation }\n   187\t  | { kind: \"tidied\"; famille: Operation };\n   188\t\n   189\t/**\n   190\t * L'atelier des opérations posées — \"la série qui se range\" (eng-review T4-A).\n   191\t *\n   192\t * One opening = one short series of operations (parent-set size). The last\n   193\t * one finished, the workshop tidies itself: the page breathes, nothing new\n   194\t * arrives on its own. Reopening a series is a deliberate child gesture.\n   195\t *\n   196\t * V1 is the \"écriture libre\" mode (T3-C): the child writes freely like on\n   197\t * paper — nothing is judged while writing; at the end the solved operation\n   198\t * appears alongside for the child to compare. The stamp-game manipulation\n   199\t * (tranche 5) arrives after the school confirms the material.\n   200\t */\n   201\tfunction CalculWorkshopPage() {\n   202\t  const { settings: dbSettings, heroName, doudouName } = Route.useLoaderData();\n   203\t  const [settings, setSettings] = useState<MathSettings | null>(null);\n   204\t  const [phase, setPhase] = useState<Phase>({ kind: \"shelf\" });\n   205\t  const [serie, setSerie] = useState<SerieState | null>(null);\n   206\t  const [selected, setSelected] = useState<CellRef | null>(null);\n   207\t  // Digit currently being dragged from the numpad (drives the DragOverlay).\n   208\t  const [dragDigit, setDragDigit] = useState<string | null>(null);\n   209\t  // On touch, implicit pointer capture retargets the post-drag click onto the\n   210\t  // numpad key — this one-shot flag swallows that ghost click so a drag never\n   211\t  // ALSO writes into the selected cell. Consumed by the first suppressed\n   212\t  // click; the fallback timer covers pointers that never emit one (a mouse\n   213\t  // released away from the key).\n   214\t  const dragJustEndedRef = useRef(false);\n   215\t  // The operation index a drag started on: a drop landing after the tray\n   216\t  // advanced (multi-touch) must never ink the NEXT operation's grid.\n   217\t  const dragOpIndexRef = useRef<number | null>(null);\n   218\t  const sensors = useSensors(useSensor(PointerSensor, POINTER_ACTIVATION));\n   219\t\n   220\t  // Settings: DB when reachable (and cache it), else device cache, else\n   221\t  // defaults. NORMALIZED whatever the source (normalizeFamilySettings, pure\n   222\t  // et golden-testée) — un cache édité ou un vieux format ne crashe jamais\n   223\t  // la page enfant. Même effet : le pont de clé legacy (une seule fois) et\n   224\t  // la purge des clés orphelines des familles désactivées (D-3A/F9).\n   225\t  useEffect(() => {\n   226\t    // Pont 2A/T4 : la série d'AVANT l'étagère est re-rangée sous la clé de\n   227\t    // sa famille (dérivée de son palier) — jamais écrasante, et l'ancienne\n   228\t    // clé ne disparaît qu'après RELECTURE de la clé cible (red-team RT1 : un\n   229\t    // write avalé par un quota plein ne doit pas coûter la série).\n   230\t    // readJson rend null pour « absente » comme pour « illisible » : on lit\n   231\t    // la chaîne brute pour pouvoir nettoyer une clé corrompue (adversarial #7).\n   232\t    let legacyStr: string | null = null;\n   233\t    try {\n   234\t      legacyStr = window.localStorage.getItem(LEGACY_SERIE_STATE_KEY);\n   235\t    } catch {\n   236\t      // Storage unavailable — nothing to migrate anyway.\n   237\t    }\n   238\t    if (legacyStr !== null) {\n   239\t      const legacy = bridgeLegacySerie(\n   240\t        readJson<unknown>(LEGACY_SERIE_STATE_KEY)\n   241\t      );\n   242\t      if (legacy) {\n   243\t        const target = serieStorageKeyOf(legacy.famille);\n   244\t        if (readJson<unknown>(target) === null) {\n   245\t          writeJson(target, legacy.state);\n   246\t        }\n   247\t        if (readJson<unknown>(target) === null) {\n   248\t          // La cible n'a pas pu s'écrire : on garde la legacy pour un\n   249\t          // prochain passage plutôt que de détruire la série.\n   250\t          return finishSettings();\n   251\t        }\n   252\t      }\n   253\t      try {\n   254\t        window.localStorage.removeItem(LEGACY_SERIE_STATE_KEY);\n   255\t      } catch {\n   256\t        // Storage unavailable — nothing to migrate anyway.\n   257\t      }\n   258\t    }\n   259\t    finishSettings();\n   260\t\n   261\t    function finishSettings() {\n   262\t      const normalized = normalizeFamilySettings(\n   263\t        dbSettings ?? readJson<unknown>(SETTINGS_CACHE_KEY)\n   264\t      );\n   265\t      // Le cache appareil ne mémorise que des réglages AUTHORITATIFS\n   266\t      // (adversarial #3) : des défauts servis pendant la fenêtre\n   267\t      // pré-migration écraseraient les vrais réglages mémorisés.\n   268\t      if (dbSettings?.authoritative) {\n   269\t        writeJson(SETTINGS_CACHE_KEY, normalized);\n   270\t      }\n   271\t      // Purge des clés orphelines (D-3A/F9) — SEULEMENT sur des réglages\n   272\t      // authoritatifs (vraies lignes DB). Des défauts (hors-ligne + cache\n   273\t      // froid, DB pas encore migrée) ne sont pas une vérité sur les familles\n   274\t      // et ne doivent JAMAIS coûter une série locale (red-team RT1 —\n   275\t      // « rien n'est jamais rangé dans le dos de l'enfant »).\n   276\t      if (dbSettings?.authoritative) {\n   277\t        for (const op of FAMILLES) {\n   278\t          if (!normalized.familles.some((f) => f.op === op)) {\n   279\t            try {\n   280\t              window.localStorage.removeItem(serieStorageKeyOf(op));\n   281\t            } catch {\n   282\t              // Storage unavailable — the ghost key is unreadable anyway.\n   283\t            }\n   284\t          }\n   285\t        }\n   286\t      }\n   287\t      setSettings(normalized);\n   288\t    }\n   289\t  }, [dbSettings]);\n   290\t\n   291\t  // Persistance : chaque frappe est sauvegardée sous la clé de SA famille —\n   292\t  // reposer le plateau ou fermer l'onglet ne perd jamais rien.\n   293\t  useEffect(() => {\n   294\t    if (serie) {\n   295\t      writeJson(serieStorageKeyOf(serie.famille), serie);\n   296\t    }\n   297\t  }, [serie]);\n   298\t\n   299\t  // Fin de série (D-2A) : le moment « rangé » est une TRANSITION vers\n   300\t  // l'étagère (où le plateau est visiblement rangé), pas une destination.\n   301\t  // Une série VIDE (palier cassé, cas théorique) compte comme finie — même\n   302\t  // chemin calme, jamais un écran bloqué.\n   303\t  const finished =\n   304\t    phase.kind === \"serie\" &&\n   305\t    serie !== null &&\n   306\t    (serie.index >= serie.serieSize || serie.perOp.length === 0);\n   307\t  useEffect(() => {\n   308\t    if (finished && serie) {\n   309\t      setPhase({ famille: serie.famille, kind: \"tidied\" });\n   310\t    }\n   311\t  }, [finished, serie]);\n   312\t  useEffect(() => {\n   313\t    if (phase.kind !== \"tidied\") {\n   314\t      return;\n   315\t    }\n   316\t    const timer = setTimeout(() => {\n   317\t      try {\n   318\t        window.localStorage.removeItem(serieStorageKeyOf(phase.famille));\n   319\t      } catch {\n   320\t        // Storage unavailable — la série finie ne reviendra pas non plus.\n   321\t      }\n   322\t      setSerie(null);\n   323\t      setPhase({ kind: \"shelf\" });\n   324\t    }, TIDIED_MOMENT_MS);\n   325\t    return () => clearTimeout(timer);\n   326\t  }, [phase]);\n   327\t\n   328\t  const palier = serie\n   329\t    ? resolvePalierForFamille(serie.famille, serie.palierId)\n   330\t    : resolvePalierForFamille(\"addition\", null);\n   331\t  // Deps = the values that drive generation only (seed/size/palier) — the\n   332\t  // serie OBJECT changes identity on every digit tap and must not retrigger\n   333\t  // the rejection sampling.\n   334\t  const serieSeed = serie?.seed;\n   335\t  const serieSize = serie?.serieSize;\n   336\t  const operations = useMemo(\n   337\t    () =>\n   338\t      serieSeed !== undefined && serieSize !== undefined\n   339\t        ? safeGenerateSerie(palier, serieSeed, serieSize)\n   340\t        : [],\n   341\t    [serieSeed, serieSize, palier]\n   342\t  );\n   343\t\n   344\t  // L'état « sorti » des plateaux : lecture localStorage + vérification\n   345\t  // d'empreinte (régénération seedée) bornées à UNE entrée d'étagère — memo\n   346\t  // sur (settings, phase), jamais à chaque rendu (D-3A/F5 ; la purge d'une\n   347\t  // clé non reprenable y vit aussi, idempotente).\n   348\t  const trays = useMemo<TrayInfo[]>(() => {\n   349\t    if (!settings || phase.kind !== \"shelf\") {\n   350\t      return [];\n   351\t    }\n   352\t    return settings.familles.map((f) => ({\n   353\t      op: f.op,\n   354\t      sorti:\n   355\t        readResumableSerie(\n   356\t          f.op,\n   357\t          resolvePalierForFamille(f.op, f.palier).id,\n   358\t          settings.serieSize\n   359\t        ) !== null,\n   360\t    }));\n   361\t  }, [settings, phase]);\n   362\t\n   363\t  /** Prendre un plateau : reprise exacte si la série est reprenable, sinon\n   364\t      série fraîche au palier parental de CETTE famille. */\n   365\t  function takeTray(op: Operation) {\n   366\t    if (!settings) {\n   367\t      return;\n   368\t    }\n   369\t    const reglage = settings.familles.find((f) => f.op === op);\n   370\t    const palierForOp = resolvePalierForFamille(op, reglage?.palier);\n   371\t    const saved = readResumableSerie(op, palierForOp.id, settings.serieSize);\n   372\t    setSelected(null);\n   373\t    setSerie(saved ?? freshSerie(op, palierForOp, settings.serieSize));\n   374\t    setPhase({ famille: op, kind: \"serie\" });\n   375\t  }\n   376\t\n   377\t  /** « Reposer le plateau » (T2/D-4A) : retour à l'étagère, sans perte —\n   378\t      la série est sauvegardée à chaque frappe. */\n   379\t  function reposerPlateau() {\n   380\t    setSelected(null);\n   381\t    setSerie(null);\n   382\t    setPhase({ kind: \"shelf\" });\n   383\t  }\n   384\t\n   385\t  if (!settings) {\n   386\t    // First client render (hydration-safe): the calm background, nothing else.\n   387\t    // L'étagère n'apparaît qu'une fois settings + localStorage résolus côté\n   388\t    // client, en fondu d'ensemble — jamais de plateau qui saute (D-3A/F6).\n   389\t    return <div className=\"min-h-[80vh]\" />;\n   390\t  }\n   391\t\n   392\t  if (phase.kind === \"shelf\") {\n   393\t    return (\n   394\t      <WorkshopShell>\n   395\t        <FadeIn>\n   396\t          <TrayShelf\n   397\t            doudouName={doudouName}\n   398\t            heroName={heroName}\n   399\t            onTake={takeTray}\n   400\t            trays={trays}\n   401\t          />\n   402\t        </FadeIn>\n   403\t      </WorkshopShell>\n   404\t    );\n   405\t  }\n   406\t\n   407\t  // Le moment « rangé », partagé par les trois chemins qui y mènent (phase\n   408\t  // tidied, série absente, série finie/vide en attente de l'effet).\n   409\t  const tidiedScreen = (\n   410\t    <WorkshopShell>\n   411\t      <TidiedMoment />\n   412\t    </WorkshopShell>\n   413\t  );\n   414\t\n   415\t  if (phase.kind === \"tidied\" || !serie) {\n   416\t    return tidiedScreen;\n   417\t  }\n   418\t\n   419\t  const operation = finished ? null : operations[serie.index];\n   420\t  const layout = operation ? layoutOperation(operation) : null;\n   421\t  const current = finished ? null : serie.perOp[serie.index];\n   422\t\n   423\t  function updateCurrent(update: Partial<SerieState[\"perOp\"][number]>) {\n   424\t    setSerie((prev) => {\n   425\t      if (!prev) {\n   426\t        return prev;\n   427\t      }\n   428\t      const perOp = prev.perOp.map((op, i) =>\n   429\t        i === prev.index ? { ...op, ...update } : op\n   430\t      );\n    70\t      withTimeout(getMathSettingsFn(), null),\n    71\t      withTimeout(listHeroesFn(), []),\n    72\t      withTimeout(listDoudousFn(), []),\n    73\t    ]);\n    74\t    return {\n    75\t      doudouName: doudous[0]?.label ?? null,\n    76\t      heroName: heroes[0]?.label ?? null,\n    77\t      settings,\n    78\t    };\n    79\t  },\n    80\t});\n    81\t\n    82\t// Toute la vie de la série hors rendu (clés localStorage, pont legacy, purge\n    83\t// authoritative, reprise/empreinte, gestes d'écriture) vit dans le module pur\n    84\t// serie-session (golden-testé) ; la route ne fait que le rendu et le dnd.\n    85\t// L'adaptateur ne touche window qu'à l'appel — sûr au niveau module.\n    86\tconst storage = browserSerieStorage();\n    87\t\n    88\t// Durée du moment « rangé » (D-2A) : 🌿 respire, puis fondu vers l'étagère —\n    89\t// appariée au fondu de 300 ms de FadeIn, jamais un écran-destination.\n    90\tconst TIDIED_MOMENT_MS = 1600;\n    91\t\n    92\t// 8px of travel before a drag starts: a plain tap stays a click. Hoisted so\n    93\t// dnd-kit's useSensor memo keeps a stable options identity across renders.\n    94\tconst POINTER_ACTIVATION = { activationConstraint: { distance: 8 } };\n    95\t\n    96\t/**\n    97\t * Forgiving drop detection for small fingers: precise when the fingertip is\n    98\t * inside a cell (pointerWithin), else the cell the tile overlaps most counts\n    99\t * (rectIntersection) — a near-miss inks the obvious cell instead of nothing.\n   100\t */\n   101\tconst forgivingCollision: CollisionDetection = (args) => {\n   102\t  const within = pointerWithin(args);\n   103\t  return within.length > 0 ? within : rectIntersection(args);\n   104\t};\n   105\t\n   106\t/**\n   107\t * Les trois temps de l'atelier : l'étagère (le choix), la série (le travail),\n   108\t * le moment « rangé » (la transition de fin, D-2A — jamais une destination).\n   109\t * Phase en état local, pas de route : le back matériel sort de l'atelier\n   110\t * (écart assumé D-8B), la flèche in-app fait le trajet fin.\n   111\t */\n   112\ttype Phase =\n   113\t  | { kind: \"shelf\" }\n   114\t  | { kind: \"serie\"; famille: Operation }\n   115\t  | { kind: \"tidied\"; famille: Operation };\n   116\t\n   117\t/**\n   118\t * L'atelier des opérations posées — \"la série qui se range\" (eng-review T4-A).\n   119\t *\n   120\t * One opening = one short series of operations (parent-set size). The last\n   121\t * one finished, the workshop tidies itself: the page breathes, nothing new\n   122\t * arrives on its own. Reopening a series is a deliberate child gesture.\n   123\t *\n   124\t * V1 is the \"écriture libre\" mode (T3-C): the child writes freely like on\n   125\t * paper — nothing is judged while writing; at the end the solved operation\n   126\t * appears alongside for the child to compare. The stamp-game manipulation\n   127\t * (tranche 5) arrives after the school confirms the material.\n   128\t */\n   129\tfunction CalculWorkshopPage() {\n   130\t  const { settings: dbSettings, heroName, doudouName } = Route.useLoaderData();\n   131\t  const [settings, setSettings] = useState<FamilySettings | null>(null);\n   132\t  const [phase, setPhase] = useState<Phase>({ kind: \"shelf\" });\n   133\t  const [serie, setSerie] = useState<SerieStateLike | null>(null);\n   134\t  const [selected, setSelected] = useState<CellRef | null>(null);\n   135\t  // Digit currently being dragged from the numpad (drives the DragOverlay).\n   136\t  const [dragDigit, setDragDigit] = useState<string | null>(null);\n   137\t  // On touch, implicit pointer capture retargets the post-drag click onto the\n   138\t  // numpad key — this one-shot flag swallows that ghost click so a drag never\n   139\t  // ALSO writes into the selected cell. Consumed by the first suppressed\n   140\t  // click; the fallback timer covers pointers that never emit one (a mouse\n   141\t  // released away from the key).\n   142\t  const dragJustEndedRef = useRef(false);\n   143\t  // The operation index a drag started on: a drop landing after the tray\n   144\t  // advanced (multi-touch) must never ink the NEXT operation's grid.\n   145\t  const dragOpIndexRef = useRef<number | null>(null);\n   146\t  const sensors = useSensors(useSensor(PointerSensor, POINTER_ACTIVATION));\n   147\t\n   148\t  // Ouverture de session (loadSession, module pur golden-testé) : pont de\n   149\t  // clé legacy (une seule fois), réglages DB → cache appareil → défauts,\n   150\t  // normalisés quelle que soit la source, cache + purge des clés orphelines\n   151\t  // SEULEMENT sur réglages authoritatifs (D-3A/F9, red-team RT1).\n   152\t  useEffect(() => {\n   153\t    setSettings(loadSession(storage, dbSettings));\n   154\t  }, [dbSettings]);\n   155\t\n   156\t  // Persistance : chaque frappe est sauvegardée sous la clé de SA famille —\n   157\t  // reposer le plateau ou fermer l'onglet ne perd jamais rien.\n   158\t  useEffect(() => {\n   159\t    if (serie) {\n   160\t      saveSerie(storage, serie);\n   161\t    }\n   162\t  }, [serie]);\n   163\t\n   164\t  // Fin de série (D-2A) : le moment « rangé » est une TRANSITION vers\n   165\t  // l'étagère (où le plateau est visiblement rangé), pas une destination.\n   166\t  // Une série VIDE (palier cassé, cas théorique) compte comme finie — même\n   167\t  // chemin calme, jamais un écran bloqué.\n   168\t  const finished =\n   169\t    phase.kind === \"serie\" && serie !== null && isSerieFinished(serie);\n   170\t  useEffect(() => {\n   171\t    if (finished && serie) {\n   172\t      setPhase({ famille: serie.famille, kind: \"tidied\" });\n   173\t    }\n   174\t  }, [finished, serie]);\n   175\t  useEffect(() => {\n   176\t    if (phase.kind !== \"tidied\") {\n   177\t      return;\n   178\t    }\n   179\t    const timer = setTimeout(() => {\n   180\t      clearSerie(storage, phase.famille);\n   181\t      setSerie(null);\n   182\t      setPhase({ kind: \"shelf\" });\n   183\t    }, TIDIED_MOMENT_MS);\n   184\t    return () => clearTimeout(timer);\n   185\t  }, [phase]);\n   186\t\n   187\t  const palier = serie\n   188\t    ? resolvePalierForFamille(serie.famille, serie.palierId)\n   189\t    : resolvePalierForFamille(\"addition\", null);\n   190\t  // Deps = the values that drive generation only (seed/size/palier) — the\n   191\t  // serie OBJECT changes identity on every digit tap and must not retrigger\n   192\t  // the rejection sampling.\n   193\t  const serieSeed = serie?.seed;\n   194\t  const serieSize = serie?.serieSize;\n   195\t  const operations = useMemo(\n   196\t    () =>\n   197\t      serieSeed !== undefined && serieSize !== undefined\n   198\t        ? safeGenerateSerie(palier, serieSeed, serieSize)\n   199\t        : [],\n   200\t    [serieSeed, serieSize, palier]\n   201\t  );\n   202\t\n   203\t  // L'état « sorti » des plateaux : lecture localStorage + vérification\n   204\t  // d'empreinte (régénération seedée) bornées à UNE entrée d'étagère — memo\n   205\t  // sur (settings, phase), jamais à chaque rendu (D-3A/F5 ; la purge d'une\n   206\t  // clé non reprenable y vit aussi, idempotente).\n   207\t  const trays = useMemo<TrayInfo[]>(\n   208\t    () =>\n   209\t      settings && phase.kind === \"shelf\" ? shelfTrays(storage, settings) : [],\n   210\t    [settings, phase]\n   211\t  );\n   212\t\n   213\t  /** Prendre un plateau (takeTray, module pur) : reprise exacte si la série\n   214\t      est reprenable, sinon série fraîche au palier parental de CETTE famille. */\n   215\t  function prendrePlateau(op: Operation) {\n   216\t    if (!settings) {\n   217\t      return;\n   218\t    }\n   219\t    setSelected(null);\n   220\t    setSerie(takeTray(storage, settings, op));\n   221\t    setPhase({ famille: op, kind: \"serie\" });\n   222\t  }\n   223\t\n   224\t  /** « Reposer le plateau » (T2/D-4A) : retour à l'étagère, sans perte —\n   225\t      la série est sauvegardée à chaque frappe. */\n   226\t  function reposerPlateau() {\n   227\t    setSelected(null);\n   228\t    setSerie(null);\n   229\t    setPhase({ kind: \"shelf\" });\n   230\t  }\n   231\t\n   232\t  if (!settings) {\n   233\t    // First client render (hydration-safe): the calm background, nothing else.\n   234\t    // L'étagère n'apparaît qu'une fois settings + localStorage résolus côté\n   235\t    // client, en fondu d'ensemble — jamais de plateau qui saute (D-3A/F6).\n   236\t    return <div className=\"min-h-[80vh]\" />;\n   237\t  }\n   238\t\n   239\t  if (phase.kind === \"shelf\") {\n   240\t    return (\n   241\t      <WorkshopShell>\n   242\t        <FadeIn>\n   243\t          <TrayShelf\n   244\t            doudouName={doudouName}\n   245\t            heroName={heroName}\n   246\t            onTake={prendrePlateau}\n   247\t            trays={trays}\n   248\t          />\n   249\t        </FadeIn>\n   250\t      </WorkshopShell>\n   251\t    );\n   252\t  }\n   253\t\n   254\t  // Le moment « rangé », partagé par les trois chemins qui y mènent (phase\n   255\t  // tidied, série absente, série finie/vide en attente de l'effet).\n   256\t  const tidiedScreen = (\n   257\t    <WorkshopShell>\n   258\t      <TidiedMoment />\n   259\t    </WorkshopShell>\n   260\t  );\n   261\t\n   262\t  if (phase.kind === \"tidied\" || !serie) {\n   263\t    return tidiedScreen;\n   264\t  }\n   265\t\n   266\t  const operation = finished ? null : operations[serie.index];\n   267\t  const layout = operation ? layoutOperation(operation) : null;\n   268\t  const current = finished ? null : serie.perOp[serie.index];\n   269\t\n   270\t  function setCell(cell: CellRef, value: string | null) {\n   271\t    // Everything derives from prev INSIDE the updater (never the render-time\n   272\t    // closure); writeCell (module pur) is bounds/done-guarded: a late drop or\n   273\t    // a second write in the same event can never clobber state or ink a\n   274\t    // frozen answer.\n   275\t    setSerie((prev) => (prev ? writeCell(prev, cell, value) : prev));\n   276\t  }\n   277\t\n   278\t  function writeDigit(digit: string) {\n   279\t    if (dragJustEndedRef.current) {\n   280\t      // The ghost click after a drag — swallow it and re-arm for real taps.\n   281\t      dragJustEndedRef.current = false;\n   282\t      return;\n   283\t    }\n   284\t    if (!selected) {\n   285\t      return;\n   286\t    }\n   287\t    setCell(selected, digit);\n   288\t    setSelected(pencilAdvance(selected));\n   289\t  }\n   290\t\n   291\t  function endDrag() {\n   292\t    setDragDigit(null);\n   293\t    dragOpIndexRef.current = null;\n   294\t    dragJustEndedRef.current = true;\n   295\t    // Browsers don't guarantee the ghost click lands before a 0ms timer, so\n   296\t    // the flag is one-shot (see writeDigit) with a generous fallback window.\n   297\t    setTimeout(() => {\n   298\t      dragJustEndedRef.current = false;\n   299\t    }, 300);\n   300\t  }\n   301\t\n   302\t  function handleDragStart(event: DragStartEvent) {\n   303\t    const digit = event.active.data.current?.digit;\n   304\t    setDragDigit(typeof digit === \"string\" ? digit : null);\n   305\t    dragOpIndexRef.current = serie?.index ?? null;\n   306\t    // Single-pencil metaphor: the lifted tile IS the pencil now — the old\n   307\t    // selection halo goes out so only the hovered cell glows during the drag.\n   308\t    setSelected(null);\n   309\t  }\n   310\t\n   311\t  function handleDragEnd(event: DragEndEvent) {\n   312\t    const dragOpIndex = dragOpIndexRef.current;\n   313\t    endDrag();\n   314\t    const digit = event.active.data.current?.digit;\n   315\t    const cell = event.over?.data.current?.cell;\n   316\t    if (typeof digit !== \"string\" || !isCellRef(cell)) {\n   317\t      return;\n   318\t    }\n   319\t    // A drop only counts on the operation it started on, and only while that\n   320\t    // operation is still being written — a drag surviving a \"J'ai fini\" or a\n   321\t    // tray change (second finger) lands as a calm no-op.\n   322\t    if (dragOpIndex === null || dragOpIndex !== serie?.index) {\n   323\t      return;\n   324\t    }\n   325\t    if (!current || current.done) {\n   326\t      return;\n   327\t    }\n   328\t    setCell(cell, digit);\n   329\t    // Same pencil flow as a tap: the dropped cell becomes \"where the pencil\n   330\t    // is\", stepping leftwards on the result line.\n   331\t    setSelected(pencilAdvance(cell));\n   332\t  }\n   333\t\n   334\t  function erase() {\n   335\t    if (!selected) {\n   336\t      return;\n   337\t    }\n   338\t    setCell(selected, null);\n   339\t  }\n   340\t\n   341\t  function nextTray() {\n   342\t    setSelected(null);\n   343\t    setSerie((prev) => (prev ? advanceSerie(prev) : prev));\n   344\t  }\n   345\t\n   346\t  if (finished || !(operation && layout && current)) {\n   347\t    // Fin de série (ou série vide sur palier cassé — dégradation calme) :\n   348\t    // le moment « rangé », puis l'effet ci-dessus ramène à l'étagère.\n   349\t    return tidiedScreen;\n   350\t  }\n   351\t\n   352\t  return (\n   353\t    <WorkshopShell onReposer={reposerPlateau}>\n   354\t      {/* No tray/progress row (review decision 3B): the series is bounded but\n   355\t          never counted in front of the child — the end simply arrives, like\n   356\t          the end of a story. */}\n   357\t      <DndContext\n   358\t        collisionDetection={forgivingCollision}\n   359\t        onDragCancel={endDrag}\n   360\t        onDragEnd={handleDragEnd}\n   361\t        onDragStart={handleDragStart}\n   362\t        sensors={sensors}\n   363\t      >\n   364\t        {heroName ? (\n   365\t          <p className=\"max-w-md text-center text-muted-foreground text-xl leading-relaxed\">\n   366\t            {enonceFor(operation, {\n   367\t              doudou: doudouName ?? undefined,\n   368\t              hero: heroName,\n   369\t            })}\n   370\t          </p>\n   371\t        ) : null}\n   372\t\n   373\t        <div className=\"flex flex-wrap items-start justify-center gap-6\">\n   374\t          <ColumnGrid\n   375\t            entries={current.entries}\n   376\t            layout={layout}\n   377\t            onSelect={setSelected}\n   378\t            selected={selected}\n   379\t            variant=\"libre\"\n   380\t          />\n     1\t/**\n     2\t * Session de série — le module PROFOND derrière la route /calcul.\n     3\t *\n     4\t * Toute la vie d'une série hors rendu vit ici : le pont de clé legacy\n     5\t * (`calcul:serie`), le cache de réglages appareil (`calcul:settings`), la\n     6\t * reprise-ou-fraîche avec purge sur désaccord, l'aller-retour d'empreinte\n     7\t * (palier, seed) → mêmes opérations, et les gestes d'écriture (crayon,\n     8\t * cellule, avancement). La route ne garde que le rendu et le câblage dnd.\n     9\t *\n    10\t * Le stockage passe par un PORT minuscule (SerieStorage) : window.localStorage\n    11\t * en prod (browserSerieStorage), une Map dans les goldens — et CHAQUE accès\n    12\t * est enveloppé ici : un stockage qui lève (mode privé, quota, SSR) dégrade\n    13\t * en silence, l'enfant ne voit jamais une erreur (invariant 2A).\n    14\t *\n    15\t * Pur au sens des goldens : aucune lecture d'env, de DB ni de DOM au chargement\n    16\t * du module (window n'est touché qu'à l'appel des méthodes de l'adaptateur).\n    17\t */\n    18\t\n    19\timport { newSerieSeed } from \"~/lib/operations/generator\";\n    20\timport { layoutOperation, type OperationLayout } from \"~/lib/operations/layout\";\n    21\timport {\n    22\t  FAMILLES,\n    23\t  resolvePalierForFamille,\n    24\t} from \"~/lib/operations/progression\";\n    25\timport {\n    26\t  bridgeLegacySerie,\n    27\t  type FamilySettings,\n    28\t  fingerprintOps,\n    29\t  isResumableSerie,\n    30\t  LEGACY_SERIE_STATE_KEY,\n    31\t  normalizeFamilySettings,\n    32\t  type SerieEntriesLike,\n    33\t  type SerieStateLike,\n    34\t  safeGenerateSerie,\n    35\t  serieStorageKeyOf,\n    36\t} from \"~/lib/operations/settings\";\n    37\timport type { Operation, Palier } from \"~/lib/operations/types\";\n    38\t\n    39\t/* ------------------------------ Port stockage ------------------------------ */\n    40\t\n    41\t/** Le port de rangement : localStorage en prod, une Map dans les goldens. */\n    42\texport interface SerieStorage {\n    43\t  getItem: (key: string) => string | null;\n    44\t  removeItem: (key: string) => void;\n    45\t  setItem: (key: string, value: string) => void;\n    46\t}\n    47\t\n    48\t/**\n    49\t * L'adaptateur prod — window n'est touché qu'à l'appel (jamais à la création,\n    50\t * donc sûr à instancier au niveau module, y compris côté serveur). Toute\n    51\t * exception (mode privé, SSR) est avalée par les enveloppes ci-dessous.\n    52\t */\n    53\texport function browserSerieStorage(): SerieStorage {\n    54\t  return {\n    55\t    getItem: (key) => window.localStorage.getItem(key),\n    56\t    removeItem: (key) => window.localStorage.removeItem(key),\n    57\t    setItem: (key, value) => window.localStorage.setItem(key, value),\n    58\t  };\n    59\t}\n    60\t\n    61\t/** Clé du cache appareil des réglages (l'ex-clé orpheline de la route). */\n    62\texport const SETTINGS_CACHE_KEY = \"calcul:settings\";\n    63\t\n    64\tfunction readRaw(storage: SerieStorage, key: string): string | null {\n    65\t  try {\n    66\t    return storage.getItem(key);\n    67\t  } catch {\n    68\t    // Stockage indisponible — comme une clé absente.\n    69\t    return null;\n    70\t  }\n    71\t}\n    72\t\n    73\tfunction readJson<T>(storage: SerieStorage, key: string): T | null {\n    74\t  try {\n    75\t    const raw = storage.getItem(key);\n    76\t    return raw ? (JSON.parse(raw) as T) : null;\n    77\t  } catch {\n    78\t    // Illisible ou indisponible — comme une clé absente.\n    79\t    return null;\n    80\t  }\n    81\t}\n    82\t\n    83\tfunction writeJson(storage: SerieStorage, key: string, value: unknown) {\n    84\t  try {\n    85\t    storage.setItem(key, JSON.stringify(value));\n    86\t  } catch {\n    87\t    // Stockage indisponible (mode privé, quota…) — la session ne\n    88\t    // reprendra simplement pas, jamais une erreur devant l'enfant.\n    89\t  }\n    90\t}\n    91\t\n    92\tfunction removeKey(storage: SerieStorage, key: string) {\n    93\t  try {\n    94\t    storage.removeItem(key);\n    95\t  } catch {\n    96\t    // Stockage indisponible — la clé fantôme est illisible de toute façon.\n    97\t  }\n    98\t}\n    99\t\n   100\t/* ------------------------- Ouverture de la session ------------------------- */\n   101\t\n   102\t/** La forme des réglages venus du serveur (MathSettings, sans l'importer). */\n   103\texport interface SessionSettingsSource extends FamilySettings {\n   104\t  authoritative?: boolean;\n   105\t}\n   106\t\n   107\t/**\n   108\t * Pont 2A/T4 : la série d'AVANT l'étagère (clé unique `calcul:serie`) est\n   109\t * re-rangée sous la clé de sa famille — jamais écrasante, et l'ancienne clé\n   110\t * ne disparaît qu'après RELECTURE de la clé cible (red-team RT1 : un write\n   111\t * avalé par un quota plein ne doit pas coûter la série ; on garde alors la\n   112\t * legacy pour un prochain passage). La chaîne brute est lue d'abord pour\n   113\t * pouvoir nettoyer une clé corrompue (adversarial #7 — readJson rend null\n   114\t * pour « absente » comme pour « illisible »).\n   115\t */\n   116\tfunction migrateLegacySerie(storage: SerieStorage) {\n   117\t  const legacyStr = readRaw(storage, LEGACY_SERIE_STATE_KEY);\n   118\t  if (legacyStr === null) {\n   119\t    return;\n   120\t  }\n   121\t  const legacy = bridgeLegacySerie(\n   122\t    readJson<unknown>(storage, LEGACY_SERIE_STATE_KEY)\n   123\t  );\n   124\t  if (legacy) {\n   125\t    const target = serieStorageKeyOf(legacy.famille);\n   126\t    if (readJson<unknown>(storage, target) === null) {\n   127\t      writeJson(storage, target, legacy.state);\n   128\t    }\n   129\t    if (readJson<unknown>(storage, target) === null) {\n   130\t      // La cible n'a pas pu s'écrire : on garde la legacy pour un\n   131\t      // prochain passage plutôt que de détruire la série.\n   132\t      return;\n   133\t    }\n   134\t  }\n   135\t  removeKey(storage, LEGACY_SERIE_STATE_KEY);\n   136\t}\n   137\t\n   138\t/**\n   139\t * Ouvre la session de l'atelier : pont de clé legacy (une seule fois), puis\n   140\t * réglages — DB quand elle répond (et mise en cache), sinon cache appareil,\n   141\t * sinon défauts — NORMALISÉS quelle que soit la source (un cache édité ou un\n   142\t * vieux format ne crashe jamais la page enfant).\n   143\t *\n   144\t * Le cache appareil ne mémorise que des réglages AUTHORITATIFS (adversarial\n   145\t * #3) : des défauts servis pendant la fenêtre pré-migration écraseraient les\n   146\t * vrais réglages mémorisés. La purge des clés orphelines des familles\n   147\t * désactivées (D-3A/F9) obéit à la même garde — des défauts (hors-ligne +\n   148\t * cache froid) ne sont pas une vérité sur les familles et ne doivent JAMAIS\n   149\t * coûter une série locale (red-team RT1 — « rien n'est jamais rangé dans le\n   150\t * dos de l'enfant »).\n   151\t */\n   152\texport function loadSession(\n   153\t  storage: SerieStorage,\n   154\t  dbSettings: SessionSettingsSource | null\n   155\t): FamilySettings {\n   156\t  migrateLegacySerie(storage);\n   157\t  const normalized = normalizeFamilySettings(\n   158\t    dbSettings ?? readJson<unknown>(storage, SETTINGS_CACHE_KEY)\n   159\t  );\n   160\t  if (dbSettings?.authoritative) {\n   161\t    writeJson(storage, SETTINGS_CACHE_KEY, normalized);\n   162\t    for (const op of FAMILLES) {\n   163\t      if (!normalized.familles.some((f) => f.op === op)) {\n   164\t        removeKey(storage, serieStorageKeyOf(op));\n   165\t      }\n   166\t    }\n   167\t  }\n   168\t  return normalized;\n   169\t}\n   170\t\n   171\t/* --------------------------- Reprise & étagère --------------------------- */\n   172\t\n   173\t/**\n   174\t * L'état « sorti » d'un plateau + reprise : lit la clé de la famille, valide\n   175\t * avec le prédicat complet (isResumableSerie, pur et golden-testé), PURGE\n   176\t * silencieusement une clé non reprenable (palier changé par le parent, cache\n   177\t * d'un autre format — l'éducatrice a réorganisé l'étagère, exception assumée\n   178\t * de la prémisse 4).\n   179\t */\n   180\texport function readResumableSerie(\n   181\t  storage: SerieStorage,\n   182\t  famille: Operation,\n   183\t  palierId: string,\n   184\t  serieSize: number\n   185\t): SerieStateLike | null {\n   186\t  const key = serieStorageKeyOf(famille);\n   187\t  const saved = readJson<SerieStateLike>(storage, key);\n   188\t  if (saved === null) {\n   189\t    return null;\n   190\t  }\n   191\t  if (isResumableSerie(saved, famille, palierId, serieSize)) {\n   192\t    return saved;\n   193\t  }\n   194\t  removeKey(storage, key);\n   195\t  return null;\n   196\t}\n   197\t\n   198\t/**\n   199\t * L'état « sorti » de chaque plateau de l'étagère — le prédicat complet\n   200\t * (reprise réelle), jamais « la clé existe » (design-review D-3A/F5).\n   201\t */\n   202\texport function shelfTrays(\n   203\t  storage: SerieStorage,\n   204\t  settings: FamilySettings\n   205\t): { op: Operation; sorti: boolean }[] {\n   206\t  return settings.familles.map((f) => ({\n   207\t    op: f.op,\n   208\t    sorti:\n   209\t      readResumableSerie(\n   210\t        storage,\n   211\t        f.op,\n   212\t        resolvePalierForFamille(f.op, f.palier).id,\n   213\t        settings.serieSize\n   214\t      ) !== null,\n   215\t  }));\n   216\t}\n   217\t\n   218\tfunction freshSerie(\n   219\t  famille: Operation,\n   220\t  palier: Palier,\n   221\t  serieSize: number,\n   222\t  seed: number\n   223\t): SerieStateLike {\n   224\t  const ops = safeGenerateSerie(palier, seed, serieSize);\n   225\t  return {\n   226\t    famille,\n   227\t    // ops vide (palier cassé, cas théorique) : perOp vide → isSerieFinished\n   228\t    // rend vrai et le rendu tombe sur l'état « rangé » — dégradation calme.\n   229\t    index: 0,\n   230\t    opsFingerprint: fingerprintOps(ops),\n   231\t    palierId: palier.id,\n   232\t    perOp: ops.map((op) => ({\n   233\t      done: false,\n   234\t      entries: emptyEntries(layoutOperation(op)),\n   235\t    })),\n   236\t    seed,\n   237\t    serieSize,\n   238\t  };\n   239\t}\n   240\t\n   241\t/**\n   242\t * Prendre un plateau : reprise exacte si la série est reprenable, sinon série\n   243\t * fraîche au palier parental de CETTE famille. Le seed naît à la PRISE du\n   244\t * plateau (T1 : plus de seed pré-engagé) ; il est injectable pour les goldens.\n   245\t */\n   246\texport function takeTray(\n   247\t  storage: SerieStorage,\n   248\t  settings: FamilySettings,\n   249\t  op: Operation,\n   250\t  seed: number = newSerieSeed()\n   251\t): SerieStateLike {\n   252\t  const reglage = settings.familles.find((f) => f.op === op);\n   253\t  const palier = resolvePalierForFamille(op, reglage?.palier);\n   254\t  return (\n   255\t    readResumableSerie(storage, op, palier.id, settings.serieSize) ??\n   256\t    freshSerie(op, palier, settings.serieSize, seed)\n   257\t  );\n   258\t}\n   259\t\n   260\t/** Persiste la série sous la clé de SA famille — chaque frappe est rangée. */\n   261\texport function saveSerie(storage: SerieStorage, state: SerieStateLike) {\n   262\t  writeJson(storage, serieStorageKeyOf(state.famille), state);\n   263\t}\n   264\t\n   265\t/** Range la clé d'une série finie (le moment « rangé », D-2A). */\n   266\texport function clearSerie(storage: SerieStorage, famille: Operation) {\n   267\t  removeKey(storage, serieStorageKeyOf(famille));\n   268\t}\n   269\t\n   270\t/* --------------------------- Gestes d'écriture --------------------------- */\n   271\t\n   272\t/** Une case adressable de la grille (résultat ou retenue), colonne 0 à gauche. */\n   273\texport type CellRef =\n   274\t  | { row: \"result\"; col: number }\n   275\t  | { row: \"carry\"; col: number };\n   276\t\n   277\t/** The droppable payload crosses dnd-kit untyped — validate, never cast. */\n   278\texport function isCellRef(value: unknown): value is CellRef {\n   279\t  const cell = value as CellRef | null;\n   280\t  return (\n   281\t    typeof cell === \"object\" &&\n   282\t    cell !== null &&\n   283\t    (cell.row === \"result\" || cell.row === \"carry\") &&\n   284\t    typeof cell.col === \"number\"\n   285\t  );\n   286\t}\n   287\t\n   288\t/**\n   289\t * Pencil flow, shared by tap and drag: after a result digit, the pencil steps\n   290\t * to the next column leftwards; col 0 and carry cells keep the pencil put.\n   291\t */\n   292\texport function pencilAdvance(cell: CellRef): CellRef {\n   293\t  return cell.row === \"result\" && cell.col > 0\n   294\t    ? { col: cell.col - 1, row: \"result\" }\n   295\t    : cell;\n   296\t}\n   297\t\n   298\t/** La grille vide d'une opération, aux dimensions exactes de son layout. */\n   299\texport function emptyEntries(layout: OperationLayout): SerieEntriesLike {\n   300\t  return {\n   301\t    carries: layout.carrySlots.map(() => null),\n   302\t    result: layout.expectedDigits.map(() => null),\n   303\t  };\n   304\t}\n   305\t\n   306\t/**\n   307\t * Écrit (ou efface, value null) une case de l'opération COURANTE. Tout est\n   308\t * borné et gardé : un drop tardif ou une écriture sur une opération figée\n   309\t * (done) rend l'état INCHANGÉ (même référence — React ne re-rend pas), jamais\n   310\t * une réponse gelée encrée ni un débordement.\n   311\t */\n   312\texport function writeCell(\n   313\t  state: SerieStateLike,\n   314\t  cell: CellRef,\n   315\t  value: string | null\n   316\t): SerieStateLike {\n   317\t  const op = state.perOp[state.index];\n   318\t  if (!op || op.done) {\n   319\t    return state;\n   320\t  }\n   321\t  const rowKey = cell.row === \"result\" ? \"result\" : \"carries\";\n   322\t  if (cell.col < 0 || cell.col >= op.entries[rowKey].length) {\n   323\t    return state;\n   324\t  }\n   325\t  const entries: SerieEntriesLike = {\n   326\t    carries: [...op.entries.carries],\n   327\t    result: [...op.entries.result],\n   328\t  };\n   329\t  entries[rowKey][cell.col] = value;\n   330\t  const perOp = state.perOp.map((o, i) =>\n   331\t    i === state.index ? { ...o, entries } : o\n   332\t  );\n   333\t  return { ...state, perOp };\n   334\t}\n   335\t\n   336\t/** « J'ai fini, je compare » : fige l'opération courante (done). */\n   337\texport function finishCurrent(state: SerieStateLike): SerieStateLike {\n   338\t  const perOp = state.perOp.map((op, i) =>\n   339\t    i === state.index ? { ...op, done: true } : op\n   340\t  );\n   341\t  return { ...state, perOp };\n   342\t}\n   343\t\n   344\t/** « Plateau suivant » : avance d'une opération dans la série. */\n   345\texport function advanceSerie(state: SerieStateLike): SerieStateLike {\n   346\t  return { ...state, index: state.index + 1 };\n   347\t}\n   348\t\n   349\t/**\n   350\t * Fin de série : l'index a dépassé la taille, ou série VIDE (palier cassé,\n   351\t * cas théorique) — même chemin calme vers le moment « rangé », jamais un\n   352\t * écran bloqué.\n   353\t */\n   354\texport function isSerieFinished(state: SerieStateLike): boolean {\n   355\t  return state.index >= state.serieSize || state.perOp.length === 0;\n   356\t}\n","exit_code":0,"status":"completed"}}
