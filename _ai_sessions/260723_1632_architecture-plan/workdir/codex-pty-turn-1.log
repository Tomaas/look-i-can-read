{"type":"item.completed","item":{"id":"item_26","type":"command_execution","command":"/usr/bin/zsh -lc \"rg -n \\\"legacy|quota|occupied|authoritative|purge|palier|fingerprint|throw|takeTray|seed|save|finish|advance\\\" src/lib/operations/__tests__/serie-session.golden.ts | sed -n '1,260p'; nl -ba src/lib/operations/__tests__/serie-session.golden.ts | sed -n '1,640p'\"","aggregated_output":"5: * legacy bridge, authoritative purge, resume-or-fresh (incl. purge on\n6: * mismatch), fingerprint round-trip, silent storage-failure degradation and\n17:  advanceSerie,\n25:  fingerprintOps,\n26:  finishCurrent,\n39:  saveSerie,\n42:  takeTray,\n81:    throw new Error(\"storage indisponible\");\n86:/** Un stockage plein : lecture OK, écriture/suppression refusées (quota). */\n93:    throw new Error(\"quota dépassé\");\n107:const palierAdd = resolvePalierForFamille(\"addition\", null); // premier palier\n108:const opsAdd = safeGenerateSerie(palierAdd, 42, 3);\n110:const legacyState = {\n112:  opsFingerprint: fingerprintOps(opsAdd),\n113:  palierId: palierAdd.id,\n118:  seed: 42,\n128:/* ----------------------------- Pont de clé legacy ----------------------------- */\n132:    [LEGACY_SERIE_STATE_KEY]: JSON.stringify(legacyState),\n137:    \"pont legacy: la série migre sous la clé de sa famille, enrichie\",\n138:    moved !== null && moved.famille === \"addition\" && moved.seed === 42,\n142:    \"pont legacy: l'ancienne clé disparaît après relecture de la cible\",\n146:    \"pont legacy: sans DB ni cache → réglages par défaut\",\n150:  // (même palier par défaut, même taille) — le plateau est « sorti ».\n152:    \"pont legacy: la série migrée se reprend (plateau sorti sur l'étagère)\",\n159:    \"pont legacy: idempotent — une seconde ouverture ne change rien\",\n161:      JSON.parse(map.get(serieStorageKeyOf(\"addition\")) ?? \"null\").seed === 42\n166:  // Jamais écrasante : une clé de famille déjà occupée gagne sur la legacy.\n167:  const occupant = JSON.stringify({ ...legacyState, seed: 7 });\n169:    [LEGACY_SERIE_STATE_KEY]: JSON.stringify(legacyState),\n174:    \"pont legacy: une clé cible occupée n'est jamais écrasée\",\n178:    \"pont legacy: la legacy est tout de même rangée (cible confirmée)\",\n184:  // Red-team RT1 : un write avalé (quota plein) ne coûte pas la série —\n185:  // la legacy RESTE pour un prochain passage.\n187:    [LEGACY_SERIE_STATE_KEY]: JSON.stringify(legacyState),\n191:    \"pont legacy: cible inécrivable → la legacy survit pour un prochain passage\",\n196:    \"pont legacy: l'échec d'écriture ne bloque pas les réglages\",\n203:    \"pont legacy: retenté au passage suivant, il aboutit\",\n210:  // Adversarial #7 : une legacy corrompue (JSON illisible) est nettoyée,\n215:    \"pont legacy: une clé corrompue est nettoyée sans rien créer\",\n220:/* --------------------- Réglages : cache & purge authoritative --------------------- */\n223:  const junk = JSON.stringify({ ...legacyState, famille: \"soustraction\" });\n230:    authoritative: true,\n231:    familles: [{ op: \"addition\" as const, palier: \"add-retenue\" }],\n236:    \"purge authoritative: les clés des familles désactivées sont rangées\",\n241:    \"purge authoritative: la clé d'une famille ACTIVÉE survit\",\n248:      settings.familles[0].palier === \"add-retenue\" &&\n255:  // pendant la fenêtre pré-migration) ne cachent rien et ne purgent RIEN.\n260:    authoritative: false,\n261:    familles: [{ op: \"addition\", palier: \"add-sans-retenue\" }],\n265:    \"réglages non authoritatifs: jamais de purge ni de cache\",\n272:  // Hors-ligne : la DB muette (null) lit le cache appareil, ne purge rien.\n274:    familles: [{ op: \"soustraction\", palier: \"sous-emprunt\" }],\n287:    \"hors-ligne: aucune purge — une série locale n'est jamais rangée sur des défauts\",\n302:/* ------------------- Reprise-ou-fraîche & purge sur désaccord ------------------- */\n305:  const saved: SerieStateLike = { ...legacyState, famille: \"addition\" };\n307:    [serieStorageKeyOf(\"addition\")]: JSON.stringify(saved),\n309:  const taken = takeTray(storage, defaultSettings, \"addition\", 999);\n311:    \"takeTray: une série reprenable se reprend EXACTEMENT (jamais régénérée)\",\n312:    JSON.stringify(taken) === JSON.stringify(saved)\n318:  // au palier parental (l'éducatrice a réorganisé l'étagère).\n319:  const saved: SerieStateLike = { ...legacyState, famille: \"addition\" };\n321:    familles: [{ op: \"addition\", palier: \"add-retenue\" }],\n325:    [serieStorageKeyOf(\"addition\")]: JSON.stringify(saved),\n327:  const fresh = takeTray(storage, parentSettings, \"addition\", 123);\n329:    \"takeTray: palier changé → série fraîche au palier parental, index 0\",\n330:    fresh.palierId === \"add-retenue\" &&\n332:      fresh.seed === 123 &&\n337:    \"purge sur désaccord: la clé non reprenable a été rangée\",\n341:    \"readResumableSerie: après purge, plus rien à reprendre\",\n347:  // Une famille sans réglage explicite prend le premier palier de SA famille.\n349:  const fresh = takeTray(\n352:      familles: [{ op: \"multiplication\", palier: \"mult-1-chiffre\" }],\n359:    \"takeTray: famille sans réglage → premier palier de la famille\",\n360:    fresh.famille === \"soustraction\" && fresh.palierId === \"sous-sans-emprunt\"\n364:/* ----------------------- Aller-retour d'empreinte (seed) ----------------------- */\n369:  const t1 = takeTray(storage, settings, \"addition\", 2026);\n371:    \"empreinte: la série fraîche régénère IDENTIQUEMENT depuis (palier, seed)\",\n373:      fingerprintOps(safeGenerateSerie(palierAdd, 2026, settings.serieSize)) &&\n380:  saveSerie(storage, written);\n381:  const t2 = takeTray(storage, settings, \"addition\", 777);\n385:      t2.seed === 2026 &&\n410:    const serie = takeTray(broken, settings, \"addition\", 11);\n411:    saveSerie(broken, serie);\n429:  // La purge authoritative sur stockage en panne ne lève pas non plus.\n430:  let purgeThrew = false;\n433:      authoritative: true,\n434:      familles: [{ op: \"addition\", palier: \"add-sans-retenue\" }],\n438:    purgeThrew = true;\n441:    \"stockage en panne: cache + purge authoritative silencieux\",\n442:    !purgeThrew\n467:  const serie = takeTray(storage, defaultSettings, \"addition\", 42);\n492:  const done = finishCurrent(serie);\n494:    \"finishCurrent: fige l'opération courante seulement\",\n501:  const advanced = advanceSerie(done);\n503:    \"advanceSerie: passe à l'opération suivante\",\n504:    advanced.index === serie.index + 1\n507:    \"isSerieFinished: fin quand l'index dépasse, ou série vide (palier cassé)\",\n545:    seed: 1,\n     1\t/**\n     2\t * SERIE-SESSION assertion script — la vie de la série hors rendu.\n     3\t *\n     4\t * Pins the serie-session module (the deep module behind the /calcul route):\n     5\t * legacy bridge, authoritative purge, resume-or-fresh (incl. purge on\n     6\t * mismatch), fingerprint round-trip, silent storage-failure degradation and\n     7\t * the writing verbs. Same standalone-runnable pattern as operations.golden.ts:\n     8\t *   bun run src/lib/operations/__tests__/serie-session.golden.ts\n     9\t * (chained into `bun run test:operations`). Exits non-zero on any failure.\n    10\t *\n    11\t * Le stockage passe par le port SerieStorage : une Map ici (adaptateur\n    12\t * mémoire), window.localStorage en prod — la MÊME logique tourne des deux\n    13\t * côtés, c'est tout l'intérêt de la couture.\n    14\t */\n    15\t\n    16\timport {\n    17\t  advanceSerie,\n    18\t  browserSerieStorage,\n    19\t  type CellRef,\n    20\t  clearSerie,\n    21\t  DEFAULT_SERIE_SIZE,\n    22\t  defaultFamilySettings,\n    23\t  emptyEntries,\n    24\t  type FamilySettings,\n    25\t  fingerprintOps,\n    26\t  finishCurrent,\n    27\t  isCellRef,\n    28\t  isSerieFinished,\n    29\t  LEGACY_SERIE_STATE_KEY,\n    30\t  layoutOperation,\n    31\t  loadSession,\n    32\t  pencilAdvance,\n    33\t  readResumableSerie,\n    34\t  resolvePalierForFamille,\n    35\t  SETTINGS_CACHE_KEY,\n    36\t  type SerieStateLike,\n    37\t  type SerieStorage,\n    38\t  safeGenerateSerie,\n    39\t  saveSerie,\n    40\t  serieStorageKeyOf,\n    41\t  shelfTrays,\n    42\t  takeTray,\n    43\t  writeCell,\n    44\t} from \"~/lib/operations\";\n    45\t\n    46\tlet failures = 0;\n    47\tfunction check(name: string, ok: boolean, detail?: string) {\n    48\t  if (ok) {\n    49\t    console.log(`✓ ${name}`);\n    50\t  } else {\n    51\t    failures += 1;\n    52\t    console.error(`✗ ${name}${detail ? `\\n  ${detail}` : \"\"}`);\n    53\t  }\n    54\t}\n    55\t\n    56\t/* ------------------------------- Adaptateurs ------------------------------- */\n    57\t\n    58\t/** Adaptateur mémoire des goldens — la Map est inspectable directement. */\n    59\tfunction memoryStorage(initial?: Record<string, string>): {\n    60\t  map: Map<string, string>;\n    61\t  storage: SerieStorage;\n    62\t} {\n    63\t  const map = new Map(Object.entries(initial ?? {}));\n    64\t  return {\n    65\t    map,\n    66\t    storage: {\n    67\t      getItem: (key) => map.get(key) ?? null,\n    68\t      removeItem: (key) => {\n    69\t        map.delete(key);\n    70\t      },\n    71\t      setItem: (key, value) => {\n    72\t        map.set(key, value);\n    73\t      },\n    74\t    },\n    75\t  };\n    76\t}\n    77\t\n    78\t/** Un stockage qui lève sur TOUT (mode privé le plus hostile). */\n    79\tfunction brokenStorage(): SerieStorage {\n    80\t  const boom = () => {\n    81\t    throw new Error(\"storage indisponible\");\n    82\t  };\n    83\t  return { getItem: boom, removeItem: boom, setItem: boom };\n    84\t}\n    85\t\n    86\t/** Un stockage plein : lecture OK, écriture/suppression refusées (quota). */\n    87\tfunction fullStorage(initial?: Record<string, string>): {\n    88\t  map: Map<string, string>;\n    89\t  storage: SerieStorage;\n    90\t} {\n    91\t  const { map } = memoryStorage(initial);\n    92\t  const boom = () => {\n    93\t    throw new Error(\"quota dépassé\");\n    94\t  };\n    95\t  return {\n    96\t    map,\n    97\t    storage: {\n    98\t      getItem: (key) => map.get(key) ?? null,\n    99\t      removeItem: boom,\n   100\t      setItem: boom,\n   101\t    },\n   102\t  };\n   103\t}\n   104\t\n   105\t/* --------------------------- États de référence --------------------------- */\n   106\t\n   107\tconst palierAdd = resolvePalierForFamille(\"addition\", null); // premier palier\n   108\tconst opsAdd = safeGenerateSerie(palierAdd, 42, 3);\n   109\t/** Une série valide au format d'AVANT l'étagère (sans champ famille). */\n   110\tconst legacyState = {\n   111\t  index: 1,\n   112\t  opsFingerprint: fingerprintOps(opsAdd),\n   113\t  palierId: palierAdd.id,\n   114\t  perOp: opsAdd.map(() => ({\n   115\t    done: false,\n   116\t    entries: emptyEntries(layoutOperation(opsAdd[0])),\n   117\t  })),\n   118\t  seed: 42,\n   119\t  serieSize: 3,\n   120\t};\n   121\tconst defaultSettings: FamilySettings = defaultFamilySettings();\n   122\t\n   123\tcheck(\n   124\t  \"clé du cache de réglages: l'ex-clé orpheline de la route, épinglée\",\n   125\t  SETTINGS_CACHE_KEY === \"calcul:settings\"\n   126\t);\n   127\t\n   128\t/* ----------------------------- Pont de clé legacy ----------------------------- */\n   129\t\n   130\t{\n   131\t  const { map, storage } = memoryStorage({\n   132\t    [LEGACY_SERIE_STATE_KEY]: JSON.stringify(legacyState),\n   133\t  });\n   134\t  const settings = loadSession(storage, null);\n   135\t  const moved = JSON.parse(map.get(serieStorageKeyOf(\"addition\")) ?? \"null\");\n   136\t  check(\n   137\t    \"pont legacy: la série migre sous la clé de sa famille, enrichie\",\n   138\t    moved !== null && moved.famille === \"addition\" && moved.seed === 42,\n   139\t    map.get(serieStorageKeyOf(\"addition\"))\n   140\t  );\n   141\t  check(\n   142\t    \"pont legacy: l'ancienne clé disparaît après relecture de la cible\",\n   143\t    map.get(LEGACY_SERIE_STATE_KEY) === undefined\n   144\t  );\n   145\t  check(\n   146\t    \"pont legacy: sans DB ni cache → réglages par défaut\",\n   147\t    JSON.stringify(settings) === JSON.stringify(defaultSettings)\n   148\t  );\n   149\t  // Aller-retour complet : la série migrée est REPRENABLE telle quelle\n   150\t  // (même palier par défaut, même taille) — le plateau est « sorti ».\n   151\t  check(\n   152\t    \"pont legacy: la série migrée se reprend (plateau sorti sur l'étagère)\",\n   153\t    JSON.stringify(shelfTrays(storage, settings)) ===\n   154\t      JSON.stringify([{ op: \"addition\", sorti: true }])\n   155\t  );\n   156\t  // Une seconde ouverture ne migre plus rien (le pont est une seule fois).\n   157\t  loadSession(storage, null);\n   158\t  check(\n   159\t    \"pont legacy: idempotent — une seconde ouverture ne change rien\",\n   160\t    map.get(LEGACY_SERIE_STATE_KEY) === undefined &&\n   161\t      JSON.parse(map.get(serieStorageKeyOf(\"addition\")) ?? \"null\").seed === 42\n   162\t  );\n   163\t}\n   164\t\n   165\t{\n   166\t  // Jamais écrasante : une clé de famille déjà occupée gagne sur la legacy.\n   167\t  const occupant = JSON.stringify({ ...legacyState, seed: 7 });\n   168\t  const { map, storage } = memoryStorage({\n   169\t    [LEGACY_SERIE_STATE_KEY]: JSON.stringify(legacyState),\n   170\t    [serieStorageKeyOf(\"addition\")]: occupant,\n   171\t  });\n   172\t  loadSession(storage, null);\n   173\t  check(\n   174\t    \"pont legacy: une clé cible occupée n'est jamais écrasée\",\n   175\t    map.get(serieStorageKeyOf(\"addition\")) === occupant\n   176\t  );\n   177\t  check(\n   178\t    \"pont legacy: la legacy est tout de même rangée (cible confirmée)\",\n   179\t    map.get(LEGACY_SERIE_STATE_KEY) === undefined\n   180\t  );\n   181\t}\n   182\t\n   183\t{\n   184\t  // Red-team RT1 : un write avalé (quota plein) ne coûte pas la série —\n   185\t  // la legacy RESTE pour un prochain passage.\n   186\t  const { map, storage } = fullStorage({\n   187\t    [LEGACY_SERIE_STATE_KEY]: JSON.stringify(legacyState),\n   188\t  });\n   189\t  const settings = loadSession(storage, null);\n   190\t  check(\n   191\t    \"pont legacy: cible inécrivable → la legacy survit pour un prochain passage\",\n   192\t    map.get(LEGACY_SERIE_STATE_KEY) !== undefined &&\n   193\t      map.get(serieStorageKeyOf(\"addition\")) === undefined\n   194\t  );\n   195\t  check(\n   196\t    \"pont legacy: l'échec d'écriture ne bloque pas les réglages\",\n   197\t    JSON.stringify(settings) === JSON.stringify(defaultSettings)\n   198\t  );\n   199\t  // Un passage suivant, stockage redevenu accessible : la migration aboutit.\n   200\t  const retry = memoryStorage(Object.fromEntries(map));\n   201\t  loadSession(retry.storage, null);\n   202\t  check(\n   203\t    \"pont legacy: retenté au passage suivant, il aboutit\",\n   204\t    retry.map.get(LEGACY_SERIE_STATE_KEY) === undefined &&\n   205\t      retry.map.get(serieStorageKeyOf(\"addition\")) !== undefined\n   206\t  );\n   207\t}\n   208\t\n   209\t{\n   210\t  // Adversarial #7 : une legacy corrompue (JSON illisible) est nettoyée,\n   211\t  // rien n'est créé.\n   212\t  const { map, storage } = memoryStorage({ [LEGACY_SERIE_STATE_KEY]: \"{oops\" });\n   213\t  loadSession(storage, null);\n   214\t  check(\n   215\t    \"pont legacy: une clé corrompue est nettoyée sans rien créer\",\n   216\t    map.get(LEGACY_SERIE_STATE_KEY) === undefined && map.size === 0\n   217\t  );\n   218\t}\n   219\t\n   220\t/* --------------------- Réglages : cache & purge authoritative --------------------- */\n   221\t\n   222\t{\n   223\t  const junk = JSON.stringify({ ...legacyState, famille: \"soustraction\" });\n   224\t  const { map, storage } = memoryStorage({\n   225\t    [serieStorageKeyOf(\"addition\")]: \"addition-serie\",\n   226\t    [serieStorageKeyOf(\"multiplication\")]: junk,\n   227\t    [serieStorageKeyOf(\"soustraction\")]: junk,\n   228\t  });\n   229\t  const db = {\n   230\t    authoritative: true,\n   231\t    familles: [{ op: \"addition\" as const, palier: \"add-retenue\" }],\n   232\t    serieSize: 4,\n   233\t  };\n   234\t  const settings = loadSession(storage, db);\n   235\t  check(\n   236\t    \"purge authoritative: les clés des familles désactivées sont rangées\",\n   237\t    map.get(serieStorageKeyOf(\"soustraction\")) === undefined &&\n   238\t      map.get(serieStorageKeyOf(\"multiplication\")) === undefined\n   239\t  );\n   240\t  check(\n   241\t    \"purge authoritative: la clé d'une famille ACTIVÉE survit\",\n   242\t    map.get(serieStorageKeyOf(\"addition\")) === \"addition-serie\"\n   243\t  );\n   244\t  check(\n   245\t    \"réglages authoritatifs: mis en cache appareil, normalisés\",\n   246\t    map.get(SETTINGS_CACHE_KEY) === JSON.stringify(settings) &&\n   247\t      settings.familles.length === 1 &&\n   248\t      settings.familles[0].palier === \"add-retenue\" &&\n   249\t      settings.serieSize === 4\n   250\t  );\n   251\t}\n   252\t\n   253\t{\n   254\t  // Adversarial #3 / RT1 : des réglages NON authoritatifs (défauts servis\n   255\t  // pendant la fenêtre pré-migration) ne cachent rien et ne purgent RIEN.\n   256\t  const { map, storage } = memoryStorage({\n   257\t    [serieStorageKeyOf(\"soustraction\")]: \"une-serie-locale\",\n   258\t  });\n   259\t  loadSession(storage, {\n   260\t    authoritative: false,\n   261\t    familles: [{ op: \"addition\", palier: \"add-sans-retenue\" }],\n   262\t    serieSize: 3,\n   263\t  });\n   264\t  check(\n   265\t    \"réglages non authoritatifs: jamais de purge ni de cache\",\n   266\t    map.get(serieStorageKeyOf(\"soustraction\")) === \"une-serie-locale\" &&\n   267\t      map.get(SETTINGS_CACHE_KEY) === undefined\n   268\t  );\n   269\t}\n   270\t\n   271\t{\n   272\t  // Hors-ligne : la DB muette (null) lit le cache appareil, ne purge rien.\n   273\t  const cached: FamilySettings = {\n   274\t    familles: [{ op: \"soustraction\", palier: \"sous-emprunt\" }],\n   275\t    serieSize: 5,\n   276\t  };\n   277\t  const { map, storage } = memoryStorage({\n   278\t    [SETTINGS_CACHE_KEY]: JSON.stringify(cached),\n   279\t    [serieStorageKeyOf(\"addition\")]: \"serie-orpheline-locale\",\n   280\t  });\n   281\t  const settings = loadSession(storage, null);\n   282\t  check(\n   283\t    \"hors-ligne: les réglages viennent du cache appareil, normalisés\",\n   284\t    JSON.stringify(settings) === JSON.stringify(cached)\n   285\t  );\n   286\t  check(\n   287\t    \"hors-ligne: aucune purge — une série locale n'est jamais rangée sur des défauts\",\n   288\t    map.get(serieStorageKeyOf(\"addition\")) === \"serie-orpheline-locale\"\n   289\t  );\n   290\t}\n   291\t\n   292\t{\n   293\t  // Un cache appareil corrompu → défauts sûrs, jamais un crash.\n   294\t  const { storage } = memoryStorage({ [SETTINGS_CACHE_KEY]: \"{oops\" });\n   295\t  check(\n   296\t    \"cache corrompu: défauts sûrs\",\n   297\t    JSON.stringify(loadSession(storage, null)) ===\n   298\t      JSON.stringify(defaultSettings)\n   299\t  );\n   300\t}\n   301\t\n   302\t/* ------------------- Reprise-ou-fraîche & purge sur désaccord ------------------- */\n   303\t\n   304\t{\n   305\t  const saved: SerieStateLike = { ...legacyState, famille: \"addition\" };\n   306\t  const { storage } = memoryStorage({\n   307\t    [serieStorageKeyOf(\"addition\")]: JSON.stringify(saved),\n   308\t  });\n   309\t  const taken = takeTray(storage, defaultSettings, \"addition\", 999);\n   310\t  check(\n   311\t    \"takeTray: une série reprenable se reprend EXACTEMENT (jamais régénérée)\",\n   312\t    JSON.stringify(taken) === JSON.stringify(saved)\n   313\t  );\n   314\t}\n   315\t\n   316\t{\n   317\t  // Palier changé par le parent → la clé est purgée, la série repart fraîche\n   318\t  // au palier parental (l'éducatrice a réorganisé l'étagère).\n   319\t  const saved: SerieStateLike = { ...legacyState, famille: \"addition\" };\n   320\t  const parentSettings: FamilySettings = {\n   321\t    familles: [{ op: \"addition\", palier: \"add-retenue\" }],\n   322\t    serieSize: 3,\n   323\t  };\n   324\t  const { map, storage } = memoryStorage({\n   325\t    [serieStorageKeyOf(\"addition\")]: JSON.stringify(saved),\n   326\t  });\n   327\t  const fresh = takeTray(storage, parentSettings, \"addition\", 123);\n   328\t  check(\n   329\t    \"takeTray: palier changé → série fraîche au palier parental, index 0\",\n   330\t    fresh.palierId === \"add-retenue\" &&\n   331\t      fresh.index === 0 &&\n   332\t      fresh.seed === 123 &&\n   333\t      fresh.perOp.length === 3 &&\n   334\t      fresh.perOp.every((op) => !op.done)\n   335\t  );\n   336\t  check(\n   337\t    \"purge sur désaccord: la clé non reprenable a été rangée\",\n   338\t    map.get(serieStorageKeyOf(\"addition\")) === undefined\n   339\t  );\n   340\t  check(\n   341\t    \"readResumableSerie: après purge, plus rien à reprendre\",\n   342\t    readResumableSerie(storage, \"addition\", \"add-retenue\", 3) === null\n   343\t  );\n   344\t}\n   345\t\n   346\t{\n   347\t  // Une famille sans réglage explicite prend le premier palier de SA famille.\n   348\t  const { storage } = memoryStorage();\n   349\t  const fresh = takeTray(\n   350\t    storage,\n   351\t    {\n   352\t      familles: [{ op: \"multiplication\", palier: \"mult-1-chiffre\" }],\n   353\t      serieSize: 2,\n   354\t    },\n   355\t    \"soustraction\",\n   356\t    5\n   357\t  );\n   358\t  check(\n   359\t    \"takeTray: famille sans réglage → premier palier de la famille\",\n   360\t    fresh.famille === \"soustraction\" && fresh.palierId === \"sous-sans-emprunt\"\n   361\t  );\n   362\t}\n   363\t\n   364\t/* ----------------------- Aller-retour d'empreinte (seed) ----------------------- */\n   365\t\n   366\t{\n   367\t  const { map, storage } = memoryStorage();\n   368\t  const settings = defaultSettings;\n   369\t  const t1 = takeTray(storage, settings, \"addition\", 2026);\n   370\t  check(\n   371\t    \"empreinte: la série fraîche régénère IDENTIQUEMENT depuis (palier, seed)\",\n   372\t    t1.opsFingerprint ===\n   373\t      fingerprintOps(safeGenerateSerie(palierAdd, 2026, settings.serieSize)) &&\n   374\t      t1.opsFingerprint.length > 0\n   375\t  );\n   376\t  // Écrire un chiffre, ranger, reprendre : la MÊME série revient, chiffre\n   377\t  // compris — une série interrompue ne change jamais sous les yeux de\n   378\t  // l'enfant.\n   379\t  const written = writeCell(t1, { col: 1, row: \"result\" }, \"4\");\n   380\t  saveSerie(storage, written);\n   381\t  const t2 = takeTray(storage, settings, \"addition\", 777);\n   382\t  check(\n   383\t    \"empreinte: rangée puis reprise → même série, chiffre écrit compris\",\n   384\t    JSON.stringify(t2) === JSON.stringify(written) &&\n   385\t      t2.seed === 2026 &&\n   386\t      t2.perOp[0].entries.result[1] === \"4\"\n   387\t  );\n   388\t  check(\n   389\t    \"shelfTrays: le plateau écrit est « sorti » (prédicat complet)\",\n   390\t    JSON.stringify(shelfTrays(storage, settings)) ===\n   391\t      JSON.stringify([{ op: \"addition\", sorti: true }])\n   392\t  );\n   393\t  clearSerie(storage, \"addition\");\n   394\t  check(\n   395\t    \"clearSerie: la clé de la famille est rangée, le plateau n'est plus sorti\",\n   396\t    map.get(serieStorageKeyOf(\"addition\")) === undefined &&\n   397\t      JSON.stringify(shelfTrays(storage, settings)) ===\n   398\t        JSON.stringify([{ op: \"addition\", sorti: false }])\n   399\t  );\n   400\t}\n   401\t\n   402\t/* -------------------- Stockage en panne : dégradation silencieuse -------------------- */\n   403\t\n   404\t{\n   405\t  const broken = brokenStorage();\n   406\t  let settings: FamilySettings | null = null;\n   407\t  let threw = false;\n   408\t  try {\n   409\t    settings = loadSession(broken, null);\n   410\t    const serie = takeTray(broken, settings, \"addition\", 11);\n   411\t    saveSerie(broken, serie);\n   412\t    clearSerie(broken, \"addition\");\n   413\t    check(\n   414\t      \"stockage en panne: une série fraîche naît quand même\",\n   415\t      serie.index === 0 && serie.perOp.length === settings.serieSize\n   416\t    );\n   417\t    check(\n   418\t      \"stockage en panne: l'étagère s'affiche, plateaux rangés\",\n   419\t      JSON.stringify(shelfTrays(broken, settings)) ===\n   420\t        JSON.stringify([{ op: \"addition\", sorti: false }])\n   421\t    );\n   422\t  } catch {\n   423\t    threw = true;\n   424\t  }\n   425\t  check(\n   426\t    \"stockage en panne: AUCUNE exception ne sort du module (défauts sûrs)\",\n   427\t    !threw && JSON.stringify(settings) === JSON.stringify(defaultSettings)\n   428\t  );\n   429\t  // La purge authoritative sur stockage en panne ne lève pas non plus.\n   430\t  let purgeThrew = false;\n   431\t  try {\n   432\t    loadSession(broken, {\n   433\t      authoritative: true,\n   434\t      familles: [{ op: \"addition\", palier: \"add-sans-retenue\" }],\n   435\t      serieSize: 3,\n   436\t    });\n   437\t  } catch {\n   438\t    purgeThrew = true;\n   439\t  }\n   440\t  check(\n   441\t    \"stockage en panne: cache + purge authoritative silencieux\",\n   442\t    !purgeThrew\n   443\t  );\n   444\t}\n   445\t\n   446\t{\n   447\t  // L'adaptateur prod : window n'existe pas sous bun — chaque méthode lève,\n   448\t  // et le module dégrade en défauts sûrs. C'est EXACTEMENT le contrat SSR /\n   449\t  // mode privé (window touché à l'appel seulement, jamais à la création).\n   450\t  let threw = false;\n   451\t  let settings: FamilySettings | null = null;\n   452\t  try {\n   453\t    settings = loadSession(browserSerieStorage(), null);\n   454\t  } catch {\n   455\t    threw = true;\n   456\t  }\n   457\t  check(\n   458\t    \"browserSerieStorage: sans window (SSR/bun), défauts sûrs sans exception\",\n   459\t    !threw && JSON.stringify(settings) === JSON.stringify(defaultSettings)\n   460\t  );\n   461\t}\n   462\t\n   463\t/* ----------------------------- Gestes d'écriture ----------------------------- */\n   464\t\n   465\t{\n   466\t  const { storage } = memoryStorage();\n   467\t  const serie = takeTray(storage, defaultSettings, \"addition\", 42);\n   468\t  const cols = serie.perOp[0].entries.result.length;\n   469\t\n   470\t  const inked = writeCell(serie, { col: 0, row: \"result\" }, \"9\");\n   471\t  check(\n   472\t    \"writeCell: encre la case visée de l'opération courante, immutable\",\n   473\t    inked.perOp[0].entries.result[0] === \"9\" &&\n   474\t      serie.perOp[0].entries.result[0] === null &&\n   475\t      inked !== serie\n   476\t  );\n   477\t  const erased = writeCell(inked, { col: 0, row: \"result\" }, null);\n   478\t  check(\n   479\t    \"writeCell: value null efface (la gomme)\",\n   480\t    erased.perOp[0].entries.result[0] === null\n   481\t  );\n   482\t  const carry = writeCell(serie, { col: 0, row: \"carry\" }, \"1\");\n   483\t  check(\n   484\t    \"writeCell: la rangée des retenues s'écrit aussi\",\n   485\t    carry.perOp[0].entries.carries[0] === \"1\"\n   486\t  );\n   487\t  check(\n   488\t    \"writeCell: hors bornes → état INCHANGÉ (même référence, pas de re-rendu)\",\n   489\t    writeCell(serie, { col: cols, row: \"result\" }, \"1\") === serie &&\n   490\t      writeCell(serie, { col: -1, row: \"result\" }, \"1\") === serie\n   491\t  );\n   492\t  const done = finishCurrent(serie);\n   493\t  check(\n   494\t    \"finishCurrent: fige l'opération courante seulement\",\n   495\t    done.perOp[0].done && done.perOp.slice(1).every((op) => !op.done)\n   496\t  );\n   497\t  check(\n   498\t    \"writeCell: une opération figée (done) n'encre plus jamais\",\n   499\t    writeCell(done, { col: 0, row: \"result\" }, \"5\") === done\n   500\t  );\n   501\t  const advanced = advanceSerie(done);\n   502\t  check(\n   503\t    \"advanceSerie: passe à l'opération suivante\",\n   504\t    advanced.index === serie.index + 1\n   505\t  );\n   506\t  check(\n   507\t    \"isSerieFinished: fin quand l'index dépasse, ou série vide (palier cassé)\",\n   508\t    !isSerieFinished(serie) &&\n   509\t      isSerieFinished({ ...serie, index: serie.serieSize }) &&\n   510\t      isSerieFinished({ ...serie, perOp: [] })\n   511\t  );\n   512\t}\n   513\t\n   514\t{\n   515\t  check(\n   516\t    \"pencilAdvance: un chiffre de résultat fait avancer le crayon vers la gauche\",\n   517\t    JSON.stringify(pencilAdvance({ col: 2, row: \"result\" })) ===\n   518\t      JSON.stringify({ col: 1, row: \"result\" })\n   519\t  );\n   520\t  check(\n   521\t    \"pencilAdvance: colonne 0 et retenues gardent le crayon en place\",\n   522\t    JSON.stringify(pencilAdvance({ col: 0, row: \"result\" })) ===\n   523\t      JSON.stringify({ col: 0, row: \"result\" }) &&\n   524\t      JSON.stringify(pencilAdvance({ col: 2, row: \"carry\" })) ===\n   525\t        JSON.stringify({ col: 2, row: \"carry\" })\n   526\t  );\n   527\t  const valid: CellRef = { col: 1, row: \"carry\" };\n   528\t  check(\n   529\t    \"isCellRef: valide le payload dnd non typé, refuse le reste\",\n   530\t    isCellRef(valid) &&\n   531\t      isCellRef({ col: 0, row: \"result\" }) &&\n   532\t      !(\n   533\t        isCellRef(null) ||\n   534\t        isCellRef(\"cell\") ||\n   535\t        isCellRef({ col: \"1\", row: \"result\" }) ||\n   536\t        isCellRef({ col: 1, row: \"operand\" })\n   537\t      )\n   538\t  );\n   539\t  const layout = layoutOperation({\n   540\t    a: 85,\n   541\t    b: 61,\n   542\t    carries: 1,\n   543\t    expected: 146,\n   544\t    op: \"addition\",\n   545\t    seed: 1,\n   546\t  });\n   547\t  const entries = emptyEntries(layout);\n   548\t  check(\n   549\t    \"emptyEntries: aux dimensions exactes du layout, toutes cases vides\",\n   550\t    entries.result.length === 3 &&\n   551\t      entries.carries.length === 3 &&\n   552\t      entries.result.every((v) => v === null) &&\n   553\t      entries.carries.every((v) => v === null)\n   554\t  );\n   555\t  check(\n   556\t    \"DEFAULT_SERIE_SIZE: les défauts de session suivent la source unique\",\n   557\t    defaultSettings.serieSize === DEFAULT_SERIE_SIZE\n   558\t  );\n   559\t}\n   560\t\n   561\t/* --------------------------------- Bilan --------------------------------- */\n   562\t\n   563\tif (failures > 0) {\n   564\t  console.error(`\\n${failures} assertion(s) en échec.`);\n   565\t  process.exit(1);\n   566\t}\n   567\tconsole.log(\"\\nToutes les assertions serie-session passent.\");\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_27","type":"command_execution","command":"/usr/bin/zsh -lc \"nl -ba src/server/providers/__tests__/media-store.golden.ts | sed -n '1,360p'; git diff --unified=40 main...HEAD -- src/server/providers/__tests__/media-store.golden.ts\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_27","type":"command_execution","command":"/usr/bin/zsh -lc \"nl -ba src/server/providers/__tests__/media-store.golden.ts | sed -n '1,360p'; git diff --unified=40 main...HEAD -- src/server/providers/__tests__/media-store.golden.ts\"","aggregated_output":"     1\t/**\n     2\t * MEDIA-STORE assertion script — the single media choke-point's READ-BACK.\n     3\t *\n     4\t * Pins:\n     5\t *  1. blob host allowlist derivation (`blobHostFromToken` must lowercase — a\n     6\t *     mixed-case store id once made the app silently reject its OWN blob URLs\n     7\t *     and disable every reference image in blob/prod mode);\n     8\t *  2. the https-branch allowlist decision (`allowedStoredMediaUrl`, pure):\n     9\t *     exact own-store host when the rw token is set, `*.public.blob.\n    10\t *     vercel-storage.com` fallback otherwise, everything else rejected (SSRF\n    11\t *     defense-in-depth);\n    12\t *  3. the `/`-prefix (local) branch of `resolveStoredMediaForModel`: bytes\n    13\t *     round-trip for a stored `/data/media/<file>` path, and REJECTION of any\n    14\t *     path escaping the media dir or of another shape entirely;\n    15\t *  4. the https branch of `resolveStoredMediaForModel` rejecting a\n    16\t *     non-allowlisted host (undefined, no fetch — the allowlist fails first).\n    17\t *\n    18\t * Both storage branches are pinned AT THE NEW INTERFACE so no caller ever\n    19\t * re-implements the `/` vs `https://` back-compat rule again.\n    20\t *\n    21\t * No test runner is configured in this app, so this is a standalone runnable\n    22\t * assertion (same pattern as prompt-identity.golden.ts):\n    23\t *   SKIP_ENV_VALIDATION=1 bun run src/server/providers/__tests__/media-store.golden.ts\n    24\t * (wired as `bun run test:media`). It exits non-zero on any failure.\n    25\t * SKIP_ENV_VALIDATION is required because importing media-store reads env at\n    26\t * module load; DATA_DIR is pointed at a throwaway temp dir BEFORE the dynamic\n    27\t * import below so the local-branch assertions touch only that sandbox.\n    28\t */\n    29\t\n    30\timport { mkdirSync, mkdtempSync, rmSync, writeFileSync } from \"node:fs\";\n    31\timport { tmpdir } from \"node:os\";\n    32\timport { join } from \"node:path\";\n    33\t\n    34\t// The env snapshot is taken when ~/env is first imported — set the sandbox\n    35\t// BEFORE the dynamic import of media-store (static imports would hoist).\n    36\tconst sandbox = mkdtempSync(join(tmpdir(), \"media-store-golden-\"));\n    37\tprocess.env.DATA_DIR = sandbox;\n    38\tprocess.env.BLOB_READ_WRITE_TOKEN = \"\";\n    39\t\n    40\tconst { allowedStoredMediaUrl, blobHostFromToken, resolveStoredMediaForModel } =\n    41\t  await import(\"~/server/providers/media-store\");\n    42\t\n    43\tlet failures = 0;\n    44\tfunction check(name: string, ok: boolean, detail?: string) {\n    45\t  if (ok) {\n    46\t    console.log(`✓ ${name}`);\n    47\t  } else {\n    48\t    failures += 1;\n    49\t    console.error(`✗ ${name}${detail ? `\\n  ${detail}` : \"\"}`);\n    50\t  }\n    51\t}\n    52\t\n    53\t// ── 1. Blob host derivation ──────────────────────────────────────────────────\n    54\t\n    55\t// A real rw token: `vercel_blob_rw_<storeId>_<secret>`; store ids carry mixed\n    56\t// case. The bug: the un-lowercased host never matched the parsed URL hostname.\n    57\tconst MIXED_CASE_TOKEN = \"vercel_blob_rw_StoreAbc123XYZ_s3cr3tPart\";\n    58\t\n    59\tcheck(\n    60\t  \"blobHostFromToken lowercases the derived host\",\n    61\t  blobHostFromToken(MIXED_CASE_TOKEN) ===\n    62\t    \"storeabc123xyz.public.blob.vercel-storage.com\",\n    63\t  JSON.stringify(blobHostFromToken(MIXED_CASE_TOKEN))\n    64\t);\n    65\t\n    66\t// The end-to-end guarantee: the mixed-case store's own blob URL is ACCEPTED by\n    67\t// the exact hostname compare used in the https allowlist.\n    68\t{\n    69\t  const storeHost = blobHostFromToken(MIXED_CASE_TOKEN);\n    70\t  const url = new URL(\n    71\t    \"https://StoreAbc123XYZ.public.blob.vercel-storage.com/img/beat0.png\"\n    72\t  );\n    73\t  check(\n    74\t    \"mixed-case store id → its own blob URL passes the allowlist compare\",\n    75\t    url.hostname === storeHost,\n    76\t    `hostname=${url.hostname} storeHost=${storeHost}`\n    77\t  );\n    78\t}\n    79\t\n    80\tcheck(\n    81\t  \"a malformed token (no store-id segment) → null\",\n    82\t  blobHostFromToken(\"vercel_blob_rw\") === null\n    83\t);\n    84\t\n    85\t// ── 2. https allowlist decision (pure) ───────────────────────────────────────\n    86\t\n    87\tconst OWN_HOST = blobHostFromToken(MIXED_CASE_TOKEN);\n    88\t\n    89\tcheck(\n    90\t  \"storeHost set: the app's OWN blob URL is allowed\",\n    91\t  allowedStoredMediaUrl(\n    92\t    \"https://storeabc123xyz.public.blob.vercel-storage.com/media/a.png\",\n    93\t    OWN_HOST\n    94\t  )?.hostname === OWN_HOST\n    95\t);\n    96\tcheck(\n    97\t  \"storeHost set: ANOTHER public-blob store is rejected (exact host, not suffix)\",\n    98\t  allowedStoredMediaUrl(\n    99\t    \"https://otherstore.public.blob.vercel-storage.com/media/a.png\",\n   100\t    OWN_HOST\n   101\t  ) === null\n   102\t);\n   103\tcheck(\n   104\t  \"storeHost set: an arbitrary https host is rejected\",\n   105\t  allowedStoredMediaUrl(\"https://evil.example.com/media/a.png\", OWN_HOST) ===\n   106\t    null\n   107\t);\n   108\tcheck(\n   109\t  \"no storeHost (local dev): the public-blob suffix is the fallback allowlist\",\n   110\t  allowedStoredMediaUrl(\n   111\t    \"https://somestore.public.blob.vercel-storage.com/media/a.png\",\n   112\t    null\n   113\t  )?.hostname === \"somestore.public.blob.vercel-storage.com\"\n   114\t);\n   115\tcheck(\n   116\t  \"no storeHost: a non-blob https host is rejected\",\n   117\t  allowedStoredMediaUrl(\"https://evil.example.com/media/a.png\", null) === null\n   118\t);\n   119\tcheck(\n   120\t  \"a suffix-LOOKALIKE host is rejected (endsWith needs the dot-prefixed suffix)\",\n   121\t  allowedStoredMediaUrl(\n   122\t    \"https://evilpublic.blob.vercel-storage.com.evil.example.com/a.png\",\n   123\t    null\n   124\t  ) === null\n   125\t);\n   126\tcheck(\n   127\t  \"a non-https value is never a blob URL\",\n   128\t  allowedStoredMediaUrl(\"/data/media/a.png\", OWN_HOST) === null &&\n   129\t    allowedStoredMediaUrl(\"http://insecure.example.com/a.png\", null) === null\n   130\t);\n   131\tcheck(\n   132\t  \"a malformed https value is rejected, not thrown\",\n   133\t  allowedStoredMediaUrl(\"https://\", null) === null\n   134\t);\n   135\t\n   136\t// ── 3. resolveStoredMediaForModel — local branch ─────────────────────────────\n   137\t\n   138\tconst mediaDir = join(sandbox, \"media\");\n   139\tmkdirSync(mediaDir, { recursive: true });\n   140\tconst AUDIO_BYTES = new Uint8Array([0x49, 0x44, 0x33, 0x04, 0x00]);\n   141\twriteFileSync(join(mediaDir, \"beat0.mp3\"), AUDIO_BYTES);\n   142\t// A file OUTSIDE the media dir that a traversal would otherwise reach.\n   143\twriteFileSync(join(sandbox, \"secret.txt\"), \"hors du dossier media\");\n   144\t\n   145\t{\n   146\t  const bytes = await resolveStoredMediaForModel(\"/data/media/beat0.mp3\");\n   147\t  check(\n   148\t    \"local branch: a stored /data/media/<file> path reads back its exact bytes\",\n   149\t    bytes !== undefined &&\n   150\t      bytes.length === AUDIO_BYTES.length &&\n   151\t      AUDIO_BYTES.every((b, i) => bytes[i] === b),\n   152\t    JSON.stringify(bytes)\n   153\t  );\n   154\t}\n   155\tcheck(\n   156\t  \"local branch: a traversal escaping the media dir is REJECTED (undefined)\",\n   157\t  (await resolveStoredMediaForModel(\"/data/media/../secret.txt\")) === undefined\n   158\t);\n   159\tcheck(\n   160\t  \"local branch: a path of another shape is REJECTED (undefined)\",\n   161\t  (await resolveStoredMediaForModel(\"/etc/passwd\")) === undefined &&\n   162\t    (await resolveStoredMediaForModel(\"/data/other/beat0.mp3\")) === undefined\n   163\t);\n   164\t\n   165\t// ── 4. resolveStoredMediaForModel — https branch, allowlist rejection ────────\n   166\t\n   167\tcheck(\n   168\t  \"https branch: a non-allowlisted host resolves to undefined (never fetched)\",\n   169\t  (await resolveStoredMediaForModel(\"https://evil.example.com/media/a.png\")) ===\n   170\t    undefined\n   171\t);\n   172\t\n   173\trmSync(sandbox, { force: true, recursive: true });\n   174\t\n   175\tif (failures > 0) {\n   176\t  console.error(`\\nMEDIA-STORE FAILED: ${failures} mismatch(es).`);\n   177\t  process.exit(1);\n   178\t}\n   179\tconsole.log(\n   180\t  \"\\nMEDIA-STORE OK: read-back choke-point pins both storage branches (allowlist + media-dir escape).\"\n   181\t);\ndiff --git a/src/server/providers/__tests__/media-store.golden.ts b/src/server/providers/__tests__/media-store.golden.ts\nindex 843b3af..6cece02 100644\n--- a/src/server/providers/__tests__/media-store.golden.ts\n+++ b/src/server/providers/__tests__/media-store.golden.ts\n@@ -1,64 +1,181 @@\n /**\n- * MEDIA-STORE assertion script — blob host allowlist derivation.\n+ * MEDIA-STORE assertion script — the single media choke-point's READ-BACK.\n  *\n- * Pins the reference-image allowlist fix: the derived blob host MUST be\n- * lowercased, because `new URL(path).hostname` is lowercased by the URL parser.\n- * A mixed-case store id previously produced a host that never equalled the\n- * parsed hostname, so the app silently rejected its OWN blob URLs and disabled\n- * every reference image in blob/prod mode (characters drifted page to page).\n+ * Pins:\n+ *  1. blob host allowlist derivation (`blobHostFromToken` must lowercase — a\n+ *     mixed-case store id once made the app silently reject its OWN blob URLs\n+ *     and disable every reference image in blob/prod mode);\n+ *  2. the https-branch allowlist decision (`allowedStoredMediaUrl`, pure):\n+ *     exact own-store host when the rw token is set, `*.public.blob.\n+ *     vercel-storage.com` fallback otherwise, everything else rejected (SSRF\n+ *     defense-in-depth);\n+ *  3. the `/`-prefix (local) branch of `resolveStoredMediaForModel`: bytes\n+ *     round-trip for a stored `/data/media/<file>` path, and REJECTION of any\n+ *     path escaping the media dir or of another shape entirely;\n+ *  4. the https branch of `resolveStoredMediaForModel` rejecting a\n+ *     non-allowlisted host (undefined, no fetch — the allowlist fails first).\n+ *\n+ * Both storage branches are pinned AT THE NEW INTERFACE so no caller ever\n+ * re-implements the `/` vs `https://` back-compat rule again.\n  *\n  * No test runner is configured in this app, so this is a standalone runnable\n  * assertion (same pattern as prompt-identity.golden.ts):\n  *   SKIP_ENV_VALIDATION=1 bun run src/server/providers/__tests__/media-store.golden.ts\n  * (wired as `bun run test:media`). It exits non-zero on any failure.\n- * SKIP_ENV_VALIDATION is required only because importing media-store reads\n- * DATA_DIR at module load; the assertions themselves are pure.\n+ * SKIP_ENV_VALIDATION is required because importing media-store reads env at\n+ * module load; DATA_DIR is pointed at a throwaway temp dir BEFORE the dynamic\n+ * import below so the local-branch assertions touch only that sandbox.\n  */\n \n-import { blobHostFromToken } from \"~/server/providers/media-store\";\n+import { mkdirSync, mkdtempSync, rmSync, writeFileSync } from \"node:fs\";\n+import { tmpdir } from \"node:os\";\n+import { join } from \"node:path\";\n+\n+// The env snapshot is taken when ~/env is first imported — set the sandbox\n+// BEFORE the dynamic import of media-store (static imports would hoist).\n+const sandbox = mkdtempSync(join(tmpdir(), \"media-store-golden-\"));\n+process.env.DATA_DIR = sandbox;\n+process.env.BLOB_READ_WRITE_TOKEN = \"\";\n+\n+const { allowedStoredMediaUrl, blobHostFromToken, resolveStoredMediaForModel } =\n+  await import(\"~/server/providers/media-store\");\n \n let failures = 0;\n function check(name: string, ok: boolean, detail?: string) {\n   if (ok) {\n     console.log(`✓ ${name}`);\n   } else {\n     failures += 1;\n     console.error(`✗ ${name}${detail ? `\\n  ${detail}` : \"\"}`);\n   }\n }\n \n+// ── 1. Blob host derivation ──────────────────────────────────────────────────\n+\n // A real rw token: `vercel_blob_rw_<storeId>_<secret>`; store ids carry mixed\n // case. The bug: the un-lowercased host never matched the parsed URL hostname.\n const MIXED_CASE_TOKEN = \"vercel_blob_rw_StoreAbc123XYZ_s3cr3tPart\";\n \n check(\n   \"blobHostFromToken lowercases the derived host\",\n   blobHostFromToken(MIXED_CASE_TOKEN) ===\n     \"storeabc123xyz.public.blob.vercel-storage.com\",\n   JSON.stringify(blobHostFromToken(MIXED_CASE_TOKEN))\n );\n \n // The end-to-end guarantee: the mixed-case store's own blob URL is ACCEPTED by\n-// the exact `url.hostname === storeHost` compare used in resolveReferenceImage.\n+// the exact hostname compare used in the https allowlist.\n {\n   const storeHost = blobHostFromToken(MIXED_CASE_TOKEN);\n   const url = new URL(\n     \"https://StoreAbc123XYZ.public.blob.vercel-storage.com/img/beat0.png\"\n   );\n   check(\n     \"mixed-case store id → its own blob URL passes the allowlist compare\",\n     url.hostname === storeHost,\n     `hostname=${url.hostname} storeHost=${storeHost}`\n   );\n }\n \n check(\n   \"a malformed token (no store-id segment) → null\",\n   blobHostFromToken(\"vercel_blob_rw\") === null\n );\n \n+// ── 2. https allowlist decision (pure) ───────────────────────────────────────\n+\n+const OWN_HOST = blobHostFromToken(MIXED_CASE_TOKEN);\n+\n+check(\n+  \"storeHost set: the app's OWN blob URL is allowed\",\n+  allowedStoredMediaUrl(\n+    \"https://storeabc123xyz.public.blob.vercel-storage.com/media/a.png\",\n+    OWN_HOST\n+  )?.hostname === OWN_HOST\n+);\n+check(\n+  \"storeHost set: ANOTHER public-blob store is rejected (exact host, not suffix)\",\n+  allowedStoredMediaUrl(\n+    \"https://otherstore.public.blob.vercel-storage.com/media/a.png\",\n+    OWN_HOST\n+  ) === null\n+);\n+check(\n+  \"storeHost set: an arbitrary https host is rejected\",\n+  allowedStoredMediaUrl(\"https://evil.example.com/media/a.png\", OWN_HOST) ===\n+    null\n+);\n+check(\n+  \"no storeHost (local dev): the public-blob suffix is the fallback allowlist\",\n+  allowedStoredMediaUrl(\n+    \"https://somestore.public.blob.vercel-storage.com/media/a.png\",\n+    null\n+  )?.hostname === \"somestore.public.blob.vercel-storage.com\"\n+);\n+check(\n+  \"no storeHost: a non-blob https host is rejected\",\n+  allowedStoredMediaUrl(\"https://evil.example.com/media/a.png\", null) === null\n+);\n+check(\n+  \"a suffix-LOOKALIKE host is rejected (endsWith needs the dot-prefixed suffix)\",\n+  allowedStoredMediaUrl(\n+    \"https://evilpublic.blob.vercel-storage.com.evil.example.com/a.png\",\n+    null\n+  ) === null\n+);\n+check(\n+  \"a non-https value is never a blob URL\",\n+  allowedStoredMediaUrl(\"/data/media/a.png\", OWN_HOST) === null &&\n+    allowedStoredMediaUrl(\"http://insecure.example.com/a.png\", null) === null\n+);\n+check(\n+  \"a malformed https value is rejected, not thrown\",\n+  allowedStoredMediaUrl(\"https://\", null) === null\n+);\n+\n+// ── 3. resolveStoredMediaForModel — local branch ─────────────────────────────\n+\n+const mediaDir = join(sandbox, \"media\");\n+mkdirSync(mediaDir, { recursive: true });\n+const AUDIO_BYTES = new Uint8Array([0x49, 0x44, 0x33, 0x04, 0x00]);\n+writeFileSync(join(mediaDir, \"beat0.mp3\"), AUDIO_BYTES);\n+// A file OUTSIDE the media dir that a traversal would otherwise reach.\n+writeFileSync(join(sandbox, \"secret.txt\"), \"hors du dossier media\");\n+\n+{\n+  const bytes = await resolveStoredMediaForModel(\"/data/media/beat0.mp3\");\n+  check(\n+    \"local branch: a stored /data/media/<file> path reads back its exact bytes\",\n+    bytes !== undefined &&\n+      bytes.length === AUDIO_BYTES.length &&\n+      AUDIO_BYTES.every((b, i) => bytes[i] === b),\n+    JSON.stringify(bytes)\n+  );\n+}\n+check(\n+  \"local branch: a traversal escaping the media dir is REJECTED (undefined)\",\n+  (await resolveStoredMediaForModel(\"/data/media/../secret.txt\")) === undefined\n+);\n+check(\n+  \"local branch: a path of another shape is REJECTED (undefined)\",\n+  (await resolveStoredMediaForModel(\"/etc/passwd\")) === undefined &&\n+    (await resolveStoredMediaForModel(\"/data/other/beat0.mp3\")) === undefined\n+);\n+\n+// ── 4. resolveStoredMediaForModel — https branch, allowlist rejection ────────\n+\n+check(\n+  \"https branch: a non-allowlisted host resolves to undefined (never fetched)\",\n+  (await resolveStoredMediaForModel(\"https://evil.example.com/media/a.png\")) ===\n+    undefined\n+);\n+\n+rmSync(sandbox, { force: true, recursive: true });\n+\n if (failures > 0) {\n   console.error(`\\nMEDIA-STORE FAILED: ${failures} mismatch(es).`);\n   process.exit(1);\n }\n-console.log(\"\\nMEDIA-STORE OK: blob host allowlist derivation is case-safe.\");\n+console.log(\n+  \"\\nMEDIA-STORE OK: read-back choke-point pins both storage branches (allowlist + media-dir escape).\"\n+);\n","exit_code":0,"status":"completed"}}
