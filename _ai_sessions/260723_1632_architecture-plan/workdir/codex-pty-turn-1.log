89\t        return __awaiter(this, void 0, void 0, function* () {\n    90\t            for (let i = 1; i <= 3 && this._ws.readyState !== this._ws.OPEN; i++) {\n    91\t                if (i == 1) {\n    92\t                    this._startTime = Date.now();\n    93\t                }\n    94\t                this._log(\"connecting: \", i);\n    95\t                yield this._initClient();\n    96\t            }\n    97\t            this._ws.send(message, () => {\n    98\t                this._log(\"<- sent message: \", message);\n    99\t            });\n   100\t        });\n   101\t    }\n   102\t    _initClient() {\n   103\t        this._ws = this._isBrowser\n   104\t            ? new isomorphic_ws_1.default(MsEdgeTTS.SYNTH_URL)\n   105\t            : new isomorphic_ws_1.default(MsEdgeTTS.SYNTH_URL, { agent: this._agent });\n   106\t        this._ws.binaryType = \"arraybuffer\";\n   107\t        return new Promise((resolve, reject) => {\n   108\t            this._ws.onopen = () => {\n   109\t                this._log(\"Connected in\", (Date.now() - this._startTime) / 1000, \"seconds\");\n   110\t                this._send(`Content-Type:application/json; charset=utf-8\\r\\nPath:speech.config\\r\\n\\r\\n\n   111\t                    {\n   112\t                        \"context\": {\n   113\t                            \"synthesis\": {\n   114\t                                \"audio\": {\n   115\t                                    \"metadataoptions\": {\n   116\t                                        \"sentenceBoundaryEnabled\": \"false\",\n   117\t                                        \"wordBoundaryEnabled\": \"false\"\n   118\t                                    },\n   119\t                                    \"outputFormat\": \"${this._outputFormat}\" \n   120\t                                }\n   121\t                            }\n   122\t                        }\n   123\t                    }\n   124\t                `).then(resolve);\n   125\t            };\n   126\t            this._ws.onmessage = (m) => {\n   127\t                const buffer = buffer_1.Buffer.from(m.data);\n   128\t                const message = buffer.toString();\n   129\t                const requestId = /X-RequestId:(.*?)\\r\\n/gm.exec(message)[1];\n   130\t                if (message.includes(\"Path:turn.start\")) {\n   131\t                    // start of turn, ignore\n   132\t                }\n   133\t                else if (message.includes(\"Path:turn.end\")) {\n   134\t                    // end of turn, close stream\n   135\t                    this._queue[requestId].push(null);\n   136\t                }\n   137\t                else if (message.includes(\"Path:response\")) {\n   138\t                    // context response, ignore\n   139\t                }\n   140\t                else if (message.includes(\"Path:audio\")) {\n   141\t                    if (m.data instanceof ArrayBuffer) {\n   142\t                        this.cacheAudioData(buffer, requestId);\n   143\t                    }\n   144\t                    else {\n   145\t                        this._log(\"UNKNOWN MESSAGE\", message);\n   146\t                    }\n   147\t                }\n   148\t                else {\n   149\t                    this._log(\"UNKNOWN MESSAGE\", message);\n   150\t                }\n   151\t            };\n   152\t            this._ws.onclose = () => {\n   153\t                this._log(\"disconnected after:\", (Date.now() - this._startTime) / 1000, \"seconds\");\n   154\t                for (const requestId in this._queue) {\n   155\t                    this._queue[requestId].push(null);\n   156\t                }\n   157\t            };\n   158\t            this._ws.onerror = function (error) {\n   159\t                reject(\"Connect Error: \" + error);\n   160\t            };\n   161\t        });\n   162\t    }\n   163\t    cacheAudioData(m, requestId) {\n   164\t        const index = m.indexOf(MsEdgeTTS.BINARY_DELIM) + MsEdgeTTS.BINARY_DELIM.length;\n   165\t        const audioData = m.slice(index, m.length);\n   166\t        this._queue[requestId].push(audioData);\n   167\t        this._log(\"receive audio chunk size: \", audioData === null || audioData === void 0 ? void 0 : audioData.length);\n   168\t    }\n   169\t    _SSMLTemplate(input, options = new ProsodyOptions()) {\n   170\t        // in case future updates to the edge API block these elements, we'll be concatenating strings.\n   171\t        return `<speak version=\"1.0\" xmlns=\"http://www.w3.org/2001/10/synthesis\" xmlns:mstts=\"https://www.w3.org/2001/mstts\" xml:lang=\"${this._voiceLocale}\">\n   172\t                <voice name=\"${this._voice}\">\n   173\t                    <prosody pitch=\"${options.pitch}\" rate=\"${options.rate}\" volume=\"${options.volume}\">\n   174\t                        ${input}\n   175\t                    </prosody> \n   176\t                </voice>\n   177\t            </speak>`;\n   178\t    }\n   179\t    /**\n   180\t     * Fetch the list of voices available in Microsoft Edge.\n","exit_code":0,"status":"completed"}}
