{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"/usr/bin/zsh -lc \"nl -ba src/server/providers/image/segment-prompt.ts | sed -n '1,220p'; git show main:src/server/dynamic-functions.ts | nl -ba | sed -n '720,805p'; nl -ba src/server/providers/image/segment-prompt.ts; nl -ba src/server/providers/image/__tests__/segment-image-prompt.golden.ts | sed -n '1,260p'; nl -ba src/server/story-context.ts | sed -n '1,240p'\"","aggregated_output":"     1\timport { imageStyleSuffix } from \"~/config/style\";\n     2\timport { doudouImageLine } from \"~/server/providers/text/doudou-prompt\";\n     3\timport {\n     4\t  heroesImageLine,\n     5\t  outfitImageLine,\n     6\t} from \"~/server/providers/text/hero-prompt\";\n     7\timport type { DoudouContext, HeroContext } from \"~/server/providers/types\";\n     8\t\n     9\t/**\n    10\t * The SEGMENT-IMAGE prompt builder — the image side's `buildPrompt`: every\n    11\t * piece of \"what an illustration prompt contains\" (scene · ambiance · outfit ·\n    12\t * heroes · doudou · style) lives HERE, in one pure golden-testable module\n    13\t * (test:golden pins its byte-identity), instead of being hand-assembled inline\n    14\t * in dynamic-functions. The caller keeps only DB read / persist / sentinel.\n    15\t */\n    16\t\n    17\t/** The story-level fields the prompt reads (a `stories` row satisfies this). */\n    18\texport interface SegmentImagePromptStory {\n    19\t  // Story-level frozen illustration ambiance (time of day, season, weather,\n    20\t  // light), generated with the arc. Null on older stories → line omitted.\n    21\t  visualWorld: string | null;\n    22\t}\n    23\t\n    24\t/** The beat-level fields the prompt reads (a `story_segments` row satisfies\n    25\t * this). */\n    26\texport interface SegmentImagePromptSegment {\n    27\t  paragraphs: string[];\n    28\t  // The beat's OWN scene (emitted by the text model). Null on older segments\n    29\t  // → the frozen place hint is the fallback.\n    30\t  sceneHint: string | null;\n    31\t}\n    32\t\n    33\t/** The frozen story context the prompt reads — `FrozenStoryContext` satisfies\n    34\t * this (structural subset: `elements` never drive the illustration). */\n    35\texport interface SegmentImagePromptContext {\n    36\t  doudous: DoudouContext[];\n    37\t  heroes: HeroContext[];\n    38\t  outfit: string | null;\n    39\t  place: { label: string; promptHint: string };\n    40\t}\n    41\t\n    42\t/**\n    43\t * Assemble the illustration prompt for ONE segment. Pure string logic — no\n    44\t * env, no DB, no provider call. `hasReferenceImage` switches the opening\n    45\t * clause: with a reference, the model is told to reuse the characters/style\n    46\t * but NEVER the decor; without one (beat 0), it gets the plain tender-story\n    47\t * framing.\n    48\t */\n    49\texport function buildSegmentImagePrompt(\n    50\t  story: SegmentImagePromptStory,\n    51\t  segment: SegmentImagePromptSegment,\n    52\t  hasReferenceImage: boolean,\n    53\t  frozen: SegmentImagePromptContext\n    54\t): string {\n    55\t  const { heroes, place, doudous, outfit } = frozen;\n    56\t\n    57\t  // The beat's OWN scene (emitted by the text model) wins over the story's\n    58\t  // frozen starting place: once the story walks through the magic door, the\n    59\t  // illustration must follow it — not stamp \"aux États-Unis\" on every page.\n    60\t  let sceneLine = \"\";\n    61\t  if (segment.sceneHint) {\n    62\t    sceneLine = `La scène : ${segment.sceneHint}`;\n    63\t  } else if (place.promptHint) {\n    64\t    sceneLine = `La scène se passe ${place.promptHint}.`;\n    65\t  }\n    66\t\n    67\t  // Story-level visual world (time of day, season, weather, light), frozen at\n    68\t  // creation. A DEFAULT ambiance, not an absolute order: the beat's own scene\n    69\t  // keeps priority (a story that walks through a magic door into space must be\n    70\t  // allowed to change its sky). Null on older stories → line omitted.\n    71\t  const ambianceLine = story.visualWorld\n    72\t    ? `Ambiance générale de l'histoire (sauf indication contraire de la scène) : ${story.visualWorld}.`\n    73\t    : \"\";\n    74\t\n    75\t  // Story-level frozen outfit (the heroes' wardrobe), a DEFAULT the reference\n    76\t  // image overrides. Mainly anchors beat 0 (no reference yet) and non-default\n    77\t  // heroes (no clothing in their imageHint). \"\" on older stories / safety drop\n    78\t  // → line omitted, image built exactly as before.\n    79\t  const outfitLine = outfitImageLine(outfit);\n    80\t\n    81\t  // Feed the WHOLE beat's text (now 1–3 short sentences) so the page's image\n    82\t  // reflects that full page, not just its first ~8-word sentence.\n    83\t  return [\n    84\t    // The reference anchors CHARACTER IDENTITY + STYLE only — never the decor.\n    85\t    // The earlier \"dans une NOUVELLE scène\" wording let the model clone page\n    86\t    // 1's backdrop on every page, so the illustrations never moved even when\n    87\t    // the story did.\n    88\t    hasReferenceImage\n    89\t      ? \"Reprends EXACTEMENT les personnages de l'image fournie (visages, coiffures, vêtements, proportions) et son style — mais PAS son décor ni son cadrage. Dessine le lieu où l'histoire se trouve MAINTENANT (voir « La scène » ci-dessous), même s'il ne ressemble plus à celui de l'image fournie :\"\n    90\t      : \"Illustration pour un bout d'une histoire d'enfant, tendre et rassurante.\",\n    91\t    segment.paragraphs.join(\" \"),\n    92\t    sceneLine,\n    93\t    ambianceLine,\n    94\t    outfitLine,\n    95\t    // Single hero → identical to the old `hero.imageHint`; multi → grouped.\n    96\t    heroesImageLine(heroes),\n    97\t    // Only the FIRST doudou appears in illustrations — 6 peluches per page\n    98\t    // crowded every composition; the text still mentions them all.\n    99\t    doudouImageLine(doudous.slice(0, 1)),\n   100\t    imageStyleSuffix,\n   101\t  ]\n   102\t    .filter(Boolean)\n   103\t    .join(\" \");\n   104\t}\n   720\t  if (segment.imagePath === IMAGE_FAILED_SENTINEL && !force) {\n   721\t    // Idempotent no-op: the terminal failure sentinel → \"failed\" (a prior\n   722\t    // attempt already failed — do NOT re-bill Gemini, do NOT re-hang the child;\n   723\t    // the calm \"no drawing\" state is final for this beat unless explicitly\n   724\t    // retried via `retrySegmentImageFn`).\n   725\t    return resolveStoredImagePath(segment.imagePath);\n   726\t  }\n   727\t\n   728\t  const [story] = await db\n   729\t    .select()\n   730\t    .from(stories)\n   731\t    .where(eq(stories.id, storyId));\n   732\t  if (!story) {\n   733\t    return { imagePath: null, imageStatus: \"skipped\" };\n   734\t  }\n   735\t  // History path: frozen snapshot, never the live editable rows.\n   736\t  const { heroes, place, doudous, outfit } = getFrozenStoryPromptContext(story);\n   737\t\n   738\t  // A prior illustration of THIS story, sent as an image input so characters/\n   739\t  // style stay consistent across beats (best-effort — null on beat 0 / no\n   740\t  // prior image / fetch failure → plain text-to-image, as before).\n   741\t  const referenceImage = await resolveReferenceImage(storyId, idx);\n   742\t\n   743\t  // The beat's OWN scene (emitted by the text model) wins over the story's\n   744\t  // frozen starting place: once the story walks through the magic door, the\n   745\t  // illustration must follow it — not stamp \"aux États-Unis\" on every page.\n   746\t  let sceneLine = \"\";\n   747\t  if (segment.sceneHint) {\n   748\t    sceneLine = `La scène : ${segment.sceneHint}`;\n   749\t  } else if (place.promptHint) {\n   750\t    sceneLine = `La scène se passe ${place.promptHint}.`;\n   751\t  }\n   752\t\n   753\t  // Story-level visual world (time of day, season, weather, light), frozen at\n   754\t  // creation. A DEFAULT ambiance, not an absolute order: the beat's own scene\n   755\t  // keeps priority (a story that walks through a magic door into space must be\n   756\t  // allowed to change its sky). Null on older stories → line omitted.\n   757\t  const ambianceLine = story.visualWorld\n   758\t    ? `Ambiance générale de l'histoire (sauf indication contraire de la scène) : ${story.visualWorld}.`\n   759\t    : \"\";\n   760\t\n   761\t  // Story-level frozen outfit (the heroes' wardrobe), a DEFAULT the reference\n   762\t  // image overrides. Mainly anchors beat 0 (no reference yet) and non-default\n   763\t  // heroes (no clothing in their imageHint). \"\" on older stories / safety drop\n   764\t  // → line omitted, image built exactly as before.\n   765\t  const outfitLine = outfitImageLine(outfit);\n   766\t\n   767\t  // Feed the WHOLE beat's text (now 1–3 short sentences) so the page's image\n   768\t  // reflects that full page, not just its first ~8-word sentence.\n   769\t  const prompt = [\n   770\t    // The reference anchors CHARACTER IDENTITY + STYLE only — never the decor.\n   771\t    // The earlier \"dans une NOUVELLE scène\" wording let the model clone page\n   772\t    // 1's backdrop on every page, so the illustrations never moved even when\n   773\t    // the story did.\n   774\t    referenceImage\n   775\t      ? \"Reprends EXACTEMENT les personnages de l'image fournie (visages, coiffures, vêtements, proportions) et son style — mais PAS son décor ni son cadrage. Dessine le lieu où l'histoire se trouve MAINTENANT (voir « La scène » ci-dessous), même s'il ne ressemble plus à celui de l'image fournie :\"\n   776\t      : \"Illustration pour un bout d'une histoire d'enfant, tendre et rassurante.\",\n   777\t    segment.paragraphs.join(\" \"),\n   778\t    sceneLine,\n   779\t    ambianceLine,\n   780\t    outfitLine,\n   781\t    // Single hero → identical to the old `hero.imageHint`; multi → grouped.\n   782\t    heroesImageLine(heroes),\n   783\t    // Only the FIRST doudou appears in illustrations — 6 peluches per page\n   784\t    // crowded every composition; the text still mentions them all.\n   785\t    doudouImageLine(doudous.slice(0, 1)),\n   786\t    imageStyleSuffix,\n   787\t  ]\n   788\t    .filter(Boolean)\n   789\t    .join(\" \");\n   790\t\n   791\t  try {\n   792\t    const imagePath = await nanoBananaImageProvider.generateImage(\n   793\t      prompt,\n   794\t      model,\n   795\t      referenceImage\n   796\t    );\n   797\t    await db\n   798\t      .update(storySegments)\n   799\t      .set({ imagePath })\n   800\t      .where(eq(storySegments.id, segment.id));\n   801\t    console.log(\"[stories] image gen DONE\", {\n   802\t      idx,\n   803\t      imagePath,\n   804\t      ms: Date.now() - startedAt,\n   805\t      storyId,\n     1\timport { imageStyleSuffix } from \"~/config/style\";\n     2\timport { doudouImageLine } from \"~/server/providers/text/doudou-prompt\";\n     3\timport {\n     4\t  heroesImageLine,\n     5\t  outfitImageLine,\n     6\t} from \"~/server/providers/text/hero-prompt\";\n     7\timport type { DoudouContext, HeroContext } from \"~/server/providers/types\";\n     8\t\n     9\t/**\n    10\t * The SEGMENT-IMAGE prompt builder — the image side's `buildPrompt`: every\n    11\t * piece of \"what an illustration prompt contains\" (scene · ambiance · outfit ·\n    12\t * heroes · doudou · style) lives HERE, in one pure golden-testable module\n    13\t * (test:golden pins its byte-identity), instead of being hand-assembled inline\n    14\t * in dynamic-functions. The caller keeps only DB read / persist / sentinel.\n    15\t */\n    16\t\n    17\t/** The story-level fields the prompt reads (a `stories` row satisfies this). */\n    18\texport interface SegmentImagePromptStory {\n    19\t  // Story-level frozen illustration ambiance (time of day, season, weather,\n    20\t  // light), generated with the arc. Null on older stories → line omitted.\n    21\t  visualWorld: string | null;\n    22\t}\n    23\t\n    24\t/** The beat-level fields the prompt reads (a `story_segments` row satisfies\n    25\t * this). */\n    26\texport interface SegmentImagePromptSegment {\n    27\t  paragraphs: string[];\n    28\t  // The beat's OWN scene (emitted by the text model). Null on older segments\n    29\t  // → the frozen place hint is the fallback.\n    30\t  sceneHint: string | null;\n    31\t}\n    32\t\n    33\t/** The frozen story context the prompt reads — `FrozenStoryContext` satisfies\n    34\t * this (structural subset: `elements` never drive the illustration). */\n    35\texport interface SegmentImagePromptContext {\n    36\t  doudous: DoudouContext[];\n    37\t  heroes: HeroContext[];\n    38\t  outfit: string | null;\n    39\t  place: { label: string; promptHint: string };\n    40\t}\n    41\t\n    42\t/**\n    43\t * Assemble the illustration prompt for ONE segment. Pure string logic — no\n    44\t * env, no DB, no provider call. `hasReferenceImage` switches the opening\n    45\t * clause: with a reference, the model is told to reuse the characters/style\n    46\t * but NEVER the decor; without one (beat 0), it gets the plain tender-story\n    47\t * framing.\n    48\t */\n    49\texport function buildSegmentImagePrompt(\n    50\t  story: SegmentImagePromptStory,\n    51\t  segment: SegmentImagePromptSegment,\n    52\t  hasReferenceImage: boolean,\n    53\t  frozen: SegmentImagePromptContext\n    54\t): string {\n    55\t  const { heroes, place, doudous, outfit } = frozen;\n    56\t\n    57\t  // The beat's OWN scene (emitted by the text model) wins over the story's\n    58\t  // frozen starting place: once the story walks through the magic door, the\n    59\t  // illustration must follow it — not stamp \"aux États-Unis\" on every page.\n    60\t  let sceneLine = \"\";\n    61\t  if (segment.sceneHint) {\n    62\t    sceneLine = `La scène : ${segment.sceneHint}`;\n    63\t  } else if (place.promptHint) {\n    64\t    sceneLine = `La scène se passe ${place.promptHint}.`;\n    65\t  }\n    66\t\n    67\t  // Story-level visual world (time of day, season, weather, light), frozen at\n    68\t  // creation. A DEFAULT ambiance, not an absolute order: the beat's own scene\n    69\t  // keeps priority (a story that walks through a magic door into space must be\n    70\t  // allowed to change its sky). Null on older stories → line omitted.\n    71\t  const ambianceLine = story.visualWorld\n    72\t    ? `Ambiance générale de l'histoire (sauf indication contraire de la scène) : ${story.visualWorld}.`\n    73\t    : \"\";\n    74\t\n    75\t  // Story-level frozen outfit (the heroes' wardrobe), a DEFAULT the reference\n    76\t  // image overrides. Mainly anchors beat 0 (no reference yet) and non-default\n    77\t  // heroes (no clothing in their imageHint). \"\" on older stories / safety drop\n    78\t  // → line omitted, image built exactly as before.\n    79\t  const outfitLine = outfitImageLine(outfit);\n    80\t\n    81\t  // Feed the WHOLE beat's text (now 1–3 short sentences) so the page's image\n    82\t  // reflects that full page, not just its first ~8-word sentence.\n    83\t  return [\n    84\t    // The reference anchors CHARACTER IDENTITY + STYLE only — never the decor.\n    85\t    // The earlier \"dans une NOUVELLE scène\" wording let the model clone page\n    86\t    // 1's backdrop on every page, so the illustrations never moved even when\n    87\t    // the story did.\n    88\t    hasReferenceImage\n    89\t      ? \"Reprends EXACTEMENT les personnages de l'image fournie (visages, coiffures, vêtements, proportions) et son style — mais PAS son décor ni son cadrage. Dessine le lieu où l'histoire se trouve MAINTENANT (voir « La scène » ci-dessous), même s'il ne ressemble plus à celui de l'image fournie :\"\n    90\t      : \"Illustration pour un bout d'une histoire d'enfant, tendre et rassurante.\",\n    91\t    segment.paragraphs.join(\" \"),\n    92\t    sceneLine,\n    93\t    ambianceLine,\n    94\t    outfitLine,\n    95\t    // Single hero → identical to the old `hero.imageHint`; multi → grouped.\n    96\t    heroesImageLine(heroes),\n    97\t    // Only the FIRST doudou appears in illustrations — 6 peluches per page\n    98\t    // crowded every composition; the text still mentions them all.\n    99\t    doudouImageLine(doudous.slice(0, 1)),\n   100\t    imageStyleSuffix,\n   101\t  ]\n   102\t    .filter(Boolean)\n   103\t    .join(\" \");\n   104\t}\n     1\t/**\n     2\t * GOLDEN segment-image prompt-identity assertion (plan candidate 3).\n     3\t *\n     4\t * `buildSegmentImagePrompt` extracts the illustration prompt that\n     5\t * `dynamic-functions.ts` used to assemble inline (scene · ambiance · outfit ·\n     6\t * heroes · doudou · style). The refactor's contract: for the same inputs the\n     7\t * assembled prompt is BYTE-IDENTICAL to the pre-refactor inline code. The\n     8\t * EXPECTED strings below were captured by running the VERBATIM pre-refactor\n     9\t * assembly over these exact fixtures (see the lane report in _ai_sessions/) —\n    10\t * they are the frozen \"before\" bytes, not a re-derivation.\n    11\t *\n    12\t * The fixture set covers the documented priority rules:\n    13\t *  - sceneHint PRIORITY over the frozen place hint;\n    14\t *  - place-hint fallback when the beat has no sceneHint;\n    15\t *  - visual_world as the DEFAULT ambiance (present/absent);\n    16\t *  - reference vs no-reference opening clause;\n    17\t *  - frozen outfit line (present/absent);\n    18\t *  - multi-hero grouping + doudou sliced to the FIRST one;\n    19\t *  - scene line omitted entirely when neither sceneHint nor place hint exist.\n    20\t *\n    21\t * No test runner is configured in this app, so this is a standalone runnable\n    22\t * assertion (same pattern as prompt-identity.golden.ts, chained into\n    23\t * `bun run test:golden`). It exits non-zero on any mismatch. Pure — no env,\n    24\t * no DB, no network.\n    25\t */\n    26\t\n    27\timport { buildSegmentImagePrompt } from \"~/server/providers/image/segment-prompt\";\n    28\timport type { DoudouContext, HeroContext } from \"~/server/providers/types\";\n    29\t\n    30\tconst HERO: HeroContext = {\n    31\t  imageHint: \"Jules est un petit garçon de 5 ans aux cheveux bruns.\",\n    32\t  label: \"Jules\",\n    33\t  promptHint: \"Jules, un petit garçon de 5 ans, curieux, gentil et malin.\",\n    34\t};\n    35\tconst HERO2: HeroContext = {\n    36\t  imageHint: \"une petite fille aux cheveux bruns\",\n    37\t  label: \"Mona\",\n    38\t  promptHint: \"Mona, la grande sœur de Jules.\",\n    39\t};\n    40\tconst DOUDOU: DoudouContext = {\n    41\t  imageHint: \"un petit lapin en tissu beige\",\n    42\t  label: \"Lapinou\",\n    43\t  promptHint: \"Lapinou, son doudou lapin tout calme\",\n    44\t};\n    45\tconst DOUDOU2: DoudouContext = {\n    46\t  imageHint: \"un ours en peluche brun\",\n    47\t  label: \"Nounours\",\n    48\t  promptHint: \"Nounours, son ours en peluche\",\n    49\t};\n    50\tconst PLACE = { label: \"La forêt\", promptHint: \"dans une forêt ensoleillée\" };\n    51\t\n    52\tlet failures = 0;\n    53\tfunction expectEqual(name: string, actual: string, expected: string) {\n    54\t  if (actual === expected) {\n    55\t    console.log(`✓ ${name}`);\n    56\t  } else {\n    57\t    failures += 1;\n    58\t    console.error(\n    59\t      `✗ ${name}\\n  expected: ${JSON.stringify(expected)}\\n  actual:   ${JSON.stringify(actual)}`\n    60\t    );\n    61\t  }\n    62\t}\n    63\t\n    64\t// ── 1. Beat 0: no reference, place-hint fallback, no visual world ────────────\n    65\texpectEqual(\n    66\t  \"beat0 — no reference, place-hint fallback, no visual world\",\n    67\t  buildSegmentImagePrompt(\n    68\t    { visualWorld: null },\n    69\t    {\n    70\t      paragraphs: [\n    71\t        \"Jules marche vers le grand chêne.\",\n    72\t        \"Puis il ramasse une jolie feuille.\",\n    73\t      ],\n    74\t      sceneHint: null,\n    75\t    },\n    76\t    false,\n    77\t    { doudous: [DOUDOU], heroes: [HERO], outfit: null, place: PLACE }\n    78\t  ),\n    79\t  \"Illustration pour un bout d'une histoire d'enfant, tendre et rassurante. Jules marche vers le grand chêne. Puis il ramasse une jolie feuille. La scène se passe dans une forêt ensoleillée. Jules est un petit garçon de 5 ans aux cheveux bruns. Avec un petit lapin en tissu beige, tendrement près de l'enfant. Style studio Ghibli. Pas de texte dans l'image. Pas de visage photoréaliste. Ambiance calme, rassurante et merveilleuse, adaptée à un enfant de 5 ans.\"\n    80\t);\n    81\t\n    82\t// ── 2. Later beat: sceneHint PRIORITY over place, full context ───────────────\n    83\texpectEqual(\n    84\t  \"later beat — reference, sceneHint priority, visual world, outfit, multi hero, doudou sliced to 1\",\n    85\t  buildSegmentImagePrompt(\n    86\t    { visualWorld: \"fin d'après-midi d'été, lumière dorée, ciel dégagé\" },\n    87\t    {\n    88\t      paragraphs: [\"Alors la barque glisse sur l'eau calme.\"],\n    89\t      sceneHint: \"Une rivière paisible au soleil couchant, une petite barque\",\n    90\t    },\n    91\t    true,\n    92\t    {\n    93\t      doudous: [DOUDOU, DOUDOU2],\n    94\t      heroes: [HERO, HERO2],\n    95\t      outfit: \"Jules en pull bleu ; Mona en veste verte\",\n    96\t      place: PLACE,\n    97\t    }\n    98\t  ),\n    99\t  \"Reprends EXACTEMENT les personnages de l'image fournie (visages, coiffures, vêtements, proportions) et son style — mais PAS son décor ni son cadrage. Dessine le lieu où l'histoire se trouve MAINTENANT (voir « La scène » ci-dessous), même s'il ne ressemble plus à celui de l'image fournie : Alors la barque glisse sur l'eau calme. La scène : Une rivière paisible au soleil couchant, une petite barque Ambiance générale de l'histoire (sauf indication contraire de la scène) : fin d'après-midi d'été, lumière dorée, ciel dégagé. Tenue des personnages, à garder IDENTIQUE d'une image à l'autre (sauf si l'image de référence montre déjà leurs vêtements) : Jules en pull bleu ; Mona en veste verte. Jules est un petit garçon de 5 ans aux cheveux bruns. et une petite fille aux cheveux bruns, tous ensemble dans la scène. Avec un petit lapin en tissu beige, tendrement près de l'enfant. Style studio Ghibli. Pas de texte dans l'image. Pas de visage photoréaliste. Ambiance calme, rassurante et merveilleuse, adaptée à un enfant de 5 ans.\"\n   100\t);\n   101\t\n   102\t// ── 3. No sceneHint AND empty place hint → scene line omitted ────────────────\n   103\texpectEqual(\n   104\t  \"no sceneHint, empty place hint — scene line omitted\",\n   105\t  buildSegmentImagePrompt(\n   106\t    { visualWorld: null },\n   107\t    { paragraphs: [\"Jules regarde les étoiles.\"], sceneHint: null },\n   108\t    false,\n   109\t    {\n   110\t      doudous: [],\n   111\t      heroes: [HERO],\n   112\t      outfit: null,\n   113\t      place: { label: \"\", promptHint: \"\" },\n   114\t    }\n   115\t  ),\n   116\t  \"Illustration pour un bout d'une histoire d'enfant, tendre et rassurante. Jules regarde les étoiles. Jules est un petit garçon de 5 ans aux cheveux bruns. Style studio Ghibli. Pas de texte dans l'image. Pas de visage photoréaliste. Ambiance calme, rassurante et merveilleuse, adaptée à un enfant de 5 ans.\"\n   117\t);\n   118\t\n   119\t// ── 4. visual_world DEFAULT: no sceneHint, place + visualWorld present ───────\n   120\texpectEqual(\n   121\t  \"visual-world DEFAULT case — no sceneHint, place + visualWorld present\",\n   122\t  buildSegmentImagePrompt(\n   123\t    { visualWorld: \"matin de printemps, lumière claire\" },\n   124\t    { paragraphs: [\"Puis Jules retrouve le sentier.\"], sceneHint: null },\n   125\t    true,\n   126\t    { doudous: [DOUDOU], heroes: [HERO], outfit: null, place: PLACE }\n   127\t  ),\n   128\t  \"Reprends EXACTEMENT les personnages de l'image fournie (visages, coiffures, vêtements, proportions) et son style — mais PAS son décor ni son cadrage. Dessine le lieu où l'histoire se trouve MAINTENANT (voir « La scène » ci-dessous), même s'il ne ressemble plus à celui de l'image fournie : Puis Jules retrouve le sentier. La scène se passe dans une forêt ensoleillée. Ambiance générale de l'histoire (sauf indication contraire de la scène) : matin de printemps, lumière claire. Jules est un petit garçon de 5 ans aux cheveux bruns. Avec un petit lapin en tissu beige, tendrement près de l'enfant. Style studio Ghibli. Pas de texte dans l'image. Pas de visage photoréaliste. Ambiance calme, rassurante et merveilleuse, adaptée à un enfant de 5 ans.\"\n   129\t);\n   130\t\n   131\tif (failures > 0) {\n   132\t  console.error(`\\nSEGMENT-IMAGE GOLDEN FAILED: ${failures} mismatch(es).`);\n   133\t  process.exit(1);\n   134\t}\n   135\tconsole.log(\n   136\t  \"\\nSEGMENT-IMAGE GOLDEN OK: the extracted builder is byte-identical to the pre-refactor inline prompt.\"\n   137\t);\n     1\timport { findLegacyHero } from \"~/config/characters\";\n     2\timport { findLegacyElement } from \"~/config/elements\";\n     3\timport { findPlace } from \"~/config/places\";\n     4\timport type { Story } from \"~/server/db/schema\";\n     5\timport type {\n     6\t  DoudouContext,\n     7\t  ElementContext,\n     8\t  HeroContext,\n     9\t} from \"~/server/providers/types\";\n    10\t\n    11\t/**\n    12\t * The frozen prompt context for an ALREADY-CREATED story.\n    13\t *\n    14\t * Codex must-do #1 + #2: every history re-prompt path (classic image regen,\n    15\t * dynamic continuation text, dynamic segment image) MUST resolve hero/place/\n    16\t * element through THIS helper — never through `findPlace(story.placeId)` against\n    17\t * the editable DB. After this change, `grep` for a history path reading the live\n    18\t * places table must come up empty.\n    19\t *\n    20\t * Resolution rules:\n    21\t *  - PLACE (editable): prefer the row's frozen snapshot (`placeLabel` /\n    22\t *    `placePromptHint`). If null (a story created before the snapshot columns\n    23\t *    existed), fall back to the IMMUTABLE legacy config by id\n    24\t *    (`src/config/places.ts`) — NOT the editable DB row, NOT the active-only\n    25\t *    list. So editing or soft-deleting a place never alters an old story.\n    26\t *  - DOUDOU (editable, OPTIONAL, MULTI): resolved purely from the row's frozen\n    27\t *    snapshot, which is self-contained — so a doudou edit/delete never touches\n    28\t *    an old story. Prefer the `doudouSnapshots` ARRAY (all chosen doudous, the\n    29\t *    multi-select source of truth); if it is null (a story created during the\n    30\t *    single-doudou period) fall back to the singular columns (`doudouLabel` /\n    31\t *    `doudouPromptHint` / `doudouImageHint`) as a one-element array; if those\n    32\t *    are also null, no doudou was chosen → `doudous` is empty and nothing is\n    33\t *    injected. (No config-by-id fallback: the doudou feature postdates the\n    34\t *    snapshot columns, so no doudou story can predate them.)\n    35\t *  - HERO + ELEMENT (editable, MULTI): resolved like the place — prefer the row's\n    36\t *    frozen snapshot ARRAY (`heroSnapshots` / `elementSnapshots`, the multi-select\n    37\t *    source of truth); if it is null (a story created before heroes/elements\n    38\t *    became editable + multi), fall back to the IMMUTABLE legacy config BY ID\n    39\t *    (`heroId` / `elementId`) as a ONE-element array — NOT the editable DB table,\n    40\t *    NOT the active-only list. So editing/deleting a hero/element never alters an\n    41\t *    old story. (Unlike doudous, heroes/elements existed as config before the\n    42\t *    snapshot columns, so the config-by-id fallback IS needed — codex #3.)\n    43\t */\n    44\texport interface FrozenStoryContext {\n    45\t  // Resolved doudous, frozen — EMPTY when the child chose no doudou. Callers\n    46\t  // inject the prompt/image hints for each. Prefers the multi-select array\n    47\t  // snapshot; falls back to the singular columns for single-doudou-era stories.\n    48\t  doudous: DoudouContext[];\n    49\t  // Resolved surprise elements, frozen. Like heroes: snapshot array → config\n    50\t  // fallback by id as a one-element array → empty.\n    51\t  elements: ElementContext[];\n    52\t  // Resolved heroes, frozen — heroes[0] is the PRIMARY (named-hard) hero. Never\n    53\t  // empty for a well-formed story (creation hard-fails on an empty resolve);\n    54\t  // callers still treat an empty array gracefully.\n    55\t  heroes: HeroContext[];\n    56\t  // The story's frozen outfit (heroes' wardrobe), or null. Not editable and not\n    57\t  // snapshotted per-entity — it is a single story-level column (like the\n    58\t  // visual world), so it needs no fallback: null on older rows / arc soft-fail\n    59\t  // / safety drop, in which case callers omit the outfit line.\n    60\t  outfit: string | null;\n    61\t  // Resolved place fields, frozen. `promptHint` may be \"\" if neither snapshot\n    62\t  // nor a legacy-config id resolves (a deleted custom place on a pre-snapshot\n    63\t  // row) — callers already treat an empty hint as \"omit the scene line\".\n    64\t  place: { label: string; promptHint: string };\n    65\t}\n    66\t\n    67\texport function getFrozenStoryPromptContext(story: Story): FrozenStoryContext {\n    68\t  const legacy = findPlace(story.placeId);\n    69\t  // Prefer the frozen snapshot; fall back to immutable legacy config by id.\n    70\t  const label = story.placeLabel ?? legacy?.label ?? \"\";\n    71\t  const promptHint = story.placePromptHint ?? legacy?.promptHint ?? \"\";\n    72\t\n    73\t  // Doudous are self-contained in the snapshot (no id column, no config\n    74\t  // fallback). Prefer the multi-select array; else the singular columns (a\n    75\t  // single-doudou-era story) as a one-element array; else none.\n    76\t  let doudous: DoudouContext[];\n    77\t  if (story.doudouSnapshots && story.doudouSnapshots.length > 0) {\n    78\t    doudous = story.doudouSnapshots.map((d) => ({\n    79\t      imageHint: d.imageHint ?? \"\",\n    80\t      label: d.label ?? \"\",\n    81\t      promptHint: d.promptHint ?? \"\",\n    82\t    }));\n    83\t  } else if (story.doudouPromptHint) {\n    84\t    doudous = [\n    85\t      {\n    86\t        imageHint: story.doudouImageHint ?? \"\",\n    87\t        label: story.doudouLabel ?? \"\",\n    88\t        promptHint: story.doudouPromptHint,\n    89\t      },\n    90\t    ];\n    91\t  } else {\n    92\t    doudous = [];\n    93\t  }\n    94\t\n    95\t  // Heroes: prefer the snapshot ARRAY; else the immutable legacy config by\n    96\t  // `heroId` as a one-element array; else empty (codex #3). A legacy hero with\n    97\t  // no own imageHint already carries the gentle DEFAULT_HERO_IMAGE_HINT.\n    98\t  let heroes: HeroContext[];\n    99\t  if (story.heroSnapshots && story.heroSnapshots.length > 0) {\n   100\t    heroes = story.heroSnapshots.map((h) => ({\n   101\t      imageHint: h.imageHint ?? \"\",\n   102\t      label: h.label ?? \"\",\n   103\t      promptHint: h.promptHint ?? \"\",\n   104\t    }));\n   105\t  } else {\n   106\t    const legacy = findLegacyHero(story.heroId);\n   107\t    heroes = legacy\n   108\t      ? [\n   109\t          {\n   110\t            imageHint: legacy.imageHint,\n   111\t            label: legacy.label,\n   112\t            promptHint: legacy.promptHint,\n   113\t          },\n   114\t        ]\n   115\t      : [];\n   116\t  }\n   117\t\n   118\t  // Elements: same shape, minus imageHint.\n   119\t  let elements: ElementContext[];\n   120\t  if (story.elementSnapshots && story.elementSnapshots.length > 0) {\n   121\t    elements = story.elementSnapshots.map((e) => ({\n   122\t      label: e.label ?? \"\",\n   123\t      promptHint: e.promptHint ?? \"\",\n   124\t    }));\n   125\t  } else {\n   126\t    const legacy = findLegacyElement(story.elementId);\n   127\t    elements = legacy\n   128\t      ? [{ label: legacy.label, promptHint: legacy.promptHint }]\n   129\t      : [];\n   130\t  }\n   131\t\n   132\t  return {\n   133\t    doudous,\n   134\t    elements,\n   135\t    heroes,\n   136\t    outfit: story.outfit ?? null,\n   137\t    place: { label, promptHint },\n   138\t  };\n   139\t}\n","exit_code":0,"status":"completed"}}
