{"type":"item.completed","item":{"id":"item_17","type":"command_execution","command":"/usr/bin/zsh -lc \"nl -ba src/server/providers/media-store.ts | sed -n '1,300p'; git show main:src/server/dynamic-functions.ts | nl -ba | sed -n '650,820p'; nl -ba src/server/dynamic-functions.ts | sed -n '600,790p'; git show main:src/server/providers/tts/edge.ts | nl -ba; nl -ba src/server/providers/tts/edge.ts\"","aggregated_output":"     1\timport { mkdir, readFile, writeFile } from \"node:fs/promises\";\n     2\timport { join, resolve, sep } from \"node:path\";\n     3\timport { serverEnv } from \"~/env\";\n     4\t\n     5\t/**\n     6\t * Generated images/audio are persisted through this single choke-point. The\n     7\t * string returned here flows verbatim into `stories.imagePath` /\n     8\t * `storySegments.imagePath` and is rendered straight into `<img src>`.\n     9\t *\n    10\t * Two backends, gated on env:\n    11\t * - Vercel Blob (cloud) when `BLOB_READ_WRITE_TOKEN` is set → returns a public\n    12\t *   `https://…` CDN URL. This makes the app cloud-deployable on Vercel, whose\n    13\t *   filesystem is ephemeral/read-only.\n    14\t * - Local disk (DATA_DIR, gitignored) as a fallback when the token is absent\n    15\t *   (e.g. offline local dev) → returns a `/data/media/<file>` web path served\n    16\t *   by the `/data/$` route.\n    17\t *\n    18\t * The leading-`/` (local) vs `https://` (blob) prefix IS the back-compat\n    19\t * boundary — old rows keep working via the disk-serve route.\n    20\t */\n    21\tconst MEDIA_DIR = resolve(serverEnv.dataDir, \"media\");\n    22\t\n    23\tconst CONTENT_TYPES: Record<string, string> = {\n    24\t  jpeg: \"image/jpeg\",\n    25\t  jpg: \"image/jpeg\",\n    26\t  mp3: \"audio/mpeg\",\n    27\t  png: \"image/png\",\n    28\t  wav: \"audio/wav\",\n    29\t  webp: \"image/webp\",\n    30\t};\n    31\t\n    32\t// Exported for the /data/$ disk-serve route, which needs the same mapping to\n    33\t// set the response Content-Type it serves stored files with.\n    34\texport function contentTypeFor(filename: string): string {\n    35\t  const ext = filename.split(\".\").pop()?.toLowerCase() ?? \"\";\n    36\t  return CONTENT_TYPES[ext] ?? \"application/octet-stream\";\n    37\t}\n    38\t\n    39\t// Hard cap on a single Blob upload. The Blob REST API has no built-in\n    40\t// timeout, so a stalled upload (network blip, provider hiccup) would otherwise\n    41\t// hang the whole image step until the client's reveal timeout. Capping it here\n    42\t// turns a stall into a fast, caught failure → the calm \"no drawing\" state.\n    43\tconst BLOB_UPLOAD_TIMEOUT_MS = 20_000;\n    44\t\n    45\t// Vercel Blob REST endpoint + protocol constants, copied verbatim from the\n    46\t// `@vercel/blob@2.4.1` SDK source so this fetch replicates `put()` exactly.\n    47\t// We DON'T use the SDK: it transitively pulls @vercel/oidc → @vercel/cli-config\n    48\t// → xdg-app-paths, a CJS module that calls bare top-level `require()`. Nitro\n    49\t// bundles this SSR app to pure ESM (.mjs) where `require` is undefined; Rollup\n    50\t// hoisted that chain into a shared eager chunk imported at module-load on every\n    51\t// route → `ReferenceError: require is not defined` → prod SSR 500. A lazy\n    52\t// `await import(\"@vercel/blob\")` did NOT help (the chain was still hoisted into\n    53\t// the eager chunk). Talking to the REST API directly removes the dep entirely.\n    54\tconst BLOB_API_URL = \"https://vercel.com/api/blob\";\n    55\tconst BLOB_API_VERSION = \"12\";\n    56\t\n    57\t// rw token format: `vercel_blob_rw_<storeId>_<secret>` → storeId is segment[3].\n    58\tfunction storeIdFromToken(token: string): string {\n    59\t  return token.split(\"_\")[3] ?? \"\";\n    60\t}\n    61\t\n    62\tfunction withTimeout<T>(\n    63\t  promise: Promise<T>,\n    64\t  ms: number,\n    65\t  label: string\n    66\t): Promise<T> {\n    67\t  return new Promise<T>((resolve, reject) => {\n    68\t    const timer = setTimeout(\n    69\t      () => reject(new Error(`${label} timed out after ${ms}ms`)),\n    70\t      ms\n    71\t    );\n    72\t    promise.then(\n    73\t      (value) => {\n    74\t        clearTimeout(timer);\n    75\t        resolve(value);\n    76\t      },\n    77\t      (err) => {\n    78\t        clearTimeout(timer);\n    79\t        reject(err);\n    80\t      }\n    81\t    );\n    82\t  });\n    83\t}\n    84\t\n    85\texport async function saveMedia(\n    86\t  filename: string,\n    87\t  bytes: Uint8Array\n    88\t): Promise<string> {\n    89\t  // Cloud path: Vercel Blob. Filenames are nanoid-unique, so we never overwrite\n    90\t  // an existing key (Blob public URLs are cached ~1mo — overwriting is unsafe).\n    91\t  if (serverEnv.blobReadWriteToken) {\n    92\t    const token = serverEnv.blobReadWriteToken;\n    93\t    const pathname = `media/${filename}`;\n    94\t    // Replicates @vercel/blob `put()`: PUT /?pathname=… with the x-* protocol\n    95\t    // headers the SDK sends. Headers copied verbatim from the SDK source so the\n    96\t    // server treats this identically (access=public, no random suffix, the\n    97\t    // file's content-type). Bounded by a timeout so a stalled upload fails fast\n    98\t    // (caught upstream → calm \"no drawing\" state) rather than hanging.\n    99\t    const params = new URLSearchParams({ pathname });\n   100\t    const response = await withTimeout(\n   101\t      fetch(`${BLOB_API_URL}/?${params.toString()}`, {\n   102\t        // Buffer (Uint8Array subclass) is a valid fetch BodyInit; the raw\n   103\t        // Uint8Array isn't accepted by the DOM lib's typings.\n   104\t        body: Buffer.from(bytes),\n   105\t        headers: {\n   106\t          authorization: `Bearer ${token}`,\n   107\t          \"x-add-random-suffix\": \"0\",\n   108\t          \"x-api-version\": BLOB_API_VERSION,\n   109\t          \"x-content-type\": contentTypeFor(filename),\n   110\t          \"x-vercel-blob-access\": \"public\",\n   111\t          \"x-vercel-blob-store-id\": storeIdFromToken(token),\n   112\t        },\n   113\t        method: \"PUT\",\n   114\t      }),\n   115\t      BLOB_UPLOAD_TIMEOUT_MS,\n   116\t      \"Vercel Blob upload\"\n   117\t    );\n   118\t    if (!response.ok) {\n   119\t      const detail = await response.text().catch(() => \"\");\n   120\t      throw new Error(\n   121\t        `Vercel Blob upload failed: ${response.status} ${response.statusText} ${detail}`.trim()\n   122\t      );\n   123\t    }\n   124\t    // SDK returns { url, downloadUrl, pathname, contentType, … }; we need `url`.\n   125\t    const result = (await response.json()) as { url?: string };\n   126\t    if (!result.url) {\n   127\t      throw new Error(\"Vercel Blob upload returned no url\");\n   128\t    }\n   129\t    return result.url;\n   130\t  }\n   131\t\n   132\t  // Local-disk fallback (offline dev). Web path served by the /data/$ route.\n   133\t  await mkdir(MEDIA_DIR, { recursive: true });\n   134\t  await writeFile(join(MEDIA_DIR, filename), bytes);\n   135\t  return `/data/media/${filename}`;\n   136\t}\n   137\t\n   138\t// The web-path prefix local-disk `saveMedia` returns (see above). Exported so\n   139\t// readers of stored paths don't re-derive the storage convention by hand.\n   140\texport const MEDIA_WEB_PREFIX = \"/data/media/\";\n   141\t\n   142\t/**\n   143\t * The exact public hostname of THIS app's Vercel Blob store (derived from the\n   144\t * rw token), or null when running without Blob (local dev). Lets readers of\n   145\t * stored https media URLs pin their allowlist to our own store instead of the\n   146\t * whole *.public.blob.vercel-storage.com namespace.\n   147\t */\n   148\texport function blobStoreHost(): string | null {\n   149\t  const token = serverEnv.blobReadWriteToken;\n   150\t  return token ? blobHostFromToken(token) : null;\n   151\t}\n   152\t\n   153\t/**\n   154\t * Derive the public blob hostname from a rw token. Pure (env-free) so the\n   155\t * allowlist compare can be unit-tested. LOWERCASED on purpose: hostnames are\n   156\t * case-insensitive and the WHATWG URL parser lowercases `url.hostname`, so a\n   157\t * store id containing uppercase letters would otherwise never equal the parsed\n   158\t * hostname — the app would silently reject its OWN blob URLs and disable every\n   159\t * reference image in blob/prod mode. Returns null for a malformed token.\n   160\t */\n   161\texport function blobHostFromToken(token: string): string | null {\n   162\t  const storeId = storeIdFromToken(token);\n   163\t  return storeId\n   164\t    ? `${storeId}.public.blob.vercel-storage.com`.toLowerCase()\n   165\t    : null;\n   166\t}\n   167\t\n   168\t/**\n   169\t * Read back the bytes of a LOCAL stored media web path (`/data/media/<file>`).\n   170\t * Returns null for any other shape. The resolved file must stay inside\n   171\t * MEDIA_DIR — a tampered stored path like `/data/media/../../.env` is rejected\n   172\t * rather than read (defense-in-depth: today only server-generated nanoid\n   173\t * filenames are ever written to the DB).\n   174\t */\n   175\texport async function readStoredMediaBytes(\n   176\t  webPath: string\n   177\t): Promise<Uint8Array | null> {\n   178\t  if (!webPath.startsWith(MEDIA_WEB_PREFIX)) {\n   179\t    return null;\n   180\t  }\n   181\t  const full = resolve(MEDIA_DIR, webPath.slice(MEDIA_WEB_PREFIX.length));\n   182\t  if (!full.startsWith(MEDIA_DIR + sep)) {\n   183\t    return null;\n   184\t  }\n   185\t  return await readFile(full);\n   186\t}\n   187\t\n   188\t// The public-blob namespace suffix, the https allowlist FALLBACK when no rw\n   189\t// token is configured (then we can't derive the exact store host).\n   190\tconst BLOB_HOST_SUFFIX = \".public.blob.vercel-storage.com\";\n   191\t\n   192\t// Bound on fetching back a stored blob media (reference-image flow): a stalled\n   193\t// CDN fetch must degrade (→ plain text-to-image) rather than hang the beat.\n   194\tconst STORED_MEDIA_FETCH_TIMEOUT_MS = 10_000;\n   195\t\n   196\t/**\n   197\t * The https-branch ALLOWLIST decision for a stored media value, PURE\n   198\t * (env-free) so the goldens can pin it: parse the stored `https://` string and\n   199\t * accept it only when its hostname is THIS app's own Blob store (`storeHost`,\n   200\t * rw-token-derived — see `blobStoreHost`) — or, when no token is configured\n   201\t * (local dev reading old blob rows), any `*.public.blob.vercel-storage.com`\n   202\t * host. Anything else (a tampered row, a future write path) returns null:\n   203\t * ignored rather than fetched server-side (SSRF defense-in-depth).\n   204\t */\n   205\texport function allowedStoredMediaUrl(\n   206\t  stored: string,\n   207\t  storeHost: string | null\n   208\t): URL | null {\n   209\t  if (!stored.startsWith(\"https://\")) {\n   210\t    return null;\n   211\t  }\n   212\t  let url: URL;\n   213\t  try {\n   214\t    url = new URL(stored);\n   215\t  } catch {\n   216\t    return null;\n   217\t  }\n   218\t  const allowed = storeHost\n   219\t    ? url.hostname === storeHost\n   220\t    : url.hostname.endsWith(BLOB_HOST_SUFFIX);\n   221\t  return allowed ? url : null;\n   222\t}\n   223\t\n   224\t/**\n   225\t * Read back a STORED media value (a `stories`/`story_segments` path column) as\n   226\t * bytes for a model input — the single read-back counterpart of `saveMedia`,\n   227\t * hiding the same `/`-prefix (local) vs `https://` (blob) back-compat boundary\n   228\t * so no caller re-implements the storage rule:\n   229\t *  - `https://…` → allowlisted via `allowedStoredMediaUrl` (own store host\n   230\t *    when the rw token is set, else the public-blob suffix), then fetched with\n   231\t *    a bounded timeout. A rejected host logs LOUDLY: a silent rejection here\n   232\t *    once hid a prod bug (a case-mismatched store host rejected the app's OWN\n   233\t *    blob URLs and disabled every reference image).\n   234\t *  - `/data/media/…` → `readStoredMediaBytes` (rejects any path escaping the\n   235\t *    media dir).\n   236\t * Returns undefined when the value is rejected/unreadable — callers degrade\n   237\t * (e.g. plain text-to-image). Errors propagate: the caller owns best-effort.\n   238\t */\n   239\texport async function resolveStoredMediaForModel(\n   240\t  stored: string\n   241\t): Promise<Uint8Array | undefined> {\n   242\t  if (stored.startsWith(\"https://\")) {\n   243\t    const storeHost = blobStoreHost();\n   244\t    const url = allowedStoredMediaUrl(stored, storeHost);\n   245\t    if (!url) {\n   246\t      console.warn(\n   247\t        `[media-store] stored https media REJECTED by host allowlist: ${stored}` +\n   248\t          ` (expected ${storeHost ?? `*${BLOB_HOST_SUFFIX}`}).`\n   249\t      );\n   250\t      return;\n   251\t    }\n   252\t    const res = await fetch(url, {\n   253\t      signal: AbortSignal.timeout(STORED_MEDIA_FETCH_TIMEOUT_MS),\n   254\t    });\n   255\t    if (!res.ok) {\n   256\t      return;\n   257\t    }\n   258\t    return new Uint8Array(await res.arrayBuffer());\n   259\t  }\n   260\t  return (await readStoredMediaBytes(stored)) ?? undefined;\n   261\t}\n   650\t          isNotNull(storySegments.imagePath),\n   651\t          ne(storySegments.imagePath, IMAGE_FAILED_SENTINEL)\n   652\t        )\n   653\t      )\n   654\t      .orderBy(asc(storySegments.idx))\n   655\t      .limit(1);\n   656\t    const path = anchor?.imagePath;\n   657\t    if (!path) {\n   658\t      return;\n   659\t    }\n   660\t    if (path.startsWith(\"https://\")) {\n   661\t      const url = new URL(path);\n   662\t      const storeHost = blobStoreHost();\n   663\t      const allowed = storeHost\n   664\t        ? url.hostname === storeHost\n   665\t        : url.hostname.endsWith(BLOB_HOST_SUFFIX);\n   666\t      if (!allowed) {\n   667\t        // Loud on purpose: a silent rejection here hid a prod bug (a\n   668\t        // case-mismatched store host rejected the app's OWN blob URLs, disabling\n   669\t        // every reference image). If this fires for our own host, it is a bug.\n   670\t        console.warn(\n   671\t          `[stories] reference image REJECTED by host allowlist for story ${storyId} idx=${idx}:` +\n   672\t            ` ${url.hostname} not allowed (expected ${storeHost ?? `*${BLOB_HOST_SUFFIX}`}).`\n   673\t        );\n   674\t        return;\n   675\t      }\n   676\t      const res = await fetch(url, {\n   677\t        signal: AbortSignal.timeout(REFERENCE_FETCH_TIMEOUT_MS),\n   678\t      });\n   679\t      if (!res.ok) {\n   680\t        return;\n   681\t      }\n   682\t      return new Uint8Array(await res.arrayBuffer());\n   683\t    }\n   684\t    return (await readStoredMediaBytes(path)) ?? undefined;\n   685\t  } catch (error) {\n   686\t    // Best-effort only: a missing local file / DB hiccup must never fail the\n   687\t    // image itself — generate without a reference instead.\n   688\t    console.warn(\n   689\t      `[stories] reference image unavailable for story ${storyId} idx=${idx}:`,\n   690\t      error instanceof Error ? error.message : String(error)\n   691\t    );\n   692\t  }\n   693\t}\n   694\t\n   695\t/**\n   696\t * The actual segment-image generation, deduped by `generateSegmentImageFn` /\n   697\t * `retrySegmentImageFn`. `force` (retry only) clears a prior `__failed__`\n   698\t * sentinel so a settled failure can be re-attempted; a real stored image is\n   699\t * still treated as a no-op (never overwritten / re-billed).\n   700\t */\n   701\tasync function generateSegmentImage(\n   702\t  storyId: string,\n   703\t  idx: number,\n   704\t  startedAt: number,\n   705\t  model: string,\n   706\t  force = false\n   707\t): Promise<ImageResult> {\n   708\t  const [segment] = await db\n   709\t    .select()\n   710\t    .from(storySegments)\n   711\t    .where(and(eq(storySegments.storyId, storyId), eq(storySegments.idx, idx)));\n   712\t  if (!segment) {\n   713\t    return { imagePath: null, imageStatus: \"skipped\" };\n   714\t  }\n   715\t  // A forced retry re-attempts ONLY a prior failure sentinel — a real stored\n   716\t  // path is always a no-op (don't overwrite / re-bill an existing illustration).\n   717\t  if (segment.imagePath && segment.imagePath !== IMAGE_FAILED_SENTINEL) {\n   718\t    return resolveStoredImagePath(segment.imagePath);\n   719\t  }\n   720\t  if (segment.imagePath === IMAGE_FAILED_SENTINEL && !force) {\n   721\t    // Idempotent no-op: the terminal failure sentinel → \"failed\" (a prior\n   722\t    // attempt already failed — do NOT re-bill Gemini, do NOT re-hang the child;\n   723\t    // the calm \"no drawing\" state is final for this beat unless explicitly\n   724\t    // retried via `retrySegmentImageFn`).\n   725\t    return resolveStoredImagePath(segment.imagePath);\n   726\t  }\n   727\t\n   728\t  const [story] = await db\n   729\t    .select()\n   730\t    .from(stories)\n   731\t    .where(eq(stories.id, storyId));\n   732\t  if (!story) {\n   733\t    return { imagePath: null, imageStatus: \"skipped\" };\n   734\t  }\n   735\t  // History path: frozen snapshot, never the live editable rows.\n   736\t  const { heroes, place, doudous, outfit } = getFrozenStoryPromptContext(story);\n   737\t\n   738\t  // A prior illustration of THIS story, sent as an image input so characters/\n   739\t  // style stay consistent across beats (best-effort — null on beat 0 / no\n   740\t  // prior image / fetch failure → plain text-to-image, as before).\n   741\t  const referenceImage = await resolveReferenceImage(storyId, idx);\n   742\t\n   743\t  // The beat's OWN scene (emitted by the text model) wins over the story's\n   744\t  // frozen starting place: once the story walks through the magic door, the\n   745\t  // illustration must follow it — not stamp \"aux États-Unis\" on every page.\n   746\t  let sceneLine = \"\";\n   747\t  if (segment.sceneHint) {\n   748\t    sceneLine = `La scène : ${segment.sceneHint}`;\n   749\t  } else if (place.promptHint) {\n   750\t    sceneLine = `La scène se passe ${place.promptHint}.`;\n   751\t  }\n   752\t\n   753\t  // Story-level visual world (time of day, season, weather, light), frozen at\n   754\t  // creation. A DEFAULT ambiance, not an absolute order: the beat's own scene\n   755\t  // keeps priority (a story that walks through a magic door into space must be\n   756\t  // allowed to change its sky). Null on older stories → line omitted.\n   757\t  const ambianceLine = story.visualWorld\n   758\t    ? `Ambiance générale de l'histoire (sauf indication contraire de la scène) : ${story.visualWorld}.`\n   759\t    : \"\";\n   760\t\n   761\t  // Story-level frozen outfit (the heroes' wardrobe), a DEFAULT the reference\n   762\t  // image overrides. Mainly anchors beat 0 (no reference yet) and non-default\n   763\t  // heroes (no clothing in their imageHint). \"\" on older stories / safety drop\n   764\t  // → line omitted, image built exactly as before.\n   765\t  const outfitLine = outfitImageLine(outfit);\n   766\t\n   767\t  // Feed the WHOLE beat's text (now 1–3 short sentences) so the page's image\n   768\t  // reflects that full page, not just its first ~8-word sentence.\n   769\t  const prompt = [\n   770\t    // The reference anchors CHARACTER IDENTITY + STYLE only — never the decor.\n   771\t    // The earlier \"dans une NOUVELLE scène\" wording let the model clone page\n   772\t    // 1's backdrop on every page, so the illustrations never moved even when\n   773\t    // the story did.\n   774\t    referenceImage\n   775\t      ? \"Reprends EXACTEMENT les personnages de l'image fournie (visages, coiffures, vêtements, proportions) et son style — mais PAS son décor ni son cadrage. Dessine le lieu où l'histoire se trouve MAINTENANT (voir « La scène » ci-dessous), même s'il ne ressemble plus à celui de l'image fournie :\"\n   776\t      : \"Illustration pour un bout d'une histoire d'enfant, tendre et rassurante.\",\n   777\t    segment.paragraphs.join(\" \"),\n   778\t    sceneLine,\n   779\t    ambianceLine,\n   780\t    outfitLine,\n   781\t    // Single hero → identical to the old `hero.imageHint`; multi → grouped.\n   782\t    heroesImageLine(heroes),\n   783\t    // Only the FIRST doudou appears in illustrations — 6 peluches per page\n   784\t    // crowded every composition; the text still mentions them all.\n   785\t    doudouImageLine(doudous.slice(0, 1)),\n   786\t    imageStyleSuffix,\n   787\t  ]\n   788\t    .filter(Boolean)\n   789\t    .join(\" \");\n   790\t\n   791\t  try {\n   792\t    const imagePath = await nanoBananaImageProvider.generateImage(\n   793\t      prompt,\n   794\t      model,\n   795\t      referenceImage\n   796\t    );\n   797\t    await db\n   798\t      .update(storySegments)\n   799\t      .set({ imagePath })\n   800\t      .where(eq(storySegments.id, segment.id));\n   801\t    console.log(\"[stories] image gen DONE\", {\n   802\t      idx,\n   803\t      imagePath,\n   804\t      ms: Date.now() - startedAt,\n   805\t      storyId,\n   806\t    });\n   807\t    return { imagePath, imageStatus: \"ready\" };\n   808\t  } catch (error) {\n   809\t    // Non-silent: log the real reason (model + story/segment + cause) so the\n   810\t    // operator sees a Gemini billing/quota denial; the child gets a calm\n   811\t    // \"no drawing this time\" state, never a hang.\n   812\t    console.error(\n   813\t      `[stories] segment image generation FAILED for story ${storyId} ` +\n   814\t        `segment idx=${idx} (model=${model}, ` +\n   815\t        `ms=${Date.now() - startedAt}): ` +\n   816\t        (error instanceof Error ? error.message : String(error))\n   817\t    );\n   818\t    // Persist the TERMINAL failure sentinel so this beat's image is settled:\n   819\t    // future remounts / HMR reloads / reopens read it back as \"failed\" and never\n   820\t    // re-attempt generation or re-hang on the waiting screen. Best-effort — a DB\n   600\t * Resolve a prior illustration of the SAME story to use as the consistency\n   601\t * reference for the next one. Picks the EARLIEST renderable image (usually beat\n   602\t * 0) as the canonical character/style anchor — chaining each image off the\n   603\t * previous one would compound drift instead of preventing it.\n   604\t *\n   605\t * Returns raw bytes, or undefined (beat 0 / nothing renderable yet / read\n   606\t * failure) — in which case the caller falls back to plain text-to-image.\n   607\t *\n   608\t * The `/`-prefix (local) vs `https://` (blob) storage rule — incl. the blob\n   609\t * host ALLOWLIST and the media-dir escape rejection — lives ENTIRELY in\n   610\t * `resolveStoredMediaForModel` (media-store, the single media choke-point);\n   611\t * this function only picks WHICH stored row anchors the story.\n   612\t *\n   613\t * The blob bytes are DOWNLOADED HERE, inside the best-effort try/catch, with a\n   614\t * bounded timeout — never handed to the AI SDK as a URL. A deleted/unreachable\n   615\t * anchor blob must degrade to plain text-to-image for that beat, NOT throw\n   616\t * inside generateImage and persist the TERMINAL failure sentinel (which, since\n   617\t * every beat anchors on the same earliest image, would kill every later\n   618\t * illustration of the story with no working retry).\n   619\t */\n   620\tasync function resolveReferenceImage(\n   621\t  storyId: string,\n   622\t  idx: number\n   623\t): Promise<Uint8Array | undefined> {\n   624\t  if (idx <= 0) {\n   625\t    return;\n   626\t  }\n   627\t  try {\n   628\t    // Earliest renderable prior image, filtered in SQL: one row, one column.\n   629\t    const [anchor] = await db\n   630\t      .select({ imagePath: storySegments.imagePath })\n   631\t      .from(storySegments)\n   632\t      .where(\n   633\t        and(\n   634\t          eq(storySegments.storyId, storyId),\n   635\t          lt(storySegments.idx, idx),\n   636\t          isNotNull(storySegments.imagePath),\n   637\t          ne(storySegments.imagePath, IMAGE_FAILED_SENTINEL)\n   638\t        )\n   639\t      )\n   640\t      .orderBy(asc(storySegments.idx))\n   641\t      .limit(1);\n   642\t    const path = anchor?.imagePath;\n   643\t    if (!path) {\n   644\t      return;\n   645\t    }\n   646\t    return await resolveStoredMediaForModel(path);\n   647\t  } catch (error) {\n   648\t    // Best-effort only: a missing local file / DB hiccup must never fail the\n   649\t    // image itself — generate without a reference instead.\n   650\t    console.warn(\n   651\t      `[stories] reference image unavailable for story ${storyId} idx=${idx}:`,\n   652\t      error instanceof Error ? error.message : String(error)\n   653\t    );\n   654\t  }\n   655\t}\n   656\t\n   657\t/**\n   658\t * The actual segment-image generation, deduped by `generateSegmentImageFn` /\n   659\t * `retrySegmentImageFn`. `force` (retry only) clears a prior `__failed__`\n   660\t * sentinel so a settled failure can be re-attempted; a real stored image is\n   661\t * still treated as a no-op (never overwritten / re-billed).\n   662\t */\n   663\tasync function generateSegmentImage(\n   664\t  storyId: string,\n   665\t  idx: number,\n   666\t  startedAt: number,\n   667\t  model: string,\n   668\t  force = false\n   669\t): Promise<ImageResult> {\n   670\t  const [segment] = await db\n   671\t    .select()\n   672\t    .from(storySegments)\n   673\t    .where(and(eq(storySegments.storyId, storyId), eq(storySegments.idx, idx)));\n   674\t  if (!segment) {\n   675\t    return { imagePath: null, imageStatus: \"skipped\" };\n   676\t  }\n   677\t  // A forced retry re-attempts ONLY a prior failure sentinel — a real stored\n   678\t  // path is always a no-op (don't overwrite / re-bill an existing illustration).\n   679\t  if (segment.imagePath && segment.imagePath !== IMAGE_FAILED_SENTINEL) {\n   680\t    return resolveStoredImagePath(segment.imagePath);\n   681\t  }\n   682\t  if (segment.imagePath === IMAGE_FAILED_SENTINEL && !force) {\n   683\t    // Idempotent no-op: the terminal failure sentinel → \"failed\" (a prior\n   684\t    // attempt already failed — do NOT re-bill Gemini, do NOT re-hang the child;\n   685\t    // the calm \"no drawing\" state is final for this beat unless explicitly\n   686\t    // retried via `retrySegmentImageFn`).\n   687\t    return resolveStoredImagePath(segment.imagePath);\n   688\t  }\n   689\t\n   690\t  const [story] = await db\n   691\t    .select()\n   692\t    .from(stories)\n   693\t    .where(eq(stories.id, storyId));\n   694\t  if (!story) {\n   695\t    return { imagePath: null, imageStatus: \"skipped\" };\n   696\t  }\n   697\t  // History path: frozen snapshot, never the live editable rows.\n   698\t  const frozen = getFrozenStoryPromptContext(story);\n   699\t\n   700\t  // A prior illustration of THIS story, sent as an image input so characters/\n   701\t  // style stay consistent across beats (best-effort — null on beat 0 / no\n   702\t  // prior image / fetch failure → plain text-to-image, as before).\n   703\t  const referenceImage = await resolveReferenceImage(storyId, idx);\n   704\t\n   705\t  // The illustration prompt (scene · ambiance · outfit · heroes · doudou ·\n   706\t  // style) is assembled by the pure builder — pinned byte-identical by\n   707\t  // test:golden. This function keeps only DB read / persist / sentinel.\n   708\t  const prompt = buildSegmentImagePrompt(\n   709\t    story,\n   710\t    segment,\n   711\t    referenceImage !== undefined,\n   712\t    frozen\n   713\t  );\n   714\t\n   715\t  try {\n   716\t    const imagePath = await generateImage(prompt, model, referenceImage);\n   717\t    await db\n   718\t      .update(storySegments)\n   719\t      .set({ imagePath })\n   720\t      .where(eq(storySegments.id, segment.id));\n   721\t    console.log(\"[stories] image gen DONE\", {\n   722\t      idx,\n   723\t      imagePath,\n   724\t      ms: Date.now() - startedAt,\n   725\t      storyId,\n   726\t    });\n   727\t    return { imagePath, imageStatus: \"ready\" };\n   728\t  } catch (error) {\n   729\t    // Non-silent: log the real reason (model + story/segment + cause) so the\n   730\t    // operator sees a Gemini billing/quota denial; the child gets a calm\n   731\t    // \"no drawing this time\" state, never a hang.\n   732\t    console.error(\n   733\t      `[stories] segment image generation FAILED for story ${storyId} ` +\n   734\t        `segment idx=${idx} (model=${model}, ` +\n   735\t        `ms=${Date.now() - startedAt}): ` +\n   736\t        (error instanceof Error ? error.message : String(error))\n   737\t    );\n   738\t    // Persist the TERMINAL failure sentinel so this beat's image is settled:\n   739\t    // future remounts / HMR reloads / reopens read it back as \"failed\" and never\n   740\t    // re-attempt generation or re-hang on the waiting screen. Best-effort — a DB\n   741\t    // write error here must not mask the original failure (still return failed).\n   742\t    try {\n   743\t      await db\n   744\t        .update(storySegments)\n   745\t        .set({ imagePath: IMAGE_FAILED_SENTINEL })\n   746\t        .where(eq(storySegments.id, segment.id));\n   747\t    } catch (markError) {\n   748\t      console.error(\n   749\t        `[stories] could not persist image-failed sentinel for story ${storyId} segment idx=${idx}:`,\n   750\t        markError\n   751\t      );\n   752\t    }\n   753\t    return { imagePath: null, imageStatus: \"failed\" };\n   754\t  }\n   755\t}\n     1\timport { mkdir } from \"node:fs/promises\";\n     2\timport { basename } from \"node:path\";\n     3\timport { MsEdgeTTS, OUTPUT_FORMAT } from \"msedge-tts\";\n     4\timport { generateId } from \"~/lib/id-generator\";\n     5\timport { mediaFilePath } from \"~/server/providers/media-store\";\n     6\timport type { Lang, TtsProvider } from \"~/server/providers/types\";\n     7\t\n     8\t// Free Microsoft Edge neural voices. FR in v1; RU voice wired for later.\n     9\tconst VOICE: Record<Lang, string> = {\n    10\t  fr: \"fr-FR-DeniseNeural\",\n    11\t  ru: \"ru-RU-SvetlanaNeural\",\n    12\t};\n    13\t\n    14\t/**\n    15\t * Default TTS: msedge-tts (edge-tts Node port). No API key required.\n    16\t * Behind TTS_ENABLED — the caller decides whether to invoke this.\n    17\t */\n    18\texport const edgeTtsProvider: TtsProvider = {\n    19\t  async synthesize(text: string, lang: Lang): Promise<string> {\n    20\t    const tts = new MsEdgeTTS();\n    21\t    await tts.setMetadata(\n    22\t      VOICE[lang],\n    23\t      OUTPUT_FORMAT.AUDIO_24KHZ_48KBITRATE_MONO_MP3\n    24\t    );\n    25\t\n    26\t    // In this version, toFile takes the full destination path (with filename)\n    27\t    // and returns it. Ensure the media directory exists first.\n    28\t    const destination = mediaFilePath(`${generateId(\"audio\")}.mp3`);\n    29\t    await mkdir(mediaFilePath(\"\"), { recursive: true });\n    30\t\n    31\t    const written = await tts.toFile(destination, text);\n    32\t    return `/data/media/${basename(written)}`;\n    33\t  },\n    34\t};\n     1\timport { MsEdgeTTS, OUTPUT_FORMAT } from \"msedge-tts\";\n     2\timport { generateId } from \"~/lib/id-generator\";\n     3\timport { saveMedia } from \"~/server/providers/media-store\";\n     4\timport type { Lang, TtsProvider } from \"~/server/providers/types\";\n     5\t\n     6\t// Free Microsoft Edge neural voices. FR in v1; RU voice wired for later.\n     7\tconst VOICE: Record<Lang, string> = {\n     8\t  fr: \"fr-FR-DeniseNeural\",\n     9\t  ru: \"ru-RU-SvetlanaNeural\",\n    10\t};\n    11\t\n    12\t/**\n    13\t * Default TTS: msedge-tts (edge-tts Node port). No API key required.\n    14\t * Behind TTS_ENABLED — the caller decides whether to invoke this.\n    15\t *\n    16\t * Synthesizes to BYTES and persists through `saveMedia` — the single media\n    17\t * choke-point — exactly like the elevenlabs adapter, so the stored path\n    18\t * honors the active backend (local `/data/media/…` OR a Blob `https://…`\n    19\t * URL). The previous version wrote the file to disk itself and hand-built the\n    20\t * `/data/media/` path, which silently broke audio in Blob mode (ephemeral\n    21\t * filesystem, and the `/data/$` route never serves what Blob mode stores).\n    22\t */\n    23\texport const edgeTtsProvider: TtsProvider = {\n    24\t  async synthesize(text: string, lang: Lang): Promise<string> {\n    25\t    const tts = new MsEdgeTTS();\n    26\t    await tts.setMetadata(\n    27\t      VOICE[lang],\n    28\t      OUTPUT_FORMAT.AUDIO_24KHZ_48KBITRATE_MONO_MP3\n    29\t    );\n    30\t\n    31\t    // toStream ends with push(null) on the service's turn.end — async\n    32\t    // iteration collects the full audio, mirroring the library's own toFile.\n    33\t    const chunks: Buffer[] = [];\n    34\t    for await (const chunk of tts.toStream(text)) {\n    35\t      chunks.push(chunk as Buffer);\n    36\t    }\n    37\t    const bytes = new Uint8Array(Buffer.concat(chunks));\n    38\t    if (bytes.length === 0) {\n    39\t      // Same failure the library's toFile raised (\"No audio data received\"):\n    40\t      // never persist an empty audio file as a playable path.\n    41\t      throw new Error(\"Aucune donnée audio reçue de msedge-tts.\");\n    42\t    }\n    43\t\n    44\t    return saveMedia(`${generateId(\"audio\")}.mp3`, bytes);\n    45\t  },\n    46\t};\n","exit_code":0,"status":"completed"}}
