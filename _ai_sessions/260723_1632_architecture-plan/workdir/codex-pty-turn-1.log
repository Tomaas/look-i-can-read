del(data.imageModel, serverEnv.imageModel);\n    50\t    if (!serverEnv.imageEnabled) {\n    51\t      console.warn(\n    52\t        \"[stories] test image gen SKIPPED — IMAGE_ENABLED is false (set IMAGE_ENABLED=true to enable)\"\n    53\t      );\n    54\t      return { imagePath: null, imageStatus: \"skipped\", model, ms: 0 };\n    55\t    }\n    56\t\n    57\t    const startedAt = Date.now();\n    58\t    console.log(\"[stories] test image gen START\", {\n    59\t      model,\n    60\t      promptLen: data.prompt.length,\n    61\t      resolution: serverEnv.imageResolution,\n    62\t    });\n    63\t\n    64\t    try {\n    65\t      // Send the prompt AS-IS — the parent has full control (no style suffix\n    66\t      // auto-append; the playground prefill already carries it).\n    67\t      const imagePath = await generateImage(data.prompt, model);\n    68\t      const ms = Date.now() - startedAt;\n    69\t      console.log(\"[stories] test image gen DONE\", { imagePath, model, ms });\n    70\t      return { imagePath, imageStatus: \"ready\", model, ms };\n    71\t    } catch (error) {\n    72\t      const ms = Date.now() - startedAt;\n    73\t      // Non-silent: log the real reason (model + cause) so the operator sees a\n    74\t      // Gemini billing/quota denial; the parent gets a calm inline message.\n    75\t      console.error(\n    76\t        `[stories] test image generation FAILED (model=${model}, ms=${ms}): ` +\n    77\t          (error instanceof Error ? error.message : String(error))\n    78\t      );\n    79\t      return { imagePath: null, imageStatus: \"failed\", model, ms };\n    80\t    }\n    81\t  });\n    82\t\n    83\t/**\n    84\t * Synthesize the story audio (only when TTS_ENABLED). Cached on the row so a\n    85\t * re-listen doesn't regenerate.\n    86\t */\n    87\texport const synthesizeFn = createServerFn({ method: \"POST\" })\n    88\t  .validator(z.object({ id: z.string() }))\n    89\t  .handler(async ({ data }): Promise<{ audioPath: string | null }> => {\n    90\t    if (!serverEnv.ttsEnabled) {\n    91\t      return { audioPath: null };\n    92\t    }\n    93\t\n    94\t    const [story] = await db\n    95\t      .select()\n    96\t      .from(stories)\n    97\t      .where(eq(stories.id, data.id));\n    98\t    if (!story) {\n    99\t      return { audioPath: null };\n   100\t    }\n   101\t    if (story.audioPath) {\n   102\t      return { audioPath: story.audioPath };\n   103\t    }\n   104\t\n   105\t    const provider = getTtsProvider();\n   106\t\n   107\t    const fullText = [story.title, ...story.paragraphs].join(\". \");\n   108\t\n   109\t    try {\n   110\t      const audioPath = await provider.synthesize(\n   111\t        fullText,\n   112\t        story.lang as \"fr\" | \"ru\"\n   113\t      );\n   114\t      await db\n   115\t        .update(stories)\n   116\t        .set({ audioPath })\n   117\t        .where(eq(stories.id, data.id));\n   118\t      return { audioPath };\n   119\t    } catch {\n   120\t      return { audioPath: null };\n   121\t    }\n   122\t  });\n   123\t\n   124\t/**\n   125\t * Kept stories, newest first — for the library. Only DYNAMIC stories appear:\n   126\t * the classic viewer is gone, so old classic rows are simply never listed\n   127\t * (no dead tiles, no broken taps).\n   128\t */\n   129\texport const getLibraryFn = createServerFn({ method: \"GET\" }).handler(() =>\n   130\t  db\n   131\t    .select()\n   132\t    .from(stories)\n   133\t    .where(and(eq(stories.kept, \"1\"), eq(stories.mode, \"dynamic\")))\n   134\t    .orderBy(desc(stories.createdAt))\n   135\t);\n     1\t/**\n     2\t * Server-only environment access.\n     3\t *\n     4\t * Vite only exposes variables prefixed with `VITE_` to the client bundle, so\n     5\t * every key read here (API keys, the DB URL, provider flags) stays on the\n     6\t * server. These getters are only ever called inside server functions /\n     7\t * providers — never from a component.\n     8\t */\n     9\t\n    10\tfunction bool(value: string | undefined, fallback: boolean): boolean {\n    11\t  if (value === undefined) {\n    12\t    return fallback;\n    13\t  }\n    14\t  return value === \"true\" || value === \"1\";\n    15\t}\n    16\t\n    17\tconst imageEnabled = bool(process.env.IMAGE_ENABLED, false);\n    18\tconst ttsEnabled = bool(process.env.TTS_ENABLED, false);\n    19\t\n    20\t// Image output resolution tier for Gemini image models (cost is per output\n    21\t// token, and the model is resolution-tiered). The illustration shows in a modest\n    22\t// 4/3 container, so 1K is plenty and far cheaper than the model's higher tiers —\n    23\t// this is the default. Tunable via IMAGE_RESOLUTION without a code change.\n    24\t// Accepted values are exactly the @ai-sdk/google `imageConfig.imageSize` enum\n    25\t// (\"512\" = the 0.5K tier, \"1K\"/\"2K\"/\"4K\"); anything else falls back to \"1K\" so a\n    26\t// typo can never send an invalid param. A model that ignores imageConfig (e.g.\n    27\t// gemini-2.5-flash-image) still works — the param is simply not applied.\n    28\tconst IMAGE_SIZES = [\"512\", \"1K\", \"2K\", \"4K\"] as const;\n    29\ttype ImageSize = (typeof IMAGE_SIZES)[number];\n    30\tconst rawImageResolution = process.env.IMAGE_RESOLUTION;\n    31\tconst imageResolution: ImageSize = IMAGE_SIZES.includes(\n    32\t  rawImageResolution as ImageSize\n    33\t)\n    34\t  ? (rawImageResolution as ImageSize)\n    35\t  : \"1K\";\n    36\tconst ttsProvider = (process.env.TTS_PROVIDER ?? \"edge\") as\n    37\t  | \"edge\"\n    38\t  | \"elevenlabs\";\n    39\t\n    40\t// biome-ignore assist/source/useSortedKeys: groupement SÉMANTIQUE (requis vs optionnel, par fonctionnalité) — les commentaires de section documentent chaque groupe.\n    41\texport const serverEnv = {\n    42\t  // Text generation (required).\n    43\t  anthropicApiKey: process.env.ANTHROPIC_API_KEY ?? \"\",\n    44\t  storyModel: process.env.STORY_MODEL ?? \"claude-opus-4-8\",\n    45\t\n    46\t  // Image generation (optional, off by default).\n    47\t  imageEnabled,\n    48\t  geminiApiKey: process.env.GEMINI_API_KEY ?? \"\",\n    49\t  imageModel: process.env.IMAGE_MODEL ?? \"gemini-2.5-flash-image\",\n    50\t  // Output resolution tier (see above) — pinned low to cut generation cost.\n    51\t  imageResolution,\n    52\t\n    53\t  // Text-to-speech (optional, off by default).\n    54\t  ttsEnabled,\n    55\t  ttsProvider,\n    56\t  elevenLabsApiKey: process.env.ELEVENLABS_API_KEY ?? \"\",\n    57\t\n    58\t  // Media storage. When set (e.g. on Vercel), generated images are persisted to\n    59\t  // Vercel Blob and stored as public https:// URLs. When unset, media falls\n    60\t  // back to local disk under dataDir (offline dev). Optional, server-only.\n    61\t  blobReadWriteToken: process.env.BLOB_READ_WRITE_TOKEN ?? \"\",\n    62\t\n    63\t  // Misc.\n    64\t  defaultLang: (process.env.DEFAULT_LANG ?? \"fr\") as \"fr\" | \"ru\",\n    65\t  dataDir: process.env.DATA_DIR ?? \"./data\",\n    66\t\n    67\t  // Database — remote Turso cloud (required, no local/offline mode).\n    68\t  databaseUrl: process.env.DATABASE_URL ?? \"\",\n    69\t  tursoAuthToken: process.env.TURSO_AUTH_TOKEN ?? \"\",\n    70\t} as const;\n    71\t\n    72\t/**\n    73\t * Validate required env at startup so a misconfiguration fails loudly with a\n    74\t * clear message instead of a cryptic libSQL / provider error mid-request.\n    75\t * Conditional: image/TTS keys are only required when their flag is on.\n    76\t * Skipped when SKIP_ENV_VALIDATION is set (used by the build).\n    77\t */\n    78\tfunction validateServerEnv(): void {\n    79\t  if (process.env.SKIP_ENV_VALIDATION) {\n    80\t    return;\n    81\t  }\n    82\t\n    83\t  const errors: string[] = [];\n    84\t\n    85\t  if (!serverEnv.anthropicApiKey) {\n    86\t    errors.push(\"ANTHROPIC_API_KEY est requis.\");\n    87\t  }\n    88\t\n    89\t  if (!serverEnv.databaseUrl) {\n    90\t    errors.push(\"DATABASE_URL est requis (Turso cloud).\");\n    91\t  } else if (\n    92\t    !(\n    93\t      serverEnv.databaseUrl.startsWith(\"libsql://\") ||\n    94\t      serverEnv.databaseUrl.startsWith(\"https://\")\n    95\t    )\n    96\t  ) {\n    97\t    errors.push(\n    98\t      \"DATABASE_URL doit être une URL Turso (libsql://<db>.turso.io). Le mode fichier local n'est plus supporté.\"\n    99\t    );\n   100\t  }\n   101\t\n   102\t  if (!serverEnv.tursoAuthToken) {\n   103\t    errors.push(\"TURSO_AUTH_TOKEN est requis (Turso cloud).\");\n   104\t  }\n   105\t\n   106\t  if (serverEnv.imageEnabled && !serverEnv.geminiApiKey) {\n   107\t    errors.push(\"GEMINI_API_KEY est requis quand IMAGE_ENABLED=true.\");\n   108\t  }\n   109\t\n   110\t  if (\n   111\t    serverEnv.ttsEnabled &&\n   112\t    serverEnv.ttsProvider === \"elevenlabs\" &&\n   113\t    !serverEnv.elevenLabsApiKey\n   114\t  ) {\n   115\t    errors.push(\n   116\t      \"ELEVENLABS_API_KEY est requis quand TTS_ENABLED=true et TTS_PROVIDER=elevenlabs.\"\n   117\t    );\n   118\t  }\n   119\t\n   120\t  if (errors.length > 0) {\n   121\t    throw new Error(\n   122\t      `Configuration [redacted-internal-hostname] incomplète :\\n- ${errors.join(\"\\n- \")}`\n   123\t    );\n   124\t  }\n   125\t}\n   126\t\n   127\tvalidateServerEnv();\n   128\t\n   129\t/**\n   130\t * Flags that are safe to send to the client so the UI can hide/show the\n   131\t * \"Écouter\" button and the illustration slot. No secrets here.\n   132\t */\n   133\texport interface PublicFlags {\n   134\t  defaultLang: \"fr\" | \"ru\";\n   135\t  imageEnabled: boolean;\n   136\t  // The env default image model, mirrored so the /parents picker's \"par défaut\"\n   137\t  // badge + the localStorage hook's default track the deployed env (not a\n   138\t  // hard-coded mirror). The id itself is not a secret.\n   139\t  imageModel: string;\n   140\t  ttsEnabled: boolean;\n   141\t}\n   142\t\n   143\texport function getPublicFlags(): PublicFlags {\n   144\t  return {\n   145\t    defaultLang: serverEnv.defaultLang,\n   146\t    imageEnabled: serverEnv.imageEnabled,\n   147\t    imageModel: serverEnv.imageModel,\n   148\t    ttsEnabled: serverEnv.ttsEnabled,\n   149\t  };\n   150\t}\n","exit_code":0,"status":"completed"}}
